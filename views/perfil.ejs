<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil — Gestor Viviendas</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Inter', system-ui, sans-serif; background: #F4F6F9; color: #0F172A; }

        .pf-page { max-width: 960px; margin: 0 auto; padding: 2.25rem 1.5rem 3.5rem; }

        /* ===== Page header ===== */
        .pf-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; }
        .pf-header-icon {
            width: 52px; height: 52px; border-radius: 14px;
            background: linear-gradient(135deg, #0F172A, #334155);
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 10px rgba(15,23,42,.2);
            flex-shrink: 0;
        }
        .pf-header-icon i { color: #fff; font-size: 1.35rem; }
        .pf-header-text h1 { font-size: 1.5rem; font-weight: 800; color: #0F172A; }
        .pf-header-text p { font-size: .875rem; color: #64748B; margin-top: .2rem; }

        /* ===== Flash messages ===== */
        .pf-alert {
            display: flex; align-items: center; gap: .625rem;
            padding: .875rem 1.125rem; border-radius: 10px;
            font-size: .875rem; font-weight: 500; margin-bottom: 1.5rem;
        }
        .pf-alert--success { background: #D1FAE5; color: #065F46; border: 1px solid #A7F3D0; }
        .pf-alert--error   { background: #FEE2E2; color: #991B1B; border: 1px solid #FECACA; }

        /* ===== Layout grid ===== */
        .pf-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
        @media (max-width: 700px) { .pf-grid { grid-template-columns: 1fr; } }

        /* ===== Cards ===== */
        .pf-card {
            background: #fff; border: 1px solid #E2E8F0;
            border-radius: 14px; box-shadow: 0 1px 3px rgba(15,23,42,.06);
            overflow: hidden;
        }
        .pf-card--full { grid-column: 1 / -1; }

        .pf-card-header {
            padding: 1.1rem 1.5rem .9rem;
            border-bottom: 1px solid #F1F5F9;
            display: flex; align-items: center; gap: .6rem;
        }
        .pf-card-header-icon {
            width: 32px; height: 32px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center; font-size: .9rem;
        }
        .pf-card-header-icon.navy  { background: #EFF6FF; color: #1D4ED8; }
        .pf-card-header-icon.teal  { background: #CCFBF1; color: #0D9488; }
        .pf-card-header-icon.amber { background: #FEF3C7; color: #B45309; }
        .pf-card-header h2 { font-size: .9375rem; font-weight: 700; color: #0F172A; }
        .pf-card-sub { font-size: .75rem; color: #94A3B8; margin-left: auto; }

        .pf-card-body { padding: 1.5rem; }

        /* ===== Form ===== */
        .pf-field { margin-bottom: 1.1rem; }
        .pf-field:last-child { margin-bottom: 0; }
        .pf-label {
            display: block; font-size: .75rem; font-weight: 700;
            color: #475569; text-transform: uppercase; letter-spacing: .05em;
            margin-bottom: .4rem;
        }
        .pf-input {
            width: 100%; padding: .625rem .875rem;
            border: 1.5px solid #E2E8F0; border-radius: 10px;
            font-size: .9rem; color: #0F172A; background: #fff;
            font-family: inherit; outline: none;
            transition: border-color .15s, box-shadow .15s;
        }
        .pf-input:focus { border-color: #0F172A; box-shadow: 0 0 0 3px rgba(15,23,42,.07); }
        .pf-input:read-only {
            background: #F8FAFC; color: #64748B; cursor: default;
            border-color: #E2E8F0 !important; box-shadow: none !important;
        }
        .pf-input-hint { font-size: .72rem; color: #94A3B8; margin-top: .3rem; }
        .pf-readonly-badge {
            display: inline-flex; align-items: center; gap: .3rem;
            font-size: .65rem; font-weight: 700; color: #94A3B8;
            background: #F1F5F9; border-radius: 99px; padding: .15rem .5rem;
            margin-left: .4rem; vertical-align: middle;
        }

        .pf-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        @media (max-width: 500px) { .pf-row { grid-template-columns: 1fr; } }

        /* ===== Buttons ===== */
        .pf-btn-primary {
            display: inline-flex; align-items: center; gap: .45rem;
            padding: .6rem 1.35rem; border-radius: 10px;
            background: #0F172A; color: #fff; border: none;
            font-size: .875rem; font-weight: 600; font-family: inherit;
            cursor: pointer; transition: background .15s;
        }
        .pf-btn-primary:hover { background: #1E293B; }

        .pf-btn-danger {
            display: inline-flex; align-items: center; gap: .45rem;
            padding: .6rem 1.35rem; border-radius: 10px;
            background: #FEF2F2; color: #EF4444; border: 1.5px solid #FECACA;
            font-size: .875rem; font-weight: 600; font-family: inherit;
            cursor: pointer; transition: background .15s;
        }
        .pf-btn-danger:hover { background: #FEE2E2; }

        .pf-btn-row { display: flex; justify-content: flex-end; margin-top: 1.25rem; }

        /* ===== User avatar / info card ===== */
        .pf-avatar-row {
            display: flex; align-items: center; gap: 1.25rem;
            padding: 1.5rem; border-bottom: 1px solid #F1F5F9;
        }
        .pf-avatar {
            width: 64px; height: 64px; border-radius: 50%;
            background: linear-gradient(135deg, #0F172A, #334155);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; font-size: 1.5rem; font-weight: 800; color: #fff;
        }
        .pf-avatar-name { font-size: 1.1rem; font-weight: 700; color: #0F172A; }
        .pf-avatar-email { font-size: .8rem; color: #64748B; margin-top: .15rem; }
        .pf-avatar-meta {
            display: flex; gap: .5rem; flex-wrap: wrap; margin-top: .5rem;
        }
        .pf-meta-pill {
            display: inline-flex; align-items: center; gap: .3rem;
            font-size: .72rem; font-weight: 600;
            padding: .2rem .6rem; border-radius: 99px;
        }
        .pf-meta-pill--teal   { background: #CCFBF1; color: #0D9488; }
        .pf-meta-pill--gray   { background: #F1F5F9; color: #475569; }

        /* ===== Password strength ===== */
        .pf-pwd-strength { margin-top: .4rem; }
        .pf-pwd-strength-bar {
            height: 4px; border-radius: 99px; background: #E2E8F0; margin-bottom: .3rem;
            overflow: hidden;
        }
        .pf-pwd-strength-fill { height: 100%; border-radius: 99px; transition: width .3s, background .3s; width: 0; }
        .pf-pwd-strength-label { font-size: .72rem; color: #94A3B8; }

        /* ===== Divider ===== */
        .pf-divider { border: none; border-top: 1px solid #F1F5F9; margin: 1.25rem 0; }
    </style>
</head>
<body>

<%- include('partials/navbar', { isAuthenticated: true, user: user }) %>

<div class="pf-page">

    <!-- Page header -->
    <div class="pf-header">
        <div class="pf-header-icon"><i class="bi bi-person-circle"></i></div>
        <div class="pf-header-text">
            <h1>Mi Perfil</h1>
            <p>Gestiona tu información personal y seguridad de la cuenta</p>
        </div>
    </div>

    <!-- Flash messages -->
    <% if (success && success.length > 0) { %>
    <div class="pf-alert pf-alert--success" id="pf-flash">
        <i class="bi bi-check-circle-fill"></i> <%= success[0] %>
    </div>
    <% } %>
    <% if (error && error.length > 0) { %>
    <div class="pf-alert pf-alert--error" id="pf-flash">
        <i class="bi bi-exclamation-circle-fill"></i> <%= error[0] %>
    </div>
    <% } %>

    <div class="pf-grid">

        <!-- ===== Avatar / resumen ===== -->
        <div class="pf-card pf-card--full">
            <div class="pf-avatar-row">
                <div class="pf-avatar"><%= (user.nombre || 'U').charAt(0).toUpperCase() %></div>
                <div>
                    <div class="pf-avatar-name"><%= user.nombre %><% if (user.apellidos) { %> <%= user.apellidos %><% } %></div>
                    <div class="pf-avatar-email"><%= user.email %></div>
                    <div class="pf-avatar-meta">
                        <span class="pf-meta-pill pf-meta-pill--teal"><i class="bi bi-check-circle-fill"></i> Cuenta activa</span>
                        <span class="pf-meta-pill pf-meta-pill--gray"><i class="bi bi-calendar3"></i>
                            Miembro desde <%= new Date(user.fecha_alta).toLocaleDateString('es-ES', { year: 'numeric', month: 'long' }) %>
                        </span>
                        <% if (user.google_id) { %>
                        <span class="pf-meta-pill pf-meta-pill--gray"><i class="bi bi-google"></i> Google</span>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== Información personal ===== -->
        <div class="pf-card pf-card--full">
            <div class="pf-card-header">
                <div class="pf-card-header-icon navy"><i class="bi bi-person-fill"></i></div>
                <h2>Información personal</h2>
                <span class="pf-card-sub">Los campos con <i class="bi bi-lock-fill" style="font-size:.65rem;"></i> no son editables</span>
            </div>
            <div class="pf-card-body">
                <form method="POST" action="/perfil">
                    <div class="pf-row">
                        <div class="pf-field">
                            <label class="pf-label">Nombre</label>
                            <input class="pf-input" type="text" name="nombre"
                                value="<%= user.nombre || '' %>" required maxlength="100"
                                placeholder="Tu nombre">
                        </div>
                        <div class="pf-field">
                            <label class="pf-label">Apellidos</label>
                            <input class="pf-input" type="text" name="apellidos"
                                value="<%= user.apellidos || '' %>" maxlength="100"
                                placeholder="Tus apellidos">
                        </div>
                    </div>

                    <div class="pf-row">
                        <div class="pf-field">
                            <label class="pf-label">
                                Email
                                <span class="pf-readonly-badge"><i class="bi bi-lock-fill"></i> único</span>
                            </label>
                            <input class="pf-input" type="email" value="<%= user.email %>" readonly>
                            <div class="pf-input-hint">El email no puede modificarse porque es tu identificador único</div>
                        </div>
                        <div class="pf-field">
                            <label class="pf-label">Teléfono</label>
                            <input class="pf-input" type="tel" name="telefono"
                                value="<%= user.telefono || '' %>" maxlength="20"
                                placeholder="+34 600 000 000">
                        </div>
                    </div>

                    <hr class="pf-divider">

                    <div class="pf-row">
                        <div class="pf-field">
                            <label class="pf-label">Razón social</label>
                            <input class="pf-input" type="text" name="razon_social"
                                value="<%= user.razon_social || '' %>" maxlength="200"
                                placeholder="Nombre de empresa (opcional)">
                        </div>
                        <div class="pf-field">
                            <label class="pf-label">
                                DNI / CIF
                                <span class="pf-readonly-badge"><i class="bi bi-lock-fill"></i> único</span>
                            </label>
                            <input class="pf-input" type="text"
                                value="<%= user.dni_cif || '—' %>" readonly>
                            <div class="pf-input-hint">Para modificar el DNI/CIF contacta con soporte</div>
                        </div>
                    </div>

                    <div class="pf-btn-row">
                        <button type="submit" class="pf-btn-primary">
                            <i class="bi bi-check-lg"></i> Guardar cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ===== Cambiar contraseña ===== -->
        <div class="pf-card pf-card--full">
            <div class="pf-card-header">
                <div class="pf-card-header-icon amber"><i class="bi bi-shield-lock-fill"></i></div>
                <h2>Seguridad · Cambiar contraseña</h2>
            </div>
            <div class="pf-card-body">
                <% if (user.google_id && !user.password_hash) { %>
                <div style="text-align:center;padding:1.5rem;color:#64748B;font-size:.875rem;">
                    <i class="bi bi-google" style="font-size:1.5rem;display:block;margin-bottom:.5rem;color:#94A3B8;"></i>
                    Tu cuenta utiliza inicio de sesión con Google. No tiene contraseña local configurada.
                </div>
                <% } else { %>
                <form method="POST" action="/perfil/cambiar-password" id="pwd-form">
                    <div class="pf-row">
                        <div class="pf-field">
                            <label class="pf-label">Contraseña actual</label>
                            <input class="pf-input" type="password" name="password_actual"
                                required autocomplete="current-password" placeholder="••••••••">
                        </div>
                        <div style="display:flex;flex-direction:column;gap:.4rem;">
                            <!-- spacer for alignment -->
                        </div>
                    </div>
                    <div class="pf-row">
                        <div class="pf-field">
                            <label class="pf-label">Nueva contraseña</label>
                            <input class="pf-input" type="password" name="password_nuevo"
                                id="pwd-new" required autocomplete="new-password"
                                placeholder="Mínimo 6 caracteres" oninput="updateStrength(this.value)">
                            <div class="pf-pwd-strength" id="pwd-strength" style="display:none;">
                                <div class="pf-pwd-strength-bar">
                                    <div class="pf-pwd-strength-fill" id="pwd-strength-fill"></div>
                                </div>
                                <div class="pf-pwd-strength-label" id="pwd-strength-label"></div>
                            </div>
                        </div>
                        <div class="pf-field">
                            <label class="pf-label">Confirmar nueva contraseña</label>
                            <input class="pf-input" type="password" name="password_confirmar"
                                id="pwd-confirm" required autocomplete="new-password"
                                placeholder="Repite la contraseña" oninput="checkMatch()">
                            <div class="pf-input-hint" id="pwd-match-hint"></div>
                        </div>
                    </div>
                    <div class="pf-btn-row">
                        <button type="submit" class="pf-btn-danger">
                            <i class="bi bi-shield-lock"></i> Cambiar contraseña
                        </button>
                    </div>
                </form>
                <% } %>
            </div>
        </div>

    </div><!-- /pf-grid -->
</div><!-- /pf-page -->

<script>
// Auto-dismiss flash after 4s
const flash = document.getElementById('pf-flash');
if (flash) setTimeout(() => flash.style.opacity === '' && flash.remove(), 4000);

// Password strength
function updateStrength(val) {
    const bar = document.getElementById('pwd-strength-fill');
    const label = document.getElementById('pwd-strength-label');
    const wrap = document.getElementById('pwd-strength');
    if (!val) { wrap.style.display = 'none'; return; }
    wrap.style.display = 'block';
    let score = 0;
    if (val.length >= 6)  score++;
    if (val.length >= 10) score++;
    if (/[A-Z]/.test(val)) score++;
    if (/[0-9]/.test(val)) score++;
    if (/[^A-Za-z0-9]/.test(val)) score++;
    const levels = [
        { pct: '20%',  bg: '#EF4444', text: 'Muy débil' },
        { pct: '40%',  bg: '#F59E0B', text: 'Débil' },
        { pct: '60%',  bg: '#F59E0B', text: 'Aceptable' },
        { pct: '80%',  bg: '#10B981', text: 'Buena' },
        { pct: '100%', bg: '#059669', text: 'Excelente' },
    ];
    const lvl = levels[Math.min(score, 4)];
    bar.style.width = lvl.pct;
    bar.style.background = lvl.bg;
    label.textContent = lvl.text;
    label.style.color = lvl.bg;
}

// Password match hint
function checkMatch() {
    const newP = document.getElementById('pwd-new').value;
    const conf = document.getElementById('pwd-confirm').value;
    const hint = document.getElementById('pwd-match-hint');
    if (!conf) { hint.textContent = ''; return; }
    if (newP === conf) {
        hint.textContent = '✓ Las contraseñas coinciden';
        hint.style.color = '#10B981';
    } else {
        hint.textContent = '✗ Las contraseñas no coinciden';
        hint.style.color = '#EF4444';
    }
}
</script>

</body>
</html>
