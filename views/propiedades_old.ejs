<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Propiedades - Gestor Viviendas' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#2563eb',
                        secondary: '#fbbf24',
                        accent: '#60a5fa',
                    }
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
        
        .filter-btn.active {
            @apply bg-blue-600 text-white border-blue-600;
        }
    </style>
</head>
<body class="bg-gradient-to-br from-blue-50 via-white to-amber-50 min-h-screen">
    
    <%- include('partials/navbar') %>

    <div class="container mx-auto px-4 py-8 max-w-7xl mb-16">
        <!-- Encabezado -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-gray-800 mb-2 tracking-tight">Mis Propiedades</h1>
            <p class="text-gray-600 text-base">Gestiona y administra todas tus viviendas en un solo lugar</p>
        </div>

        <!-- Dashboard de Estadísticas -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <!-- Total Propiedades -->
            <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-2 border border-blue-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-600 mb-1">Propiedades Totales</p>
                        <p class="text-4xl font-bold text-blue-600"><%= stats.total %></p>
                    </div>
                    <div class="bg-blue-100 rounded-xl p-4">
                        <i class="bi bi-house-door text-3xl text-blue-600"></i>
                    </div>
                </div>
                <div class="mt-4 flex items-center text-xs text-gray-500">
                    <i class="bi bi-graph-up text-blue-500 mr-1"></i>
                    <span>Total gestionadas</span>
                </div>
            </div>
            
            <!-- Propiedades Ocupadas -->
            <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-2 border border-red-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-600 mb-1">Ocupadas</p>
                        <p class="text-4xl font-bold text-red-600"><%= stats.ocupadas %></p>
                    </div>
                    <div class="bg-red-100 rounded-xl p-4">
                        <i class="bi bi-lock-fill text-3xl text-red-600"></i>
                    </div>
                </div>
                <div class="mt-4 flex items-center text-xs text-gray-500">
                    <i class="bi bi-calendar-check text-red-500 mr-1"></i>
                    <span>Con reservas activas</span>
                </div>
            </div>
            
            <!-- Propiedades Libres -->
            <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-2 border border-green-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-600 mb-1">Disponibles</p>
                        <p class="text-4xl font-bold text-green-600"><%= stats.libres %></p>
                    </div>
                    <div class="bg-green-100 rounded-xl p-4">
                        <i class="bi bi-check-circle-fill text-3xl text-green-600"></i>
                    </div>
                </div>
                <div class="mt-4 flex items-center text-xs text-gray-500">
                    <i class="bi bi-door-open text-green-500 mr-1"></i>
                    <span>Listas para alquilar</span>
                </div>
            </div>
        </div>

        <!-- Buscador y Filtros -->
        <div class="bg-white rounded-2xl p-6 shadow-lg mb-8 border border-gray-100">
            <div class="flex flex-col lg:flex-row gap-4 items-center">
                <div class="flex-1 w-full relative">
                    <i class="bi bi-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-lg"></i>
                    <input type="search" id="searchInput" 
                           class="w-full pl-12 pr-4 py-3 border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition-all outline-none text-sm" 
                           placeholder="Buscar propiedad por nombre o dirección...">
                </div>
                <div class="flex gap-3 w-full lg:w-auto">
                    <button class="filter-btn flex-1 lg:flex-none px-6 py-3 rounded-xl font-semibold text-sm transition-all bg-blue-600 text-white border-2 border-blue-600 hover:bg-blue-700 active" data-filter="todas">
                        <i class="bi bi-grid-3x3-gap mr-2"></i>Todas
                    </button>
                    <button class="filter-btn flex-1 lg:flex-none px-6 py-3 rounded-xl font-semibold text-sm transition-all bg-white text-gray-700 border-2 border-gray-200 hover:border-blue-500 hover:bg-blue-50 hover:text-blue-600" data-filter="libres">
                        <i class="bi bi-check-circle mr-2"></i>Libres
                    </button>
                    <button class="filter-btn flex-1 lg:flex-none px-6 py-3 rounded-xl font-semibold text-sm transition-all bg-white text-gray-700 border-2 border-gray-200 hover:border-blue-500 hover:bg-blue-50 hover:text-blue-600" data-filter="ocupadas">
                        <i class="bi bi-lock mr-2"></i>Ocupadas
                    </button>
                </div>
            </div>
        </div>

        <!-- Grid de Propiedades -->
        <% if (viviendas && viviendas.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8" id="propertiesGrid">
                <% viviendas.forEach(vivienda => { 
                    const isOcupada = false;
                    const estado = isOcupada ? 'ocupada' : 'libre';
                    const nombre = vivienda.tipo_vivienda || 'Propiedad';
                %>
                <div class="bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100 property-card" data-status="<%= estado %>">
                    <!-- Imagen de la propiedad -->
                    <div class="relative h-48">
                        <% if (vivienda.imagen_url) { %>
                            <img src="<%= vivienda.imagen_url %>" alt="<%= nombre %>" class="w-full h-full object-cover">
                        <% } else { %>
                            <div class="w-full h-full bg-gradient-to-br from-blue-400 via-blue-500 to-blue-600 flex items-center justify-center">
                                <i class="bi bi-house-door text-7xl text-white opacity-80"></i>
                            </div>
                        <% } %>
                        
                        <!-- Badge de estado -->
                        <div class="absolute top-4 right-4 <%= isOcupada ? 'bg-red-500' : 'bg-green-500' %> text-white px-4 py-2 rounded-full font-semibold text-xs shadow-lg flex items-center gap-2">
                            <span class="w-2 h-2 bg-white rounded-full animate-pulse"></span>
                            <%= isOcupada ? 'Ocupada' : 'Libre' %>
                        </div>
                    </div>
                    
                    <!-- Contenido de la tarjeta -->
                    <div class="p-6">
                        <h3 class="text-xl font-bold text-gray-800 mb-3"><%= nombre %></h3>
                        
                        <div class="flex items-start gap-2 text-gray-600 mb-4">
                            <i class="bi bi-geo-alt-fill text-blue-500 text-lg mt-0.5"></i>
                            <span class="text-sm leading-relaxed"><%= vivienda.direccion || 'Sin dirección' %>, <%= vivienda.ciudad || '' %></span>
                        </div>
                        
                        <!-- Detalles -->
                        <div class="flex items-center gap-4 py-4 border-t border-b border-gray-100 mb-4">
                            <div class="flex items-center gap-2 text-gray-700">
                                <i class="bi bi-people-fill text-blue-500"></i>
                                <span class="text-sm font-medium"><%= vivienda.capacidad || 0 %></span>
                            </div>
                            <div class="flex items-center gap-2 text-gray-700">
                                <i class="bi bi-door-closed-fill text-blue-500"></i>
                                <span class="text-sm font-medium"><%= vivienda.habitaciones || 0 %></span>
                            </div>
                            <div class="flex items-center gap-2 text-gray-700">
                                <i class="bi bi-droplet-fill text-blue-500"></i>
                                <span class="text-sm font-medium"><%= vivienda.banos || 0 %></span>
                            </div>
                        </div>
                        
                        <!-- Botones de acción -->
                        <div class="grid grid-cols-3 gap-2">
                            <button class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-2.5 rounded-lg font-semibold text-xs transition-all hover:-translate-y-1 shadow-md hover:shadow-lg flex items-center justify-center gap-1">
                                <i class="bi bi-eye"></i>
                                <span class="hidden sm:inline">Ver</span>
                            </button>
                            <button class="bg-amber-500 hover:bg-amber-600 text-white px-3 py-2.5 rounded-lg font-semibold text-xs transition-all hover:-translate-y-1 shadow-md hover:shadow-lg flex items-center justify-center gap-1">
                                <i class="bi bi-pencil"></i>
                                <span class="hidden sm:inline">Editar</span>
                            </button>
                            <button class="bg-white hover:bg-red-500 text-red-600 hover:text-white border-2 border-red-500 px-3 py-2.5 rounded-lg font-semibold text-xs transition-all hover:-translate-y-1 shadow-md hover:shadow-lg flex items-center justify-center gap-1 btn-delete" 
                                    data-property-id="<%= vivienda.id_vivienda %>" 
                                    data-property-name="<%= nombre %>">
                                <i class="bi bi-trash"></i>
                                <span class="hidden sm:inline">Borrar</span>
                            </button>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
            
            <!-- Mensaje cuando no hay resultados de búsqueda/filtro -->
            <div class="bg-white rounded-2xl p-12 text-center shadow-lg border border-gray-100 hidden" id="noResultsMessage">
                <i class="bi bi-search text-7xl text-gray-300 mb-4"></i>
                <h3 class="text-2xl font-bold text-gray-700 mb-2">No se encontraron resultados</h3>
                <p class="text-gray-500">Intenta con otros términos de búsqueda o ajusta los filtros</p>
            </div>
        <% } else { %>
            <div class="bg-white rounded-2xl p-12 text-center shadow-lg border border-gray-100">
                <i class="bi bi-house-slash text-7xl text-gray-300 mb-4"></i>
                <h3 class="text-2xl font-bold text-gray-700 mb-2">No tienes propiedades registradas</h3>
                <p class="text-gray-500 mb-6">Comienza agregando tu primera vivienda</p>
            </div>
        <% } %>

        <!-- Botón Agregar Propiedad -->
        <div class="mt-8">
            <button class="w-full bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white py-6 rounded-2xl font-bold text-lg shadow-lg hover:shadow-xl transition-all hover:-translate-y-1 border-3 border-blue-700" id="btnAddProperty">
                <i class="bi bi-plus-circle mr-3 text-2xl"></i>Agregar Nueva Vivienda
            </button>
        </div>
    </div>

    <!-- Modal de Confirmación de Eliminación -->
    <div class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50" id="deleteModal">
        <div class="bg-white rounded-2xl max-w-md w-full mx-4 shadow-2xl">
            <div class="p-6 border-b border-gray-200">
                <div class="flex items-center gap-3">
                    <div class="bg-red-100 rounded-full p-3">
                        <i class="bi bi-exclamation-triangle-fill text-red-600 text-2xl"></i>
                    </div>
                    <h5 class="text-xl font-bold text-gray-800">Confirmar Eliminación</h5>
                </div>
            </div>
            <div class="p-6">
                <p class="text-gray-700 mb-2">¿Estás seguro de que quieres eliminar <strong id="propertyNameToDelete" class="text-gray-900"></strong>?</p>
                <p class="text-red-600 text-sm font-semibold">⚠️ Esta acción no se puede deshacer.</p>
            </div>
            <div class="p-6 border-t border-gray-200 flex gap-3">
                <button type="button" class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-800 px-6 py-3 rounded-xl font-semibold transition-all" id="cancelDelete">
                    <i class="bi bi-x-circle mr-2"></i>Cancelar
                </button>
                <button type="button" class="flex-1 bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-xl font-semibold transition-all" id="confirmDelete">
                    <i class="bi bi-trash-fill mr-2"></i>Eliminar
                </button>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script>
        // Funcionalidad de búsqueda
        const searchInput = document.getElementById('searchInput');
        const propertiesGrid = document.getElementById('propertiesGrid');
        const noResultsMessage = document.getElementById('noResultsMessage');
        
        if (searchInput && propertiesGrid) {
            searchInput.addEventListener('input', function(e) {
                const searchTerm = e.target.value.toLowerCase();
                const cards = propertiesGrid.querySelectorAll('.property-card');
                let visibleCount = 0;
                
                cards.forEach(card => {
                    const title = card.querySelector('h3').textContent.toLowerCase();
                    const address = card.querySelector('.bi-geo-alt-fill').parentElement.textContent.toLowerCase();
                    
                    if (title.includes(searchTerm) || address.includes(searchTerm)) {
                        card.classList.remove('hidden');
                        visibleCount++;
                    } else {
                        card.classList.add('hidden');
                    }
                });
                
                // Mostrar/ocultar mensaje de no resultados
                if (noResultsMessage) {
                    if (visibleCount === 0) {
                        noResultsMessage.classList.remove('hidden');
                    } else {
                        noResultsMessage.classList.add('hidden');
                    }
                }
            });
        }
        
        // Funcionalidad de filtros
        const filterBtns = document.querySelectorAll('.filter-btn');
        filterBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                // Actualizar botón activo
                filterBtns.forEach(b => {
                    b.classList.remove('active', 'bg-blue-600', 'text-white', 'border-blue-600');
                    b.classList.add('bg-white', 'text-gray-700', 'border-gray-200');
                });
                this.classList.add('active', 'bg-blue-600', 'text-white', 'border-blue-600');
                this.classList.remove('bg-white', 'text-gray-700', 'border-gray-200');
                
                const filter = this.getAttribute('data-filter');
                const cards = propertiesGrid?.querySelectorAll('.property-card');
                let visibleCount = 0;
                
                cards?.forEach(card => {
                    const status = card.getAttribute('data-status');
                    
                    if (filter === 'todas') {
                        card.classList.remove('hidden');
                        visibleCount++;
                    } else if (filter === 'libres' && status === 'libre') {
                        card.classList.remove('hidden');
                        visibleCount++;
                    } else if (filter === 'ocupadas' && status === 'ocupada') {
                        card.classList.remove('hidden');
                        visibleCount++;
                    } else {
                        card.classList.add('hidden');
                    }
                });
                
                // Mostrar/ocultar mensaje de no resultados
                if (noResultsMessage) {
                    if (visibleCount === 0) {
                        noResultsMessage.classList.remove('hidden');
                    } else {
                        noResultsMessage.classList.add('hidden');
                    }
                }
            });
        });
        
        // Modal de eliminación
        const deleteModal = document.getElementById('deleteModal');
        const cancelDelete = document.getElementById('cancelDelete');
        let propertyIdToDelete = null;
        
        document.querySelectorAll('.btn-delete').forEach(btn => {
            btn.addEventListener('click', function() {
                propertyIdToDelete = this.getAttribute('data-property-id');
                const propertyName = this.getAttribute('data-property-name');
                document.getElementById('propertyNameToDelete').textContent = propertyName;
                deleteModal.classList.remove('hidden');
                deleteModal.classList.add('flex');
            });
        });
        
        cancelDelete?.addEventListener('click', function() {
            deleteModal.classList.add('hidden');
            deleteModal.classList.remove('flex');
        });
        
        document.getElementById('confirmDelete')?.addEventListener('click', function() {
            if (propertyIdToDelete) {
                console.log('Eliminando propiedad:', propertyIdToDelete);
                deleteModal.classList.add('hidden');
                deleteModal.classList.remove('flex');
                location.reload();
            }
        });
        
        // Botón agregar propiedad
        document.getElementById('btnAddProperty')?.addEventListener('click', function() {
            window.location.href = '/propiedades/nueva';
        });
        
        // Cerrar modal al hacer clic fuera
        deleteModal?.addEventListener('click', function(e) {
            if (e.target === deleteModal) {
                deleteModal.classList.add('hidden');
                deleteModal.classList.remove('flex');
            }
        });
    </script>
</body>
</html>
