<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mis Propiedades</title>
    
    <!-- Bootstrap CSS (DEBE ir primero) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    
    <!-- CSS Personalizado del Navbar -->
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/propiedades.css">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="main-content">
        <div class="container-fluid" style="max-width: 1400px;">
            <!-- Contenedor Principal con Fondo Bonito -->
            <div class="propiedades-container">
                <!-- Cabecera -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1 class="fw-bold" style="color: #1e3a8a; font-size: 1.875rem; margin: 0;">Mis propiedades</h1>
                    <a href="/viviendas/nueva" class="btn d-flex align-items-center gap-2" style="background-color: #1e40af; color: white; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-weight: 600; border: none;">
                        <i class="fas fa-plus" style="font-size: 0.875rem;"></i>
                        <span>Añadir propiedad</span>
                    </a>
                </div>

            <!-- Dashboard de KPIs -->
            <div class="row g-3 mb-4">
                <!-- KPI: Ingresos del Mes -->
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="kpi-card">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div class="kpi-icon" style="background-color: #dbeafe; width: 2.5rem; height: 2.5rem; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-euro-sign" style="color: #1e3a8a; font-size: 1.125rem;"></i>
                            </div>
                            <span class="tendencia-positiva d-flex align-items-center gap-1">
                                <i class="fas fa-arrow-up"></i>
                                +12.5%
                            </span>
                        </div>
                        <p class="text-muted mb-1" style="font-size: 0.875rem;">Ingresos del Mes</p>
                        <p class="fw-bold mb-0" style="font-size: 1.5rem; color: #1e293b;">€8,450</p>
                    </div>
                </div>

                <!-- KPI: Ocupación Actual -->
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="kpi-card">
                        <div class="kpi-icon mb-3" style="background-color: #d1fae5; width: 2.5rem; height: 2.5rem; border-radius: 0.5rem; display: inline-flex; align-items: center; justify-content: center;">
                            <i class="fas fa-chart-pie" style="color: #047857; font-size: 1.125rem;"></i>
                        </div>
                        <p class="text-muted mb-2" style="font-size: 0.875rem;">Ocupación Actual</p>
                        <p class="fw-bold mb-2" style="font-size: 1.5rem; color: #1e293b;">75%</p>
                        <div class="progress-bar-custom">
                            <div class="progress-fill" style="width: 75%"></div>
                        </div>
                    </div>
                </div>

                <!-- KPI: Tareas Urgentes -->
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="kpi-card">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div class="kpi-icon" style="background-color: #fee2e2; width: 2.5rem; height: 2.5rem; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-tasks" style="color: #b91c1c; font-size: 1.125rem;"></i>
                            </div>
                            <span class="tendencia-negativa d-flex align-items-center gap-1">
                                <i class="fas fa-arrow-up"></i>
                                +2
                            </span>
                        </div>
                        <p class="text-muted mb-1" style="font-size: 0.875rem;">Tareas Urgentes</p>
                        <p class="fw-bold mb-0" style="font-size: 1.5rem; color: #1e293b;">3</p>
                        <p class="text-muted mb-0" style="font-size: 0.75rem;">Requieren atención</p>
                    </div>
                </div>

                <!-- KPI: Próximas Reservas -->
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="kpi-card">
                        <div class="kpi-icon mb-3" style="background-color: #fef3c7; width: 2.5rem; height: 2.5rem; border-radius: 0.5rem; display: inline-flex; align-items: center; justify-content: center;">
                            <i class="fas fa-calendar-check" style="color: #b45309; font-size: 1.125rem;"></i>
                        </div>
                        <p class="text-muted mb-1" style="font-size: 0.875rem;">Próximas Reservas</p>
                        <p class="fw-bold mb-0" style="font-size: 1.5rem; color: #1e293b;">7</p>
                        <p class="text-muted mb-0" style="font-size: 0.75rem;">En todo el mes</p>
                    </div>
                </div>
            </div>

            <!-- Barra de Búsqueda y Filtros -->
            <div class="card mb-4" style="border: 1px solid #e2e8f0;">
                <div class="card-body">
                    <div class="row g-3 align-items-center">
                        <!-- Buscador -->
                        <div class="col-12 col-lg-8">
                            <div class="position-relative">
                                <i class="fas fa-search position-absolute" style="left: 0.75rem; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 0.875rem;"></i>
                                <input 
                                    type="text" 
                                    class="form-control search-input" 
                                    placeholder="Buscar por nombre, dirección o ciudad..." 
                                    id="searchInput"
                                    style="padding: 0.625rem 1rem 0.625rem 2.5rem; border: 1px solid #cbd5e1; border-radius: 0.5rem; font-size: 0.875rem;"
                                >
                            </div>
                        </div>

                        <!-- Filtros -->
                        <div class="col-12 col-lg-4">
                            <div class="d-flex gap-2 justify-content-lg-end">
                                <button class="btn btn-filter active" data-filter="todas">Todas</button>
                                <button class="btn btn-filter" data-filter="libre">Libres</button>
                                <button class="btn btn-filter" data-filter="ocupada">Ocupadas</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Layout de Dos Columnas -->
            <div class="row g-4">
                <!-- Columna Izquierda: Listado de Propiedades (75%) -->
                <div class="col-12 col-lg-9">
                    <div id="propiedadesContainer">
                        <!-- Si hay viviendas -->
                        <% if (viviendas && viviendas.length > 0) { %>
                            <div class="row g-4">
                                <% viviendas.forEach(vivienda => { %>
                                    <div class="col-12 col-md-6 col-xl-4">
                                        <div class="card card-propiedad h-100" data-estado="<%= vivienda.estado_actual %>">
                                            <!-- Imagen/Icono -->
                                            <div class="property-image-container position-relative">
                                                <% if (vivienda.imagen_url) { %>
                                                    <img src="<%= vivienda.imagen_url %>" 
                                                         alt="<%= vivienda.nombre %>" 
                                                         style="width: 100%; height: 100%; object-fit: cover;">
                                                <% } else { %>
                                                    <div class="property-icon-wrapper">
                                                        <i class="fas fa-home" style="color: white; font-size: 2rem;"></i>
                                                    </div>
                                                <% } %>
                                                <!-- Badge de Estado -->
                                                <div class="position-absolute top-0 end-0 m-2">
                                                    <% if (vivienda.estado_actual === 'libre') { %>
                                                        <span class="badge-libre d-flex align-items-center gap-1">
                                                            <i class="fas fa-check-circle"></i>
                                                            Libre
                                                        </span>
                                                    <% } else if (vivienda.estado_actual === 'ocupada') { %>
                                                        <span class="badge-ocupada d-flex align-items-center gap-1">
                                                            <i class="fas fa-user-check"></i>
                                                            Ocupada
                                                        </span>
                                                    <% } else { %>
                                                        <span class="badge" style="background-color: #94a3b8; color: white; font-size: 0.75rem; font-weight: 600; padding: 0.375rem 0.75rem; border-radius: 0.375rem; display: inline-flex; align-items: center; gap: 0.25rem;">
                                                            <i class="fas fa-question-circle"></i>
                                                            Sin estado
                                                        </span>
                                                    <% } %>
                                                </div>
                                            </div>

                                            <!-- Contenido -->
                                            <div class="card-body">
                                                <!-- Título -->
                                                <h5 class="card-title fw-bold mb-1 text-truncate" style="color: #1e293b; font-size: 1rem;">
                                                    <%= vivienda.nombre %>
                                                </h5>
                                                
                                                <!-- Dirección -->
                                                <p class="text-muted mb-3 text-truncate" style="font-size: 0.875rem;">
                                                    <i class="fas fa-map-marker-alt me-1" style="font-size: 0.75rem;"></i>
                                                    <%= vivienda.direccion %>, <%= vivienda.ciudad %>
                                                </p>

                                                <!-- Micro-datos -->
                                                <div class="d-flex gap-3 mb-3 pb-3 border-bottom" style="font-size: 0.75rem; color: #475569;">
                                                    <span class="d-flex align-items-center gap-1">
                                                        <i class="fas fa-ruler-combined" style="color: #94a3b8;"></i>
                                                        <%= vivienda.metros_cuadrados || 85 %>m²
                                                    </span>
                                                    <span class="d-flex align-items-center gap-1">
                                                        <i class="fas fa-bed" style="color: #94a3b8;"></i>
                                                        <%= vivienda.num_dormitorios || 2 %>
                                                    </span>
                                                    <span class="d-flex align-items-center gap-1">
                                                        <i class="fas fa-bath" style="color: #94a3b8;"></i>
                                                        <%= vivienda.num_banos || 1 %>
                                                    </span>
                                                </div>

                                                <!-- Botón para subir/cambiar imagen -->
                                                <div class="mb-3">
                                                    <form id="form-imagen-<%= vivienda.id_vivienda %>" enctype="multipart/form-data" style="display: inline;">
                                                        <input type="file" 
                                                               id="file-imagen-<%= vivienda.id_vivienda %>" 
                                                               name="imagen" 
                                                               accept="image/jpeg,image/jpg,image/png,image/gif,image/webp"
                                                               style="display: none;"
                                                               onchange="subirImagenVivienda(<%= vivienda.id_vivienda %>)">
                                                        <button type="button" 
                                                                onclick="document.getElementById('file-imagen-<%= vivienda.id_vivienda %>').click()" 
                                                                class="btn btn-sm w-100" 
                                                                style="background-color: #64748b; color: white; font-size: 0.75rem; font-weight: 600; border: none; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                                                            <i class="fas fa-camera"></i>
                                                            <span><%= vivienda.imagen_url ? 'Cambiar' : 'Añadir' %> imagen</span>
                                                        </button>
                                                    </form>
                                                </div>

                                                <!-- Botones de Acción -->
                                                <div class="d-flex gap-2">
                                                    <a href="/viviendas/<%= vivienda.id_vivienda %>" class="btn btn-sm flex-fill" style="background-color: #10b981; color: white; font-size: 0.75rem; font-weight: 600; border: none;">
                                                        <i class="fas fa-eye me-1"></i>
                                                        Ver
                                                    </a>
                                                    <a href="/viviendas/<%= vivienda.id_vivienda %>/editar" class="btn btn-sm flex-fill" style="background-color: #fbbf24; color: #1e293b; font-size: 0.75rem; font-weight: 600; border: none;">
                                                        <i class="fas fa-edit me-1"></i>
                                                        Editar
                                                    </a>
                                                    <button onclick="eliminarVivienda(<%= vivienda.id_vivienda %>)" class="btn btn-sm" style="background-color: #dc2626; color: white; font-size: 0.75rem; font-weight: 600; border: none; padding: 0.375rem 0.75rem;">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <!-- Estado Vacío -->
                            <div class="card text-center" style="border: 2px solid #e2e8f0; padding: 3rem; background-color: white;">
                                <div class="d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 5rem; height: 5rem; background-color: #dbeafe; border-radius: 50%;">
                                    <i class="fas fa-home" style="color: #1e3a8a; font-size: 2rem;"></i>
                                </div>
                                <h3 class="fw-bold mb-2" style="color: #1e293b; font-size: 1.125rem;">No hay propiedades registradas</h3>
                                <p class="text-muted mb-4" style="font-size: 0.875rem;">Comienza agregando tu primera propiedad al sistema</p>
                                <a href="/viviendas/nueva" class="btn btn-primary-custom d-inline-flex align-items-center gap-2">
                                    <i class="fas fa-plus"></i>
                                    Agregar Primera Propiedad
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Columna Derecha: Widget de Mantenimiento (25%) -->
                <div class="col-12 col-lg-3">
                    <div class="card mb-4" style="border: 1px solid #e2e8f0;">
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-2 mb-3 pb-3 border-bottom">
                                <div class="d-flex align-items-center justify-content-center" style="background-color: #fef3c7; width: 2.5rem; height: 2.5rem; border-radius: 0.5rem;">
                                    <i class="fas fa-clipboard-list" style="color: #b45309;"></i>
                                </div>
                                <h2 class="fw-bold mb-0" style="color: #1e293b; font-size: 1rem;">Tareas a Hacer</h2>
                            </div>

                            <!-- Lista de Tareas -->
                            <div class="d-flex flex-column gap-3">
                                <!-- Tarea Alta Prioridad -->
                                <div class="urgencia-alta p-3" style="border-radius: 0.5rem;">
                                    <div class="d-flex align-items-start justify-content-between mb-1">
                                        <h4 class="fw-semibold mb-0" style="font-size: 0.875rem; color: #1e293b;">Fuga de agua</h4>
                                        <span class="badge" style="background-color: #fecaca; color: #b91c1c; font-size: 0.75rem; font-weight: 700;">ALTA</span>
                                    </div>
                                    <p class="text-muted mb-2" style="font-size: 0.75rem;">Apartamento Centro - Piso 3B</p>
                                    <div class="d-flex align-items-center justify-content-between" style="font-size: 0.75rem;">
                                        <span class="text-muted">
                                            <i class="far fa-calendar me-1" style="font-size: 0.75rem;"></i>
                                            Hoy
                                        </span>
                                        <a href="#" class="link-detalle">
                                            Ver detalles →
                                        </a>
                                    </div>
                                </div>

                                <!-- Tarea Media Prioridad -->
                                <div class="urgencia-media p-3" style="border-radius: 0.5rem;">
                                    <div class="d-flex align-items-start justify-content-between mb-1">
                                        <h4 class="fw-semibold mb-0" style="font-size: 0.875rem; color: #1e293b;">Revisión caldera</h4>
                                        <span class="badge" style="background-color: #fed7aa; color: #92400e; font-size: 0.75rem; font-weight: 700;">MEDIA</span>
                                    </div>
                                    <p class="text-muted mb-2" style="font-size: 0.75rem;">Villa Norte</p>
                                    <div class="d-flex align-items-center justify-content-between" style="font-size: 0.75rem;">
                                        <span class="text-muted">
                                            <i class="far fa-calendar me-1" style="font-size: 0.75rem;"></i>
                                            En 3 días
                                        </span>
                                        <a href="#" class="link-detalle">
                                            Ver detalles →
                                        </a>
                                    </div>
                                </div>

                                <!-- Tarea Media Prioridad -->
                                <div class="urgencia-media p-3" style="border-radius: 0.5rem;">
                                    <div class="d-flex align-items-start justify-content-between mb-1">
                                        <h4 class="fw-semibold mb-0" style="font-size: 0.875rem; color: #1e293b;">Limpieza profunda</h4>
                                        <span class="badge" style="background-color: #fed7aa; color: #92400e; font-size: 0.75rem; font-weight: 700;">MEDIA</span>
                                    </div>
                                    <p class="text-muted mb-2" style="font-size: 0.75rem;">Casa Playa</p>
                                    <div class="d-flex align-items-center justify-content-between" style="font-size: 0.75rem;">
                                        <span class="text-muted">
                                            <i class="far fa-calendar me-1" style="font-size: 0.75rem;"></i>
                                            En 5 días
                                        </span>
                                        <a href="#" class="link-detalle">
                                            Ver detalles →
                                        </a>
                                    </div>
                                </div>

                                <!-- Tarea Baja Prioridad -->
                                <div class="urgencia-baja p-3" style="border-radius: 0.5rem;">
                                    <div class="d-flex align-items-start justify-content-between mb-1">
                                        <h4 class="fw-semibold mb-0" style="font-size: 0.875rem; color: #1e293b;">Pintar fachada</h4>
                                        <span class="badge" style="background-color: #e2e8f0; color: #475569; font-size: 0.75rem; font-weight: 700;">BAJA</span>
                                    </div>
                                    <p class="text-muted mb-2" style="font-size: 0.75rem;">Edificio Sur</p>
                                    <div class="d-flex align-items-center justify-content-between" style="font-size: 0.75rem;">
                                        <span class="text-muted">
                                            <i class="far fa-calendar me-1" style="font-size: 0.75rem;"></i>
                                            En 2 semanas
                                        </span>
                                        <a href="#" class="link-detalle">
                                            Ver detalles →
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <!-- Ver Todas las Tareas -->
                            <button class="w-100 mt-3 pt-3 border-top btn btn-link fw-medium p-0" style="color: #1e3a8a; font-size: 0.875rem; text-decoration: none;">
                                Ver todas las tareas
                                <i class="fas fa-arrow-right ms-1" style="font-size: 0.75rem;"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Widget Adicional: Estadísticas Rápidas -->
                    <div class="card" style="border: 1px solid #e2e8f0;">
                        <div class="card-body">
                            <h3 class="fw-bold mb-3" style="color: #1e293b; font-size: 1rem;">Resumen General</h3>
                            <div class="d-flex flex-column gap-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted" style="font-size: 0.875rem;">Total Propiedades</span>
                                    <span class="fw-bold" style="color: #1e293b;"><%= viviendas ? viviendas.length : 0 %></span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted" style="font-size: 0.875rem;">Propiedades Libres</span>
                                    <span class="fw-bold" style="color: #059669;">
                                        <%= viviendas ? viviendas.filter(v => v.estado_actual === 'libre').length : 0 %>
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted" style="font-size: 0.875rem;">Propiedades Ocupadas</span>
                                    <span class="fw-bold" style="color: #d97706;">
                                        <%= viviendas ? viviendas.filter(v => v.estado_actual === 'ocupada').length : 0 %>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Fin del Contenedor Principal -->
        </div>
    </main>

    <%- include('partials/footer') %>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Sistema de Filtros
        const filterButtons = document.querySelectorAll('[data-filter]');
        const propiedades = document.querySelectorAll('[data-estado]');

        filterButtons.forEach(button => {
            button.addEventListener('click', () => {
                // Actualizar botones activos
                filterButtons.forEach(btn => {
                    btn.classList.remove('active');
                });
                button.classList.add('active');

                const filter = button.getAttribute('data-filter');

                // Filtrar propiedades
                propiedades.forEach(propiedad => {
                    const parentCol = propiedad.closest('.col-12');
                    if (filter === 'todas') {
                        parentCol.style.display = 'block';
                    } else {
                        if (propiedad.getAttribute('data-estado') === filter) {
                            parentCol.style.display = 'block';
                        } else {
                            parentCol.style.display = 'none';
                        }
                    }
                });
            });
        });

        // Buscador
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.addEventListener('input', (e) => {
                const searchTerm = e.target.value.toLowerCase();
                
                propiedades.forEach(propiedad => {
                    const parentCol = propiedad.closest('.col-12');
                    const text = propiedad.textContent.toLowerCase();
                    if (text.includes(searchTerm)) {
                        parentCol.style.display = 'block';
                    } else {
                        parentCol.style.display = 'none';
                    }
                });
            });
        }

        // Función para eliminar vivienda
        function eliminarVivienda(id) {
            if (confirm('¿Estás seguro de que deseas eliminar esta propiedad?')) {
                fetch(`/viviendas/${id}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Error al eliminar la propiedad');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error al eliminar la propiedad');
                });
            }
        }

        // Función para subir imagen de vivienda
        function subirImagenVivienda(viviendaId) {
            const fileInput = document.getElementById(`file-imagen-${viviendaId}`);
            const file = fileInput.files[0];
            
            if (!file) {
                return;
            }

            // Validar tipo de archivo
            const validTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];
            if (!validTypes.includes(file.type)) {
                alert('Solo se permiten imágenes (JPG, PNG, GIF, WEBP)');
                fileInput.value = '';
                return;
            }

            // Validar tamaño (5MB máximo)
            if (file.size > 5 * 1024 * 1024) {
                alert('La imagen no puede superar 5MB');
                fileInput.value = '';
                return;
            }

            // Crear FormData y enviar
            const formData = new FormData();
            formData.append('imagen', file);

            // Obtener referencias al DOM
            const button = document.querySelector(`#form-imagen-${viviendaId} button`);
            const buttonText = button.querySelector('span');
            const card = button.closest('.card-propiedad');
            const imageContainer = card.querySelector('.property-image-container');
            
            const originalHTML = button.innerHTML;
            button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Subiendo...';
            button.disabled = true;

            fetch(`/propiedades/${viviendaId}/imagen`, {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Actualizar el contenedor de imagen sin recargar la página
                    const badge = imageContainer.querySelector('.position-absolute');
                    imageContainer.innerHTML = `
                        <img src="${data.imagen_url}" 
                             alt="Imagen de la vivienda" 
                             style="width: 100%; height: 100%; object-fit: cover;">
                    `;
                    // Restaurar el badge de estado
                    if (badge) {
                        imageContainer.appendChild(badge);
                    }
                    
                    // Actualizar el texto del botón
                    button.innerHTML = '<i class="fas fa-camera"></i> <span>Cambiar imagen</span>';
                    button.disabled = false;
                    
                    // Resetear el input
                    fileInput.value = '';
                } else {
                    alert('Error al subir la imagen: ' + (data.message || 'Error desconocido'));
                    button.innerHTML = originalHTML;
                    button.disabled = false;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error al subir la imagen');
                button.innerHTML = originalHTML;
                button.disabled = false;
            });
        }
    </script>
</body>
</html>
