<!-- filepath: views/propiedades/detalle.ejs -->
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= vivienda.direccion %> - Dashboard de Propiedad</title>
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  
  <!-- FullCalendar CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" />
  
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>
  
  <!-- CSS Personalizado -->
  <link rel="stylesheet" href="/css/navbar.css">
  <link rel="stylesheet" href="/css/detalle-dashboard.css">
  <style>
    .kpi-card.kpi-small {
      min-width: 120px;
      max-width: 140px;
      min-height: 80px;
      padding: 0.75rem 0.75rem 0.5rem 0.75rem;
      font-size: 0.92rem;
    }
    .kpi-card.kpi-small .kpi-value {
      font-size: 1.2rem;
      font-weight: 700;
    }
    .kpi-card.kpi-small .kpi-label {
      font-size: 0.85rem;
    }
    .kpi-card.kpi-small .kpi-subtitle {
      font-size: 0.75rem;
    }
    .kpi-card.kpi-platform {
      min-width: 120px;
      max-width: 160px;
      min-height: 80px;
      padding: 0.5rem 0.5rem 0.5rem 0.5rem;
    }
    /* Modal para tareas */
    .modal-task-bg {
      display: none; position: fixed; z-index: 1050; left: 0; top: 0; width: 100vw; height: 100vh; background: rgba(30,41,59,0.25); align-items: center; justify-content: center;
    }
    .modal-task {
      background: #fff; border-radius: 10px; box-shadow: 0 2px 16px rgba(0,0,0,0.12); padding: 2rem 1.5rem 1.5rem 1.5rem; min-width: 320px; max-width: 95vw;
    }
    .modal-task-header { font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
    .modal-task-footer { display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 1.5rem; }
    .modal-task input, .modal-task textarea { width: 100%; margin-bottom: 0.75rem; }
  </style>
  
</head>
<body>

  <%- include('../partials/navbar') %>

  <!-- Hero Section -->
  <div class="hero-section">
    <div class="hero-background"></div>
    <div class="hero-overlay">
      <div class="hero-info">
        <h1 class="hero-title">
          <i class="fas fa-home"></i>
          <%= vivienda.direccion || vivienda.calle %>
        </h1>
        <p class="hero-address">
          <i class="fas fa-map-marker-alt"></i>
          <%= [vivienda.calle, vivienda.bloque_portal, vivienda.piso, vivienda.letra_numero].filter(Boolean).join(', ') %> - 
          <%= vivienda.ciudad %>, <%= vivienda.pais || 'España' %>
        </p>
        <div class="hero-meta">
          <div class="hero-meta-item">
            <span class="hero-meta-label">Tipo de Vivienda</span>
            <span class="hero-meta-value"><%= vivienda.tipo_vivienda || 'Apartamento' %></span>
          </div>
          <div class="hero-meta-item">
            <span class="hero-meta-label">Categoría</span>
            <span class="hero-meta-value"><%= vivienda.categoria || 'Vacacional' %></span>
          </div>
          <div class="hero-meta-item">
            <span class="hero-meta-label">Valor Estimado</span>
            <span class="hero-meta-value">€ 
              <%= vivienda.precio_compra ? vivienda.precio_compra.toLocaleString('es-ES') : '---' %>
            </span>
          </div>
        </div>
      </div>
      <div class="hero-badges">
        <span class="status-badge <%= vivienda.activa ? 'activa' : 'inactiva' %>">
          <i class="fas fa-circle"></i>
          <%= vivienda.activa ? 'Activa' : 'Inactiva' %>
        </span>
        <% if (vivienda.categoria) { %>
          <span class="type-badge">
            <i class="fas fa-certificate"></i>
            <%= vivienda.categoria %>
          </span>
        <% } %>
      </div>
    </div>
  </div>

  <div class="container-dashboard">
    <!-- Back Button -->
    <a href="/propiedades" class="btn-back">
      <i class="fas fa-arrow-left"></i>
      Volver a mis propiedades
    </a>

    <!-- KPI Cards (smaller) + Platform Buttons -->
    <div class="kpi-grid" style="gap: 1rem; margin-bottom: 1.5rem;">
      <div class="kpi-card kpi-small">
        <div class="kpi-header">
          <span class="kpi-label">Rentabilidad Anual</span>
          <div class="kpi-icon green">
            <i class="fas fa-chart-line"></i>
          </div>
        </div>
        <div class="kpi-value">
          <% 
            let rentabilidad = 0;
            if (typeof balanceAnual !== 'undefined' && vivienda.precio_compra) {
              rentabilidad = ((balanceAnual / vivienda.precio_compra) * 100).toFixed(1);
            }
          %>
          <%= rentabilidad %>%
        </div>
        <div class="kpi-subtitle">ROI estimado</div>
      </div>

      <div class="kpi-card kpi-small">
        <div class="kpi-header">
          <span class="kpi-label">Ingresos Mes Actual</span>
          <div class="kpi-icon blue">
            <i class="fas fa-euro-sign"></i>
          </div>
        </div>
        <div class="kpi-value">
          <%= typeof balanceMensual !== 'undefined' ? balanceMensual.toFixed(0) : '0' %>€
        </div>
        <div class="kpi-subtitle">Febrero 2026</div>
      </div>
      <div class="kpi-card kpi-small">
        <div class="kpi-header">
          <span class="kpi-label">Incidencias Activas</span>
          <div class="kpi-icon red">
            <i class="fas fa-exclamation-triangle"></i>
          </div>
        </div>
        <div class="kpi-value">0</div>
        <div class="kpi-subtitle">Todo en orden</div>
      </div>

      <% if (typeof porcentajeOcupacion !== 'undefined') { %>
      <div class="kpi-card kpi-small">
        <div class="kpi-header">
          <span class="kpi-label">Ocupación Histórica</span>
          <div class="kpi-icon blue">
            <i class="fas fa-percentage"></i>
          </div>
        </div>
        <div class="kpi-value"><%= porcentajeOcupacion %>%</div>
        <div class="kpi-subtitle">Últimos 12 meses</div>
      </div>
      <% } %>

      <% if (typeof balanceAnual !== 'undefined') { %>
      <div class="kpi-card kpi-small">
        <div class="kpi-header">
          <span class="kpi-label">Balance Anual</span>
          <div class="kpi-icon green">
            <i class="fas fa-coins"></i>
          </div>
        </div>
        <div class="kpi-value"><%= balanceAnual.toFixed(0) %>€</div>
        <div class="kpi-subtitle">2025</div>
      </div>
      <% } %>

      <!-- Platform Buttons -->
      <div class="kpi-card kpi-platform" style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-width: 160px; min-height: 90px; background: #f8fafc; border: 1px solid #e5e7eb; box-shadow: 0 1px 4px rgba(0,0,0,0.03);">
        <div style="display: flex; gap: 0.75rem;">
          <a href="<%= vivienda.url_airbnb || '#' %>" target="_blank" class="btn btn-sm btn-airbnb" style="background: #ff5a5f; color: #fff; font-weight: 600; border-radius: 6px; padding: 0.5rem 1rem; display: flex; align-items: center; gap: 0.5rem;">
            <i class="fab fa-airbnb"></i> Airbnb
          </a>
          <a href="<%= vivienda.url_booking || '#' %>" target="_blank" class="btn btn-sm btn-booking" style="background: #003580; color: #fff; font-weight: 600; border-radius: 6px; padding: 0.5rem 1rem; display: flex; align-items: center; gap: 0.5rem;">
            <i class="fas fa-bed"></i> Booking
          </a>
        </div>
      </div>
    </div>

    <!-- Main Layout -->
    <div class="main-layout">
      <!-- Column A: Details and Media -->
      <div class="column-a">
        
        <!-- Gallery -->
        <div class="card">
          <div class="card-header">
            <h3>
              <div class="card-header-icon">
                <i class="fas fa-images"></i>
              </div>
              Galería Multimedia
            </h3>
          </div>
          <div class="card-body">
            <div class="gallery-container">
              <div class="gallery-placeholder">
                <i class="fas fa-image"></i>
                <p>Vista previa de imágenes de la propiedad</p>
                <small style="opacity: 0.7;">Carrusel de fotos, planos y videos</small>
              </div>
            </div>
          </div>
        </div>

        <!-- Technical Specifications -->
        <div class="card">
          <div class="card-header">
            <h3>
              <div class="card-header-icon">
                <i class="fas fa-clipboard-list"></i>
              </div>
              Ficha Técnica
            </h3>
          </div>
          <div class="card-body">
            <div class="technical-grid">
              <div class="technical-item">
                <div class="technical-icon">
                  <i class="fas fa-ruler-combined"></i>
                </div>
                <div class="technical-info">
                  <div class="technical-label">Superficie</div>
                  <div class="technical-value"><%= vivienda.superficie || 0 %> m²</div>
                </div>
              </div>

              <div class="technical-item">
                <div class="technical-icon">
                  <i class="fas fa-bed"></i>
                </div>
                <div class="technical-info">
                  <div class="technical-label">Dormitorios</div>
                  <div class="technical-value"><%= vivienda.num_habitaciones || vivienda.num_dormitorios || 0 %></div>
                </div>
              </div>

              <div class="technical-item">
                <div class="technical-icon">
                  <i class="fas fa-bath"></i>
                </div>
                <div class="technical-info">
                  <div class="technical-label">Baños</div>
                  <div class="technical-value"><%= vivienda.num_banos || 0 %></div>
                </div>
              </div>

              <div class="technical-item">
                <div class="technical-icon">
                  <i class="fas fa-users"></i>
                </div>
                <div class="technical-info">
                  <div class="technical-label">Capacidad Máxima</div>
                  <div class="technical-value"><%= vivienda.capacidad_maxima || vivienda.max_huespedes || 0 %> personas</div>
                </div>
              </div>

              <% if (vivienda.planta !== null && vivienda.planta !== undefined) { %>
              <div class="technical-item">
                <div class="technical-icon">
                  <i class="fas fa-layer-group"></i>
                </div>
                <div class="technical-info">
                  <div class="technical-label">Planta</div>
                  <div class="technical-value">
                    <%= vivienda.planta === 0 ? 'Bajo' : vivienda.planta === -1 ? 'Sótano' : vivienda.planta %>
                  </div>
                </div>
              </div>
              <% } %>

              <% if (vivienda.ano_construccion) { %>
              <div class="technical-item">
                <div class="technical-icon">
                  <i class="fas fa-calendar-alt"></i>
                </div>
                <div class="technical-info">
                  <div class="technical-label">Año Construcción</div>
                  <div class="technical-value"><%= vivienda.ano_construccion %></div>
                </div>
              </div>
              <% } %>

              <% if (vivienda.superficie_parcela) { %>
              <div class="technical-item">
                <div class="technical-icon">
                  <i class="fas fa-map"></i>
                </div>
                <div class="technical-info">
                  <div class="technical-label">Superficie Parcela</div>
                  <div class="technical-value"><%= vivienda.superficie_parcela %> m²</div>
                </div>
              </div>
              <% } %>
            </div>

            <!-- Amenities -->
            <div style="margin-top: 2rem;">
              <h4 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--gray-500); font-weight: 700; margin-bottom: 1rem;">
                Comodidades Destacadas
              </h4>
              <div class="amenities-list">
                <% 
                let amenitiesList = [];
                if (vivienda.amenities) {
                  try {
                    amenitiesList = JSON.parse(vivienda.amenities);
                  } catch(e) {}
                }
                
                const legacyAmenities = [];
                if (vivienda.wifi) legacyAmenities.push({ nombre: 'Wi-Fi', icon: 'wifi' });
                if (vivienda.aire_acondicionado) legacyAmenities.push({ nombre: 'Aire acondicionado', icon: 'wind' });
                if (vivienda.calefaccion) legacyAmenities.push({ nombre: 'Calefacción', icon: 'fire' });
                if (vivienda.cocina) legacyAmenities.push({ nombre: 'Cocina', icon: 'utensils' });
                if (vivienda.parking) legacyAmenities.push({ nombre: 'Parking', icon: 'parking' });
                if (vivienda.piscina) legacyAmenities.push({ nombre: 'Piscina', icon: 'swimming-pool' });
                
                const allAmenities = amenitiesList.length > 0 ? amenitiesList : legacyAmenities;
                
                if (allAmenities.length > 0) {
                  allAmenities.forEach(amenity => { %>
                    <div class="amenity-tag">
                      <i class="fas fa-<%= amenity.icon || 'check-circle' %>"></i>
                      <span><%= amenity.nombre %></span>
                    </div>
                  <% });
                } else { %>
                  <p style="color: var(--gray-500); font-size: 0.875rem;">No hay comodidades especificadas</p>
                <% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- Location -->
        <div class="card">
          <div class="card-header">
            <h3>
              <div class="card-header-icon">
                <i class="fas fa-map-marker-alt"></i>
              </div>
              Ubicación
            </h3>
          </div>
          <div class="card-body">
            <% if (vivienda.latitud && vivienda.longitud) { %>
              <div class="map-container" id="mapa"></div>
            <% } else { %>
              <div class="map-container" style="display: flex; align-items: center; justify-content: center; background: var(--gray-100);">
                <div style="text-align: center; color: var(--gray-500);">
                  <i class="fas fa-map-marked-alt" style="font-size: 3rem; margin-bottom: 1rem;"></i>
                  <p>Mapa no disponible</p>
                </div>
              </div>
            <% } %>
            
            <div class="map-info">
              <% if (vivienda.barrio) { %>
              <div class="map-info-item">
                <i class="fas fa-map-signs"></i>
                <span><strong>Barrio:</strong> <%= vivienda.barrio %></span>
              </div>
              <% } %>
              <% if (vivienda.codigo_postal) { %>
              <div class="map-info-item">
                <i class="fas fa-mail-bulk"></i>
                <span><strong>CP:</strong> <%= vivienda.codigo_postal %></span>
              </div>
              <% } %>
              <% if (vivienda.latitud && vivienda.longitud) { %>
              <div class="map-info-item" style="grid-column: 1/-1; font-size: 0.75rem;">
                <i class="fas fa-map-pin"></i>
                <span><strong>Coordenadas:</strong> <%= parseFloat(vivienda.latitud).toFixed(6) %>, <%= parseFloat(vivienda.longitud).toFixed(6) %></span>
              </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Legal Documentation -->
        <div class="card">
          <div class="card-header">
            <h3>
              <div class="card-header-icon">
                <i class="fas fa-file-contract"></i>
              </div>
              Documentación Legal
            </h3>
          </div>
          <div class="card-body">
            <div class="documents-list">
              <% if (vivienda.referencia_catastral) { %>
              <div class="document-item">
                <div class="document-info">
                  <div class="document-icon">
                    <i class="fas fa-file-alt"></i>
                  </div>
                  <div>
                    <div class="document-name">Referencia Catastral</div>
                    <div class="document-date"><%= vivienda.referencia_catastral %></div>
                  </div>
                </div>
                <button class="btn-download">
                  <i class="fas fa-download"></i>
                  Descargar
                </button>
              </div>
              <% } %>

              <% if (vivienda.numero_registro_autonomico) { %>
              <div class="document-item">
                <div class="document-info">
                  <div class="document-icon">
                    <i class="fas fa-file-signature"></i>
                  </div>
                  <div>
                    <div class="document-name">Nº Registro Autonómico</div>
                    <div class="document-date"><%= vivienda.numero_registro_autonomico %></div>
                  </div>
                </div>
                <button class="btn-download">
                  <i class="fas fa-download"></i>
                  Descargar
                </button>
              </div>
              <% } %>

              <% if (vivienda.fecha_registro) { %>
              <div class="document-item">
                <div class="document-info">
                  <div class="document-icon">
                    <i class="fas fa-calendar-check"></i>
                  </div>
                  <div>
                    <div class="document-name">Fecha de Registro</div>
                    <div class="document-date"><%= new Date(vivienda.fecha_registro).toLocaleDateString('es-ES') %></div>
                  </div>
                </div>
                <button class="btn-download">
                  <i class="fas fa-eye"></i>
                  Ver
                </button>
              </div>
              <% } %>

              <div class="document-item">
                <div class="document-info">
                  <div class="document-icon">
                    <i class="fas fa-file-pdf"></i>
                  </div>
                  <div>
                    <div class="document-name">Escrituras</div>
                    <div class="document-date">Documento notarial</div>
                  </div>
                </div>
                <button class="btn-download">
                  <i class="fas fa-download"></i>
                  Descargar
                </button>
              </div>

              <div class="document-item">
                <div class="document-info">
                  <div class="document-icon">
                    <i class="fas fa-file-invoice-dollar"></i>
                  </div>
                  <div>
                    <div class="document-name">IBI</div>
                    <div class="document-date">Impuesto anual</div>
                  </div>
                </div>
                <button class="btn-download">
                  <i class="fas fa-download"></i>
                  Descargar
                </button>
              </div>

              <div class="document-item">
                <div class="document-info">
                  <div class="document-icon">
                    <i class="fas fa-shield-alt"></i>
                  </div>
                  <div>
                    <div class="document-name">Seguro de Hogar</div>
                    <div class="document-date">Póliza vigente</div>
                  </div>
                </div>
                <button class="btn-download">
                  <i class="fas fa-download"></i>
                  Descargar
                </button>
              </div>

              <div class="document-item">
                <div class="document-info">
                  <div class="document-icon">
                    <i class="fas fa-leaf"></i>
                  </div>
                  <div>
                    <div class="document-name">Certificado Energético</div>
                    <div class="document-date">Eficiencia energética</div>
                  </div>
                </div>
                <button class="btn-download">
                  <i class="fas fa-download"></i>
                  Descargar
                </button>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Column B: Management and Finance -->
      <div class="column-b">
        
        <!-- Financial Balance -->
        <div class="card">
          <div class="card-header">
            <h3>
              <div class="card-header-icon">
                <i class="fas fa-chart-line"></i>
              </div>
              Balance Financiero
            </h3>
          </div>
          <div class="card-body">
            <div class="chart-container">
              <canvas id="financialChart"></canvas>
            </div>
            <div class="stats-summary">
              <div class="stat-item">
                <div class="stat-label">Ingresos Totales</div>
                <div class="stat-value" style="color: var(--forest-green);">
                  <%= typeof balanceAnual !== 'undefined' ? (balanceAnual * 1.3).toFixed(0) : '0' %>€
                </div>
              </div>
              <div class="stat-item">
                <div class="stat-label">Gastos Totales</div>
                <div class="stat-value" style="color: var(--danger-red);">
                  <%= typeof balanceAnual !== 'undefined' ? (balanceAnual * 0.3).toFixed(0) : '0' %>€
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Upcoming Reservations -->
        <div class="card">
          <div class="card-header">
            <h3>
              <div class="card-header-icon">
                <i class="fas fa-calendar-check"></i>
              </div>
              Próximas Reservas
            </h3>
          </div>
          <div class="card-body">
            <% if (typeof proximasReservas !== 'undefined' && proximasReservas.length > 0) { %>
              <div class="reservations-list">
                <% proximasReservas.slice(0, 5).forEach((reserva, index) => { %>
                  <div class="reservation-card">
                    <div class="reservation-header">
                      <span class="platform-badge airbnb">
                        <i class="fab fa-airbnb"></i>
                        Airbnb
                      </span>
                      <span class="payment-status paid">
                        <i class="fas fa-check-circle"></i>
                        Pagado
                      </span>
                    </div>
                    <div class="reservation-dates">
                      <i class="fas fa-calendar"></i>
                      <%= new Date(reserva.fecha_entrada).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                      <i class="fas fa-arrow-right" style="font-size: 0.75rem;"></i>
                      <%= new Date(reserva.fecha_salida).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    </div>
                    <div class="reservation-guests">
                      <i class="fas fa-users"></i>
                      <%= reserva.num_huespedes %> huésped<%= reserva.num_huespedes > 1 ? 'es' : '' %>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div style="text-align: center; padding: 2rem; color: var(--gray-500);">
                <i class="fas fa-calendar-times" style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;"></i>
                <p style="margin: 0; font-weight: 500;">No hay reservas programadas</p>
                <small>Las próximas reservas aparecerán aquí</small>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Calendar -->
        <% if (typeof reservasMes !== 'undefined') { %>
        <div class="card">
          <div class="card-header">
            <h3>
              <div class="card-header-icon">
                <i class="fas fa-calendar"></i>
              </div>
              Calendario de Ocupación
            </h3>
          </div>
          <div class="card-body">
            <div class="calendar-wrapper">
              <div id="calendario"></div>
            </div>
          </div>
        </div>
        <% } %>

        <!-- Tareas Card -->
        <div class="card">
          <div class="card-header">
            <h3>
              <div class="card-header-icon">
                <i class="fas fa-tasks"></i>
              </div>
              Tareas
            </h3>
          </div>
          <div class="card-body">
            <div id="task-list" style="margin-bottom: 1rem;">
              <!-- Aquí se mostrarán las tareas existentes -->
              <div class="task-item" style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                <input type="checkbox" />
                <span>Tarea de ejemplo: Revisar contador de agua</span>
                <span class="badge bg-secondary" style="font-size: 0.7rem; margin-left: auto;">Pendiente</span>
              </div>
              <div class="task-item" style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                <input type="checkbox" checked />
                <span>Llamar a la empresa de limpieza</span>
                <span class="badge bg-success" style="font-size: 0.7rem; margin-left: auto;">Completada</span>
              </div>
            </div>
            <button class="btn btn-primary btn-sm" onclick="openTaskModal()">
              <i class="fas fa-plus"></i> Añadir Tarea
            </button>
            <!-- Modal para añadir tarea -->
            <div id="modalTaskBg" class="modal-task-bg">
              <div class="modal-task">
                <div class="modal-task-header"><i class="fas fa-tasks"></i> Añadir Nueva Tarea</div>
                <input id="taskTitle" type="text" placeholder="Título de la tarea" maxlength="60" required />
                <textarea id="taskDesc" rows="2" placeholder="Descripción (opcional)"></textarea>
                <div class="modal-task-footer">
                  <button class="btn btn-secondary btn-sm" onclick="closeTaskModal()">Cancelar</button>
                  <button class="btn btn-primary btn-sm" onclick="saveTask()">Guardar</button>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Footer -->
    <div class="dashboard-footer">
      <p>Última actualización de datos: <%= new Date().toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' }) %></p>
    </div>
  </div>

  <!-- Leaflet JS -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  
  <!-- FullCalendar JS -->
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
  
  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  
  <script>
        // Modal lógica para tareas
        function openTaskModal() {
          document.getElementById('modalTaskBg').style.display = 'flex';
          setTimeout(() => {
            document.getElementById('taskTitle').focus();
          }, 100);
        }
        function closeTaskModal() {
          document.getElementById('modalTaskBg').style.display = 'none';
          document.getElementById('taskTitle').value = '';
          document.getElementById('taskDesc').value = '';
        }
        function saveTask() {
          const title = document.getElementById('taskTitle').value.trim();
          const desc = document.getElementById('taskDesc').value.trim();
          if (!title) {
            document.getElementById('taskTitle').focus();
            return;
          }
          // Añadir tarea a la lista (solo frontend demo)
          const taskList = document.getElementById('task-list');
          const div = document.createElement('div');
          div.className = 'task-item';
          div.style.display = 'flex';
          div.style.alignItems = 'center';
          div.style.gap = '0.5rem';
          div.style.marginBottom = '0.5rem';
          div.innerHTML = `<input type='checkbox' /> <span>${title}${desc ? ': ' + desc : ''}</span> <span class='badge bg-secondary' style='font-size:0.7rem;margin-left:auto;'>Pendiente</span>`;
          taskList.prepend(div);
          closeTaskModal();
        }
        // Cerrar modal al hacer click fuera
        window.addEventListener('click', function(e) {
          const modalBg = document.getElementById('modalTaskBg');
          if (modalBg && e.target === modalBg) closeTaskModal();
        });
    // Inicializar mapa si hay coordenadas
    <% if (vivienda.latitud && vivienda.longitud) { %>
      document.addEventListener('DOMContentLoaded', function() {
        const map = L.map('mapa').setView([<%= vivienda.latitud %>, <%= vivienda.longitud %>], 15);
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '© OpenStreetMap contributors',
          maxZoom: 19
        }).addTo(map);
        
        const marker = L.marker([<%= vivienda.latitud %>, <%= vivienda.longitud %>]).addTo(map);
        
        marker.bindPopup(`
          <div style="text-align: center;">
            <strong><%= vivienda.direccion || vivienda.calle %></strong><br>
            <%= vivienda.ciudad %>, <%= vivienda.pais || 'España' %>
          </div>
        `).openPopup();
      });
    <% } %>

    // Inicializar gráfico financiero
    document.addEventListener('DOMContentLoaded', function() {
      const ctx = document.getElementById('financialChart');
      if (ctx) {
        const balanceAnual = <%= typeof balanceAnual !== 'undefined' ? balanceAnual : 0 %>;
        
        // Datos simulados para los últimos 12 meses
        const months = ['Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic', 'Ene'];
        const ingresos = months.map((m, i) => {
          const base = balanceAnual / 12 * 1.3;
          const variation = (Math.random() - 0.5) * base * 0.3;
          return (base + variation).toFixed(0);
        });
        const gastos = ingresos.map(ing => (ing * (0.2 + Math.random() * 0.2)).toFixed(0));

        new Chart(ctx, {
          type: 'line',
          data: {
            labels: months,
            datasets: [
              {
                label: 'Ingresos',
                data: ingresos,
                borderColor: '#2f855a',
                backgroundColor: 'rgba(47, 133, 90, 0.1)',
                borderWidth: 3,
                fill: true,
                tension: 0.4
              },
              {
                label: 'Gastos',
                data: gastos,
                borderColor: '#e53e3e',
                backgroundColor: 'rgba(229, 62, 62, 0.1)',
                borderWidth: 3,
                fill: true,
                tension: 0.4
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                display: true,
                position: 'top',
                labels: {
                  usePointStyle: true,
                  padding: 15,
                  font: {
                    size: 12,
                    weight: '600'
                  }
                }
              },
              tooltip: {
                mode: 'index',
                intersect: false,
                backgroundColor: 'rgba(26, 54, 93, 0.95)',
                padding: 12,
                titleFont: {
                  size: 13,
                  weight: '600'
                },
                bodyFont: {
                  size: 12
                },
                callbacks: {
                  label: function(context) {
                    return context.dataset.label + ': €' + parseFloat(context.parsed.y).toLocaleString('es-ES');
                  }
                }
              }
            },
            scales: {
              y: {
                beginAtZero: true,
                grid: {
                  color: 'rgba(0, 0, 0, 0.05)'
                },
                ticks: {
                  callback: function(value) {
                    return '€' + value.toLocaleString('es-ES');
                  },
                  font: {
                    size: 11
                  }
                }
              },
              x: {
                grid: {
                  display: false
                },
                ticks: {
                  font: {
                    size: 11
                  }
                }
              }
            }
          }
        });
      }
    });

    // Inicializar calendario si hay reservas
    <% if (typeof reservasMes !== 'undefined') { %>
      document.addEventListener('DOMContentLoaded', function() {
        const calendarEl = document.getElementById('calendario');
        if (calendarEl) {
          const reservas = <%- JSON.stringify(reservasMes) %>;
          
          const events = reservas.map(reserva => ({
            title: 'Reservado',
            start: reserva.fecha_entrada,
            end: reserva.fecha_salida,
            backgroundColor: '#1a365d',
            borderColor: '#0f2540',
            textColor: '#ffffff'
          }));

          const calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            locale: 'es',
            events: events,
            headerToolbar: {
              left: 'prev,next today',
              center: 'title',
              right: 'dayGridMonth'
            },
            buttonText: {
              today: 'Hoy'
            },
            height: 'auto',
            dayMaxEvents: true,
            eventDisplay: 'block'
          });
          
          calendar.render();
        }
      });
    <% } %>
  </script>
</body>
</html>
