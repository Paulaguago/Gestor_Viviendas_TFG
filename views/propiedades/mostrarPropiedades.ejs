<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Propiedades - Dashboard</title>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Bootstrap CSS (debe ir ANTES de Tailwind) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            corePlugins: {
                preflight: false, // Desactiva el reset de Tailwind para no conflictuar con Bootstrap
            }
        }
    </script>
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <!-- CSS Personalizado (debe ir AL FINAL) -->
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/mostrar-propiedades.css">
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
      body { background: #dce3ef; font-family: 'Inter', sans-serif; }
      .mp-page { max-width: 1280px; margin: 0 auto; padding: 2rem 1.5rem; }

      /* Header */
      .mp-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.75rem; }
      .mp-title { font-size: 1.625rem; font-weight: 800; color: #0F172A; margin: 0; letter-spacing: -0.02em; }
      .mp-title span { font-size: 0.875rem; font-weight: 500; color: #94a3b8; margin-left: 0.5rem; font-letter-spacing: 0; }
      .mp-btn-add { display: inline-flex; align-items: center; gap: 0.5rem; background: #0F172A; color: #fff; border: none; border-radius: 0.625rem; padding: 0.625rem 1.25rem; font-size: 0.875rem; font-weight: 600; cursor: pointer; transition: background .15s; }
      .mp-btn-add:hover { background: #1e293b; }

      /* Toolbar */
      .mp-toolbar { background: #fff; border-radius: 0.875rem; padding: 0.875rem 1.125rem; box-shadow: 0 1px 3px rgba(15,23,42,.06); margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.875rem; flex-wrap: wrap; }
      .mp-search-wrap { flex: 1; min-width: 14rem; position: relative; }
      .mp-search-wrap i { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 0.8rem; pointer-events: none; }
      .mp-search { width: 100%; padding: 0.55rem 1rem 0.55rem 2.5rem; border: 1px solid #a0aec0; border-radius: 99px; font-size: 0.875rem; color: #0F172A; background: #f7f9fc; outline: none; transition: border-color .15s, box-shadow .15s; box-sizing: border-box; }
      .mp-search:focus { border-color: #0F172A; box-shadow: 0 0 0 3px rgba(15,23,42,.08); background: #fff; }
      .mp-filters { display: flex; gap: 0.375rem; }
      .mp-pill { padding: 0.45rem 0.875rem; border-radius: 99px; font-size: 0.8rem; font-weight: 600; border: 1.5px solid #e2e8f0; background: #fff; color: #64748b; cursor: pointer; transition: all .15s; }
      .mp-pill:hover { border-color: #cbd5e1; color: #0F172A; }
      .mp-pill.active { background: #0F172A; color: #fff; border-color: #0F172A; }
      .mp-btn-filter { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.45rem 0.875rem; border-radius: 0.5rem; font-size: 0.8rem; font-weight: 600; border: 1.5px solid #e2e8f0; background: #fff; color: #64748b; cursor: pointer; transition: all .15s; }
      .mp-btn-filter:hover { border-color: #0F172A; color: #0F172A; }

      /* Cards */
      .mp-list { display: flex; flex-direction: column; gap: 0.875rem; background: #cdd5e2; border: 1.5px solid #b0bcce; border-radius: 1.125rem; padding: 1rem; }
      .mp-card { background: #ffffff; border: 1px solid #c8d0de; border-radius: 1rem; box-shadow: 0 4px 20px rgba(0,0,0,0.10); display: flex; overflow: hidden; transition: box-shadow .2s, transform .2s; }
      .mp-card:hover { box-shadow: 0 8px 28px rgba(0,0,0,0.16); transform: translateY(-2px); }

      /* Image column */
      .mp-img-col { width: 210px; flex-shrink: 0; display: flex; flex-direction: column; position: relative; }
      .mp-img-wrap { flex: 1; position: relative; overflow: hidden; min-height: 160px; }
      .mp-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
      .mp-img-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #4338ca 0%, #7c3aed 100%); display: flex; align-items: center; justify-content: center; cursor: pointer; min-height: 160px; }
      .mp-cam-btn { position: absolute; bottom: 0.5rem; right: 0.5rem; width: 1.875rem; height: 1.875rem; background: rgba(15,23,42,.8); border: none; border-radius: 0.5rem; color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; transition: background .15s; }
      .mp-cam-btn:hover { background: rgba(15,23,42,1); }
      .mp-price-badge { padding: 0.625rem 0.875rem; background: #F1F5F9; border-top: 2px solid #e2e8f0; display: flex; align-items: baseline; gap: 0.25rem; }
      .mp-price-val { font-size: 1.375rem; font-weight: 800; color: #1a202c; line-height: 1; }
      .mp-price-unit { font-size: 0.78rem; color: #64748b; font-weight: 600; }
      .mp-price-none { font-size: 0.8rem; color: #94a3b8; font-style: italic; }

      /* Info column */
      .mp-info-col { flex: 1.8; padding: 1.25rem 1.375rem 1.25rem 1.375rem; display: flex; flex-direction: column; gap: 0.5rem; min-width: 0; border-right: 1px solid #f1f5f9; }
      .mp-name { font-size: 1.0625rem; font-weight: 700; color: #0f1f3d; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.3; }
      .mp-type-row { display: flex; gap: 0.375rem; flex-wrap: wrap; }
      .mp-badge { display: inline-flex; align-items: center; padding: 0.25rem 0.7rem; border-radius: 99px; font-size: 0.78rem; font-weight: 600; }
      .mp-badge--type { background: #eef2ff; color: #3730a3; border: 1px solid #c7d2fe; }
      .mp-badge--cat { background: #ecfdf5; color: #065f46; border: 1px solid #6ee7b7; }
      .mp-location { display: flex; align-items: flex-start; gap: 0.35rem; font-size: 0.875rem; color: #2d3748; margin: 0; line-height: 1.4; }
      .mp-location i { color: #0F172A; font-size: 0.75rem; flex-shrink: 0; margin-top: 0.15rem; }
      .mp-stats { display: flex; gap: 1rem; align-items: center; padding: 0.5rem 0; border-top: 1px solid #f1f5f9; border-bottom: 1px solid #f1f5f9; flex-wrap: wrap; }
      .mp-stat { display: flex; align-items: center; gap: 0.35rem; font-size: 0.875rem; color: #2d3748; font-weight: 500; }
      .mp-stat i { color: #0F172A; font-size: 0.8rem; }
      .mp-amenities { display: flex; gap: 0.35rem; flex-wrap: wrap; }
      .mp-chip { padding: 0.25rem 0.7rem; background: #F1F5F9; border-radius: 99px; font-size: 0.78rem; font-weight: 500; color: #475569; }

      /* Legal column */
      .mp-legal-col { width: 200px; flex-shrink: 0; padding: 1.25rem 1.125rem; display: flex; flex-direction: column; gap: 0.625rem; border-right: 1px solid #f1f5f9; }
      .mp-legal-label { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #4a5568; margin-bottom: .15rem; }
      .mp-legal-val { font-size: 0.875rem; font-weight: 500; color: #2d3748; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .mp-badge--legal-pending { background: #FEF3C7; color: #b45309; }
      .mp-badge--legal-active { background: #D1FAE5; color: #065f46; }
      .mp-badge--legal-na { background: #F1F5F9; color: #64748b; }
      .mp-platform-row { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.125rem; }
      .mp-platform { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.25rem 0.5rem; border-radius: 0.375rem; font-size: 0.68rem; font-weight: 600; text-decoration: none; transition: opacity .15s; }
      .mp-platform:hover { opacity: .75; }
      .mp-platform--airbnb { background: #FFF0EF; color: #FF5A5F; }
      .mp-platform--booking { background: #EFF3FF; color: #003580; }

      /* Action column */
      .mp-action-col { width: 130px; flex-shrink: 0; padding: 1.25rem 1rem; display: flex; flex-direction: column; align-items: stretch; justify-content: center; gap: 0.5rem; }
      .mp-status-pill { display: inline-flex; align-items: center; justify-content: center; gap: 0.3rem; padding: 0.3rem 0.625rem; border-radius: 99px; font-size: 0.73rem; font-weight: 700; }
      .mp-status-pill--libre { background: #D1FAE5; color: #065f46; }
      .mp-status-pill--ocupada { background: #FEE2E2; color: #991b1b; }
      .mp-btn-ver { display: flex; align-items: center; justify-content: center; gap: 0.35rem; padding: 0.55rem 0.5rem; background: #0F172A; color: #fff; border-radius: 0.625rem; text-decoration: none; font-size: 0.8rem; font-weight: 600; transition: background .15s; }
      .mp-btn-ver:hover { background: #1e293b; color: #fff; }
      .mp-btn-reserva { display: flex; align-items: center; justify-content: center; gap: 0.35rem; padding: 0.55rem 0.5rem; background: #10B981; color: #fff; border-radius: 0.625rem; text-decoration: none; font-size: 0.8rem; font-weight: 600; transition: background .15s; }
      .mp-btn-reserva:hover { background: #059669; color: #fff; }
      .mp-btn-del { display: flex; align-items: center; justify-content: center; gap: 0.35rem; padding: 0.45rem 0.5rem; background: #FEF2F2; color: #EF4444; border: none; border-radius: 0.625rem; font-size: 0.75rem; font-weight: 600; cursor: pointer; transition: background .15s; }
      .mp-btn-del:hover { background: #FEE2E2; }

      /* Empty */
      .mp-empty { background: #fff; border-radius: 1rem; padding: 4rem 2rem; text-align: center; box-shadow: 0 1px 3px rgba(15,23,42,.06); }

      /* Alert banners */
      .mp-alert { display: flex; align-items: center; gap: 0.625rem; padding: 0.75rem 1.125rem; border-radius: 0.625rem; font-size: 0.875rem; font-weight: 500; margin-bottom: 1.25rem; }
      .mp-alert--success { background: #D1FAE5; color: #065f46; }
      .mp-alert--error { background: #FEE2E2; color: #991b1b; }

      /* filter-pill compat for JS */
      .filter-pill { padding: 0.45rem 0.875rem; border-radius: 99px; font-size: 0.8rem; font-weight: 600; border: 1.5px solid #e2e8f0; background: #fff; color: #64748b; cursor: pointer; transition: all .15s; }
      .filter-pill:hover { border-color: #cbd5e1; color: #0F172A; }
      .filter-pill--active, .filter-pill.active { background: #0F172A !important; color: #fff !important; border-color: #0F172A !important; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <%- include('../partials/spinner') %>

    <main>
      <div class="mp-page">

        <!-- Alertas -->
        <% if (typeof mensaje !== 'undefined' && mensaje === 'eliminada') { %>
        <div class="mp-alert mp-alert--success" id="alertMessage">
            <i class="fas fa-check-circle"></i> Propiedad eliminada correctamente
        </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error === 'eliminacion') { %>
        <div class="mp-alert mp-alert--error" id="alertMessage">
            <i class="fas fa-exclamation-triangle"></i> Error al eliminar la propiedad
        </div>
        <% } %>

        <!-- Header -->
        <div class="mp-header">
            <h1 class="mp-title">
                Mis Propiedades
                <% if (viviendas && viviendas.length > 0) { %><span><%= viviendas.length %> propiedades</span><% } %>
            </h1>
            <button class="mp-btn-add" onclick="abrirModalNuevaPropiedad()">
                <i class="fas fa-plus"></i> Añadir Propiedad
            </button>
        </div>

        <!-- Toolbar -->
        <div class="mp-toolbar">
            <div class="mp-search-wrap">
                <i class="fas fa-search"></i>
                <input type="text" id="searchNombre" class="mp-search" placeholder="Buscar por nombre...">
            </div>
            <div class="mp-search-wrap" style="max-width: 220px;">
                <i class="fas fa-map-marker-alt"></i>
                <input type="text" id="searchCiudad" class="mp-search" placeholder="Buscar por ciudad...">
            </div>
        </div>

        <!-- Lista de propiedades -->
        <div id="propiedadesGrid" class="mp-list">

          <% if (viviendas && viviendas.length > 0) { %>
            <% viviendas.forEach(vivienda => {
                let amenities = [];
                try {
                    if (vivienda.amenities) {
                        amenities = typeof vivienda.amenities === 'string' ? JSON.parse(vivienda.amenities) : vivienda.amenities;
                    }
                } catch(e) {}
                const amenityLabels = { wifi: 'WiFi', aire_acondicionado: 'A/C', cocina_equipada: 'Cocina', terraza: 'Terraza', piscina: 'Piscina', jardin: 'Jardín', parking: 'Parking', calefaccion: 'Calefacción', lavadora: 'Lavadora', secadora: 'Secadora', gimnasio: 'Gimnasio', tv: 'TV' };
                let legalClass = 'mp-badge--legal-na';
                if (vivienda.estado_legal) {
                    const el = vivienda.estado_legal.toLowerCase();
                    if (el.includes('tramite') || el.includes('trámite') || el.includes('pendiente')) legalClass = 'mp-badge--legal-pending';
                    else if (el.includes('activo') || el.includes('activa') || el.includes('vigente') || el.includes('aprobado')) legalClass = 'mp-badge--legal-active';
                }
            %>
            <article class="mp-card" data-nombre="<%= (vivienda.nombre || '').toLowerCase() %>" data-ciudad="<%= (vivienda.ciudad || '').toLowerCase() %>">

              <!-- COL 1: Imagen + Precio -->
              <div class="mp-img-col">
                <div class="mp-img-wrap">
                  <% if (vivienda.imagen_url) { %>
                    <img src="<%= vivienda.imagen_url %>" alt="<%= vivienda.nombre %>">
                  <% } else { %>
                    <div class="mp-img-placeholder" onclick="document.getElementById('file-<%= vivienda.id_vivienda %>').click()">
                      <i class="fas fa-camera" style="font-size:2rem;color:rgba(255,255,255,.45);"></i>
                    </div>
                  <% } %>
                  <button class="mp-cam-btn" onclick="document.getElementById('file-<%= vivienda.id_vivienda %>').click()" title="Cambiar imagen">
                    <i class="fas fa-camera"></i>
                  </button>
                  <input type="file" id="file-<%= vivienda.id_vivienda %>" accept="image/*" style="display:none;">
                </div>
                <div class="mp-price-badge">
                  <% if (vivienda.precio_alquiler) { %>
                    <span class="mp-price-val"><%= Number(vivienda.precio_alquiler).toLocaleString('es-ES') %>€</span>
                    <span class="mp-price-unit">/noche</span>
                  <% } else { %>
                    <span class="mp-price-none">Sin precio</span>
                  <% } %>
                </div>
              </div>

              <!-- COL 2: Info principal -->
              <div class="mp-info-col">
                <h3 class="mp-name" title="<%= vivienda.nombre %>"><%= vivienda.nombre %></h3>
                <div class="mp-type-row">
                  <% if (vivienda.tipo_vivienda) { %><span class="mp-badge mp-badge--type"><%= vivienda.tipo_vivienda %></span><% } %>
                  <% if (vivienda.categoria) { %><span class="mp-badge mp-badge--cat"><%= vivienda.categoria %></span><% } %>
                </div>
                <p class="mp-location">
                  <i class="fas fa-map-marker-alt"></i>
                  <%
                    var addrParts = [];
                    var streetParts = [];
                    if (vivienda.calle) streetParts.push(vivienda.calle);
                    if (vivienda.bloque_portal) streetParts.push(vivienda.bloque_portal);
                    if (vivienda.piso) streetParts.push(vivienda.piso);
                    if (vivienda.escalera) streetParts.push('Esc. ' + vivienda.escalera);
                    if (vivienda.letra_numero) streetParts.push(vivienda.letra_numero);
                    if (streetParts.length) addrParts.push(streetParts.join(' '));
                    if (vivienda.barrio) addrParts.push(vivienda.barrio);
                    if (vivienda.ciudad) addrParts.push(vivienda.ciudad);
                    if (vivienda.pais) addrParts.push(vivienda.pais);
                  %>
                  <%= addrParts.length ? addrParts.join(', ') : 'Sin ubicación' %>
                </p>
                <div class="mp-stats">
                  <div class="mp-stat"><i class="fas fa-bed"></i> <strong><%= vivienda.num_habitaciones || '—' %></strong>&nbsp;<span style="font-size:.8rem;color:#94a3b8;">hab</span></div>
                  <div class="mp-stat"><i class="fas fa-bath"></i> <strong><%= vivienda.num_banos || '—' %></strong>&nbsp;<span style="font-size:.8rem;color:#94a3b8;">baños</span></div>
                  <% if (vivienda.superficie) { %><div class="mp-stat"><i class="fas fa-ruler-combined"></i> <strong><%= Math.round(vivienda.superficie) %></strong>&nbsp;<span style="font-size:.8rem;color:#94a3b8;">m²</span></div><% } %>
                  <% if (vivienda.capacidad_maxima) { %><div class="mp-stat"><i class="fas fa-users"></i> <strong><%= vivienda.capacidad_maxima %></strong>&nbsp;<span style="font-size:.8rem;color:#94a3b8;">pers</span></div><% } %>
                </div>
                <div class="mp-amenities">
                  <% amenities.slice(0,4).forEach(a => { %><span class="mp-chip"><%= amenityLabels[a] || a %></span><% }) %>
                  <% if (amenities.length > 4) { %><span class="mp-chip">+<%= amenities.length - 4 %></span><% } %>
                </div>
              </div>

              <!-- COL 3: Legal / Plataformas -->
              <div class="mp-legal-col">
                <div>
                  <div class="mp-legal-label">Estado legal</div>
                  <% if (vivienda.estado_legal) { %>
                    <span class="mp-badge <%= legalClass %>"><%= vivienda.estado_legal %></span>
                  <% } else { %>
                    <span class="mp-badge mp-badge--legal-na">—</span>
                  <% } %>
                </div>
                <% if (vivienda.referencia_catastral) { %>
                <div>
                  <div class="mp-legal-label">Ref. Catastral</div>
                  <div class="mp-legal-val" title="<%= vivienda.referencia_catastral %>"><%= vivienda.referencia_catastral %></div>
                </div>
                <% } %>
                <% if (vivienda.url_airbnb || vivienda.url_booking) { %>
                <div>
                  <div class="mp-legal-label">Plataformas</div>
                  <div class="mp-platform-row">
                    <% if (vivienda.url_airbnb) { %>
                      <a href="<%= vivienda.url_airbnb %>" target="_blank" class="mp-platform mp-platform--airbnb">
                        <i class="fab fa-airbnb"></i> Airbnb
                      </a>
                    <% } %>
                    <% if (vivienda.url_booking) { %>
                      <a href="<%= vivienda.url_booking %>" target="_blank" class="mp-platform mp-platform--booking">
                        <i class="fas fa-hotel"></i> Booking
                      </a>
                    <% } %>
                  </div>
                </div>
                <% } %>
                <% if (vivienda.fecha_registro) { %>
                <div>
                  <div class="mp-legal-label">Registro</div>
                  <div class="mp-legal-val"><%= new Date(vivienda.fecha_registro).toLocaleDateString('es-ES') %></div>
                </div>
                <% } %>
              </div>

              <!-- COL 4: Acciones -->
              <div class="mp-action-col">
                <a href="/viviendas/<%= vivienda.id_vivienda %>" class="mp-btn-ver">
                  <i class="fas fa-eye" style="font-size:.75rem;"></i> Ver
                </a>
                <a href="/viviendas/<%= vivienda.id_vivienda %>?tab=channels" class="mp-btn-reserva">
                  <i class="fas fa-calendar-plus" style="font-size:.75rem;"></i> Reserva
                </a>
                <button class="mp-btn-del" onclick="eliminarVivienda('<%= vivienda.id_vivienda %>')" title="Eliminar propiedad">
                  <i class="fas fa-trash-alt" style="font-size:.75rem;"></i> Eliminar
                </button>
              </div>

            </article>
            <% }) %>

          <% } else { %>
            <!-- Empty State -->
            <div class="mp-empty">
              <div style="width:4rem;height:4rem;background:#F1F5F9;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
                <i class="fas fa-home" style="font-size:1.5rem;color:#94a3b8;"></i>
              </div>
              <h3 style="font-size:1.125rem;font-weight:700;color:#0F172A;margin:0 0 .5rem;">No hay propiedades registradas</h3>
              <p style="color:#64748b;margin:0 0 1.5rem;font-size:.875rem;">Comienza añadiendo tu primera propiedad al sistema</p>
              <button class="mp-btn-add" onclick="abrirModalNuevaPropiedad()" style="margin:0 auto;">
                <i class="fas fa-plus"></i> Añadir Primera Propiedad
              </button>
            </div>
          <% } %>

        </div><!-- /#propiedadesGrid -->

        <!-- Mensaje sin resultados (JS) -->
        <div id="noResultsMessage" style="display:none;">
          <div class="mp-empty">
            <div style="width:4rem;height:4rem;background:#F1F5F9;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
              <i class="fas fa-search" style="font-size:1.5rem;color:#94a3b8;"></i>
            </div>
            <h3 style="font-size:1.125rem;font-weight:700;color:#0F172A;margin:0 0 .5rem;">Sin resultados</h3>
            <p style="color:#64748b;margin:0;font-size:.875rem;">Prueba con otros términos o filtros</p>
          </div>
        </div>

      </div><!-- /.mp-page -->
    </main>

    <%- include('../partials/modal-nueva-propiedad') %>

    <!-- Modal: Confirmar Eliminación -->
    <div id="modalConfirmarEliminar" class="modal-overlay">
        <div class="modal-delete">
            <div class="modal-delete-icon">
                <i class="fas fa-trash-alt"></i>
            </div>
            <h3 class="modal-delete-title">¿Eliminar propiedad?</h3>
            <p class="modal-delete-text">Esta acción ocultará la propiedad del listado</p>
            <div class="modal-delete-actions">
                <button class="btn-modal-cancel" onclick="cerrarModalEliminar()">Cancelar</button>
                <button class="btn-modal-delete" onclick="confirmarEliminarVivienda()">Eliminar</button>
            </div>
        </div>
    </div>

    <%- include('../partials/modal-comodidades') %>

    <!-- Bootstrap JS -->
