            <!-- Footer -->
            <div class="custom-modal-footer">
                <button type="button" class="btn-secondary" onclick="cerrarModalNuevaPropiedad()">
                    Cancelar
                </button>
                <button type="button" class="btn-primary" onclick="submitNuevaPropiedad()">
                    <i class="fas fa-save"></i>
                    Guardar Propiedad
                </button>
