<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Propiedades - Dashboard</title>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- CSS Personalizado -->
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/mostrar-propiedades.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <!-- Contenedor Principal Dashboard -->
    <main class="dashboard-main">
        
        <!-- Mensajes de éxito/error -->
        <% if (typeof mensaje !== 'undefined' && mensaje === 'eliminada') { %>
        <div class="alert-success" id="alertMessage">
            <i class="fas fa-check-circle"></i>
            Propiedad eliminada correctamente
        </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error === 'eliminacion') { %>
        <div class="alert-error" id="alertMessage">
            <i class="fas fa-exclamation-circle"></i>
            Error al eliminar la propiedad
        </div>
        <% } %>
        
        <!-- Micro KPIs -->
        <section class="kpi-section">
            <!-- Contenedor con fondo claro -->
            <div class="kpi-wrapper">
                <div class="kpi-row">
                
                <!-- KPI: Ingresos -->
                <div class="kpi-micro">
                    <div class="kpi-icon kpi-icon--success">
                        <i class="fas fa-euro-sign"></i>
                    </div>
                    <div class="kpi-content">
                        <span class="kpi-label">Ingresos</span>
                        <div class="kpi-value-row">
                            <span class="kpi-value">€8,450</span>
                            <span class="kpi-trend kpi-trend--up">+12.5%</span>
                        </div>
                    </div>
                </div>

                <!-- KPI: Ocupación -->
                <div class="kpi-micro">
                    <div class="kpi-icon kpi-icon--info">
                        <i class="fas fa-chart-pie"></i>
                    </div>
                    <div class="kpi-content">
                        <span class="kpi-label">Ocupación</span>
                        <div class="kpi-value-row">
                            <span class="kpi-value">75%</span>
                            <div class="kpi-progress">
                                <div class="kpi-progress-fill" style="width: 75%"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- KPI: Alertas -->
                <div class="kpi-micro">
                    <div class="kpi-icon kpi-icon--danger">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <div class="kpi-content">
                        <span class="kpi-label">Tareas Urgentes</span>
                        <div class="kpi-value-row">
                            <span class="kpi-value kpi-value--danger">3</span>
                            <span class="kpi-trend kpi-trend--up">+2</span>
                        </div>
                    </div>
                </div>

                <!-- KPI: Reservas -->
                <div class="kpi-micro">
                    <div class="kpi-icon kpi-icon--purple">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                    <div class="kpi-content">
                        <span class="kpi-label">Reservas</span>
                        <div class="kpi-value-row">
                            <span class="kpi-value">7</span>
                        </div>
                    </div>
                </div>
                </div>
            </div>
        </section>

        <!-- Barra de Herramientas -->
        <section class="toolbar">
            <div class="toolbar-search">
                <i class="fas fa-search"></i>
                <input 
                    type="text" 
                    id="searchInput" 
                    class="toolbar-input" 
                    placeholder="Buscar por nombre, dirección o ciudad..."
                >
            </div>

            <div class="toolbar-filters">
                <button class="filter-pill filter-pill--active" data-filter="todas">Todas</button>
                <button class="filter-pill" data-filter="libre">Libres</button>
                <button class="filter-pill" data-filter="ocupada">Ocupadas</button>
            </div>

            <button class="btn-primary" onclick="abrirModalNuevaPropiedad()">
                <i class="fas fa-plus"></i>
                <span>Añadir Propiedad</span>
            </button>
        </section>

        <!-- Layout Principal: Grid + Sidebar -->
        <div class="content-layout">
            
            <!-- Grid de Propiedades (75%) -->
            <div class="properties-container">
                <!-- Contenedor con fondo claro -->
                <div class="properties-wrapper">
                    <div id="propiedadesGrid" class="properties-grid">
                    
                    <% if (viviendas && viviendas.length > 0) { %>
                        <% viviendas.forEach(vivienda => { %>
                            <article class="property-card" data-estado="<%= vivienda.estado_actual %>">
                                
                                <!-- Imagen -->
                                <div class="property-image">
                                    <% if (vivienda.imagen_url) { %>
                                        <img src="<%= vivienda.imagen_url %>" alt="<%= vivienda.nombre %>">
                                    <% } else { %>
                                        <div class="image-placeholder" onclick="document.getElementById('file-<%= vivienda.id_vivienda %>').click()">
                                            <i class="fas fa-camera"></i>
                                            <span class="fa-plus"><i class="fas fa-plus"></i></span>
                                        </div>
                                    <% } %>
                                    
                                    <!-- Badge Estado -->
                                    <div class="status-badge status-badge--<%= vivienda.estado_actual || 'default' %>">
                                        <i class="fas fa-circle"></i>
                                        <%= vivienda.estado_actual === 'libre' ? 'Libre' : vivienda.estado_actual === 'ocupada' ? 'Ocupada' : 'Sin estado' %>
                                    </div>

                                    <!-- Botón Cámara (hover) -->
                                    <% if (vivienda.imagen_url) { %>
                                        <button 
                                            type="button" 
                                            class="camera-overlay" 
                                            onclick="document.getElementById('file-<%= vivienda.id_vivienda %>').click()"
                                        >
                                            <i class="fas fa-camera"></i>
                                        </button>
                                    <% } %>

                                    <!-- Input File Oculto -->
                                    <input 
                                        type="file" 
                                        id="file-<%= vivienda.id_vivienda %>" 
                                        accept="image/*" 
                                        style="display: none;"
                                        onchange="subirImagenVivienda(<%= vivienda.id_vivienda %>)"
                                    >
                                </div>

                                <!-- Cuerpo de Card -->
                                <div class="property-body">
                                    <h3 class="property-title"><%= vivienda.nombre %></h3>
                                    <p class="property-address">
                                        <i class="fas fa-map-marker-alt"></i>
                                        <%= vivienda.direccion %>, <%= vivienda.ciudad %>
                                    </p>

                                    <!-- Especificaciones -->
                                    <div class="property-specs">
                                        <span class="spec">
                                            <i class="fas fa-ruler-combined"></i>
                                            <%= vivienda.metros_cuadrados || 85 %>m²
                                        </span>
                                        <span class="spec">
                                            <i class="fas fa-bed"></i>
                                            <%= vivienda.num_dormitorios || 2 %>
                                        </span>
                                        <span class="spec">
                                            <i class="fas fa-bath"></i>
                                            <%= vivienda.num_banos || 1 %>
                                        </span>
                                    </div>

                                    <!-- Acciones -->
                                    <div class="property-actions">
                                        <a href="/viviendas/<%= vivienda.id_vivienda %>" class="btn-action btn-action--primary">
                                            <i class="fas fa-eye"></i>
                                            Ver
                                        </a>
                                        <a href="/viviendas/<%= vivienda.id_vivienda %>/editar" class="btn-action btn-action--secondary">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <button onclick="eliminarVivienda(<%= vivienda.id_vivienda %>)" class="btn-action btn-action--danger">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </div>
                            </article>
                        <% }) %>
                    <% } else { %>
                        <!-- Empty State -->
                        <div class="empty-state">
                            <div class="empty-icon">
                                <i class="fas fa-home"></i>
                            </div>
                            <h3 class="empty-title">No hay propiedades registradas</h3>
                            <p class="empty-text">Comienza agregando tu primera propiedad al sistema</p>
                            <button class="btn-primary" onclick="abrirModalNuevaPropiedad()">
                                <i class="fas fa-plus"></i>
                                Agregar Primera Propiedad
                            </button>
                        </div>
                    <% } %>
                </div>
                </div>

                <!-- Mensaje No Resultados (dinámico JS) -->
                <div id="noResultsMessage" class="no-results" style="display: none;">
                    <i class="fas fa-search"></i>
                    <h3>No se encontraron propiedades</h3>
                    <p>Intenta ajustar los filtros o términos de búsqueda</p>
                </div>
            </div>

            <!-- Sidebar Sticky (25%) -->
            <aside class="sidebar">
                
                <!-- Widget: Tareas Pendientes -->
                <div class="widget">
                    <div class="widget-header">
                        <div class="widget-icon">
                            <i class="fas fa-clipboard-list"></i>
                        </div>
                        <h3 class="widget-title">Tareas Pendientes</h3>
                    </div>

                    <div class="task-list">
                        <div class="task-item task-item--high">
                            <div class="task-info">
                                <h4 class="task-name">Fuga de agua</h4>
                                <span class="task-priority">ALTA</span>
                            </div>
                            <p class="task-location">Apartamento Centro - Piso 3B</p>
                            <div class="task-meta">
                                <span class="task-date"><i class="far fa-calendar"></i> Hoy</span>
                                <a href="#" class="task-link">Ver →</a>
                            </div>
                        </div>

                        <div class="task-item task-item--medium">
                            <div class="task-info">
                                <h4 class="task-name">Revisión caldera</h4>
                                <span class="task-priority">MEDIA</span>
                            </div>
                            <p class="task-location">Villa Norte</p>
                            <div class="task-meta">
                                <span class="task-date"><i class="far fa-calendar"></i> En 3 días</span>
                                <a href="#" class="task-link">Ver →</a>
                            </div>
                        </div>

                        <div class="task-item task-item--low">
                            <div class="task-info">
                                <h4 class="task-name">Pintar fachada</h4>
                                <span class="task-priority">BAJA</span>
                            </div>
                            <p class="task-location">Edificio Sur</p>
                            <div class="task-meta">
                                <span class="task-date"><i class="far fa-calendar"></i> En 2 semanas</span>
                                <a href="#" class="task-link">Ver →</a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Widget: Resumen de Cartera -->
                <div class="widget">
                    <h3 class="widget-title widget-title--solo">Resumen de Cartera</h3>
                    
                    <div class="summary-list">
                        <div class="summary-item">
                            <span class="summary-label">Total Propiedades</span>
                            <span class="summary-value summary-value--total">
                                <%= viviendas ? viviendas.length : 0 %>
                            </span>
                        </div>
                        <div class="summary-item">
                            <span class="summary-label">Libres</span>
                            <span class="summary-value summary-value--success">
                                <%= viviendas ? viviendas.filter(v => v.estado_actual === 'libre').length : 0 %>
                            </span>
                        </div>
                        <div class="summary-item">
                            <span class="summary-label">Ocupadas</span>
                            <span class="summary-value summary-value--warning">
                                <%= viviendas ? viviendas.filter(v => v.estado_actual === 'ocupada').length : 0 %>
                            </span>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </main>

    <!-- Modal: Nueva Propiedad -->
    <div id="modalNuevaPropiedad" class="modal-overlay">
        <div class="custom-modal-dialog">
            
            <!-- Header -->
            <div class="custom-modal-header">
                <h2 class="custom-modal-title">Nueva Propiedad</h2>
                <button type="button" class="custom-modal-close" onclick="cerrarModalNuevaPropiedad()">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <!-- Body -->
            <div class="custom-modal-body">
                <form id="formNuevaPropiedad">
                    
                    <!-- Bloque: Información Básica -->
                    <div class="form-block">
                        <div class="form-block-header">
                            <i class="fas fa-info-circle"></i>
                            <h3>Información Básica</h3>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label>Nombre de la propiedad *</label>
                                <input type="text" name="nombre" placeholder="Ej: Apartamento céntrico en Madrid" required class="form-input">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label>Imagen de la Propiedad</label>
                                <input type="file" name="imagen" accept="image/jpeg,image/jpg,image/png,image/gif,image/webp" class="form-input">
                                <span class="form-hint">JPG, PNG, GIF, WEBP (máx. 5MB)</span>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label>Descripción</label>
                                <textarea name="descripcion" rows="4" placeholder="Describe tu propiedad: características principales, ubicación, servicios cercanos..." class="form-input"></textarea>
                            </div>
                        </div>
                        <div class="form-row form-row--3">
                            <div class="form-field">
                                <label><i class="fas fa-euro-sign"></i> Precio por noche (€) *</label>
                                <input type="number" name="precio_alquiler" step="0.01" min="0" placeholder="50.00" required class="form-input">
                            </div>
                            <div class="form-field">
                                <label><i class="fas fa-ruler"></i> Superficie (m²) *</label>
                                <input type="number" name="superficie" min="1" placeholder="75" required class="form-input">
                            </div>
                            <div class="form-field">
                                <label><i class="fas fa-users"></i> Máximo de huéspedes *</label>
                                <input type="number" name="capacidad_maxima" min="1" placeholder="4" required class="form-input">
                            </div>
                        </div>
                    </div>

                    <!-- Bloque: Ubicación -->
                    <div class="form-block">
                        <div class="form-block-header">
                            <i class="fas fa-map-pin"></i>
                            <h3>Ubicación</h3>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label>Calle *</label>
                                <input type="text" name="calle" placeholder="Calle Mayor" required class="form-input">
                            </div>
                        </div>
                        <div class="form-row form-row--4">
                            <div class="form-field">
                                <label>Bloque/Portal</label>
                                <input type="text" name="bloque_portal" placeholder="Portal B" class="form-input">
                            </div>
                            <div class="form-field">
                                <label>Escalera</label>
                                <input type="text" name="escalera" placeholder="Escalera 2" class="form-input">
                            </div>
                            <div class="form-field">
                                <label>Piso</label>
                                <input type="text" name="piso" placeholder="3º" class="form-input">
                            </div>
                            <div class="form-field">
                                <label>Letra/Número</label>
                                <input type="text" name="letra_numero" placeholder="A" class="form-input">
                            </div>
                        </div>
                        <!-- Campo oculto para dirección completa generada automáticamente -->
                        <input type="hidden" name="direccion" value="">
                        <div class="form-row form-row--3">
                            <div class="form-field">
                                <label>Ciudad *</label>
                                <input type="text" name="ciudad" placeholder="Madrid" required class="form-input">
                            </div>
                            <div class="form-field">
                                <label>País *</label>
                                <input type="text" name="pais" value="España" placeholder="España" required class="form-input">
                            </div>
                            <div class="form-field">
                                <label>Código Postal</label>
                                <input type="text" name="codigo_postal" placeholder="28001" class="form-input">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label>Barrio</label>
                                <input type="text" name="barrio" placeholder="Centro" class="form-input">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label>Buscar ubicación en el mapa</label>
                                <div class="map-search">
                                    <input type="text" id="buscarDireccion" placeholder="Busca la dirección..." class="form-input">
                                    <button type="button" onclick="buscarUbicacion()" class="btn-secondary">
                                        <i class="fas fa-search"></i>
                                    </button>
                                </div>
                                <span class="form-hint">Haz clic en el mapa para marcar la ubicación exacta</span>
                            </div>
                        </div>
                        <div id="mapa-nuevo" class="map-container"></div>
                        <div class="form-row">
                            <div class="form-field">
                                <label><i class="fas fa-map"></i> Latitud</label>
                                <input type="number" name="latitud" id="latitudInput" step="0.00000001" placeholder="40.41677500" readonly class="form-input">
                                <span class="form-hint">Se obtiene automáticamente del mapa</span>
                            </div>
                            <div class="form-field">
                                <label><i class="fas fa-map"></i> Longitud</label>
                                <input type="number" name="longitud" id="longitudInput" step="0.00000001" placeholder="-3.70379000" readonly class="form-input">
                                <span class="form-hint">Se obtiene automáticamente del mapa</span>
                            </div>
                        </div>
                    </div>

                    <!-- Bloque: Características -->
                    <div class="form-block">
                        <div class="form-block-header">
                            <i class="fas fa-sliders-h"></i>
                            <h3>Características</h3>
                        </div>
                        <div class="form-row form-row--3">
                            <div class="form-field">
                                <label>Categoría de Vivienda *</label>
                                <select name="tipo_vivienda" required class="form-select">
                                    <option value="">Seleccionar</option>
                                    <option value="Vivienda de Uso Turístico">Vivienda de Uso Turístico</option>
                                    <option value="Apartamento Turístico">Apartamento Turístico</option>
                                    <option value="Casa Rural">Casa Rural</option>
                                    <option value="Vivienda Turística">Vivienda Turística</option>
                                </select>
                            </div>
                            <div class="form-field">
                                <label>Planta</label>
                                <input type="number" name="planta" min="0" placeholder="3" class="form-input">
                            </div>
                            <div class="form-field">
                                <label>Año de construcción</label>
                                <input type="number" name="ano_construccion" min="1800" max="2030" placeholder="2005" class="form-input">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label><i class="fas fa-bed"></i> Número de dormitorios *</label>
                                <input type="number" name="num_habitaciones" min="0" placeholder="2" required class="form-input">
                            </div>
                            <div class="form-field">
                                <label><i class="fas fa-bath"></i> Número de baños *</label>
                                <input type="number" name="num_banos" min="0" placeholder="1" required class="form-input">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label>Superficie de la parcela (m²)</label>
                                <input type="number" name="superficie_parcela" min="0" placeholder="Se usa la superficie de la vivienda por defecto" class="form-input">
                                <span class="form-hint">Deja vacío para usar la misma superficie que la vivienda</span>
                            </div>
                        </div>
                    </div>

                    <!-- Bloque: Comodidades -->
                    <div class="form-block">
                        <div class="form-block-header">
                            <i class="fas fa-sparkles"></i>
                            <h3>Comodidades</h3>
                        </div>
                        <button type="button" class="btn-amenities" onclick="abrirModalComodidades()">
                            <i class="fas fa-cog"></i>
                            Gestionar Comodidades
                        </button>
                        <div id="selectedAmenitiesDisplay" class="selected-amenities-display">
                            <span class="text-muted">No se han seleccionado comodidades</span>
                        </div>
                        <!-- Inputs hidden para enviar al backend -->
                        <div id="hiddenAmenitiesInputs"></div>
                    </div>

                    <!-- Bloque: Datos Legales -->
                    <div class="form-block">
                        <div class="form-block-header">
                            <i class="fas fa-file-contract"></i>
                            <h3>Datos Legales</h3>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label>Estado Legal</label>
                                <select name="estado_legal" class="form-select">
                                    <option value="">Seleccionar</option>
                                    <option value="Activa">Activa</option>
                                    <option value="En trámite">En trámite</option>
                                    <option value="No aplica">No aplica</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label>Referencia Catastral</label>
                                <input type="text" name="referencia_catastral" placeholder="1234567VK1234S0001AA" class="form-input">
                            </div>
                            <div class="form-field">
                                <label>Nº Registro Autonómico</label>
                                <input type="text" name="numero_registro_autonomico" placeholder="VUT-12345" class="form-input">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label>Fecha de Registro</label>
                                <input type="date" name="fecha_registro" class="form-input">
                            </div>
                        </div>
                    </div>

                    <!-- Bloque: Plataformas -->
                    <div class="form-block">
                        <div class="form-block-header">
                            <i class="fas fa-link"></i>
                            <h3>Conexión con Plataformas</h3>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label><i class="fab fa-airbnb"></i> URL de Airbnb</label>
                                <input type="url" name="url_airbnb" placeholder="https://airbnb.com/rooms/..." class="form-input">
                            </div>
                            <div class="form-field">
                                <label><i class="fas fa-bed"></i> URL de Booking</label>
                                <input type="url" name="url_booking" placeholder="https://booking.com/hotel/..." class="form-input">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label><i class="fas fa-calendar-alt"></i> URL iCal Airbnb</label>
                                <input type="url" name="url_ical_airbnb" placeholder="https://airbnb.com/calendar/ical/..." class="form-input">
                                <span class="form-hint">Para sincronizar el calendario de Airbnb</span>
                            </div>
                            <div class="form-field">
                                <label><i class="fas fa-calendar-alt"></i> URL iCal Booking</label>
                                <input type="url" name="url_ical_booking" placeholder="https://booking.com/calendar/ical/..." class="form-input">
                                <span class="form-hint">Para sincronizar el calendario de Booking</span>
                            </div>
                        </div>
                    </div>

                    <!-- Bloque: Estado -->
                    <div class="form-block">
                        <div class="form-block-header">
                            <i class="fas fa-toggle-on"></i>
                            <h3>Estado de la Propiedad</h3>
                        </div>
                        <div class="form-row">
                            <div class="form-field">
                                <label>Categoría</label>
                                <select name="categoria" class="form-select">
