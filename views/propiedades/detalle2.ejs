            <label style="font-size:0.75rem;font-weight:600;color:#475569;text-transform:uppercase;letter-spacing:.05em;display:block;margin-bottom:.4rem;">Longitud</label>
            <input type="number" id="editCoordLng" placeholder="Ej: -3.703790" step="0.000001"
              style="width:100%;border:1.5px solid #e2e8f0;border-radius:.4rem;padding:.5rem .75rem;font-size:0.875rem;color:#1a2332;outline:none;transition:border .2s;font-family:inherit;"
              onfocus="this.style.borderColor='#1a2332'"
              onblur="this.style.borderColor='#e2e8f0'">
          </div>
        </div>
        <div class="modal-footer" style="border:none;padding:.75rem 1.25rem;gap:.5rem;justify-content:flex-end;">
          <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal"
            style="font-size:.8rem;border-radius:.4rem;">Cancelar</button>
          <button type="button" id="btnSaveCoordinates" class="btn btn-sm"
            style="background:#1a2332;color:#fff;border:none;border-radius:.4rem;font-size:.8rem;padding:.35rem .9rem;">
            <i class="fas fa-check me-1"></i>Guardar
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal Confirmar Eliminar Comodidad -->
  <div class="modal fade" id="modalConfirmDeleteAmenity" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px">
      <div class="modal-content" style="border:none;border-radius:0.75rem;overflow:hidden;box-shadow:0 10px 25px -5px rgba(0,0,0,0.1);">
        <div class="modal-header" style="background:#f8fafc;border-bottom:1px solid #f1f5f9;padding:1.25rem;">
          <h5 class="modal-title" style="font-size:1.1rem;font-weight:600;color:#0f172a;"><i class="fas fa-exclamation-triangle" style="color:#ef4444;margin-right:0.6rem;"></i>Eliminar Comodidad</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="font-size:.8rem;"></button>
        </div>
        <div class="modal-body" style="padding:1.5rem 1.25rem;">
          <p style="margin:0;color:#475569;font-size:0.95rem;">¿Seguro que quieres eliminar la comodidad <strong id="amenityToDeleteName" style="color:#0f172a;"></strong>?</p>
        </div>
        <div class="modal-footer" style="border-top:1px solid #f1f5f9;padding:.75rem 1.25rem;gap:.5rem;justify-content:flex-end;">
          <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal" style="font-size:.85rem;border-radius:.4rem;padding:0.4rem 0.9rem;">Cancelar</button>
          <button type="button" id="btnConfirmDeleteAmenity" class="btn btn-sm" style="background:#ef4444;color:#fff;border:none;border-radius:.4rem;font-size:.85rem;padding:0.4rem 0.9rem;" onclick="ejecutarEliminarComodidad()">
            <i class="fas fa-trash me-1"></i>Eliminar
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    // --- GESTIÓN DE COMODIDADES (AMENITIES) INLINE ---
    let pendingDeleteAmenity = { id: null, nombre: null };

    function mostrarInputComodidad() {
      document.getElementById('btn-add-amenity-wrap').style.display = 'none';
      document.getElementById('add-amenity-form').style.display = 'flex';
      document.getElementById('nueva-comodidad-input').focus();
    }

    function ocultarInputComodidad() {
      document.getElementById('add-amenity-form').style.display = 'none';
      document.getElementById('btn-add-amenity-wrap').style.display = 'block';
      document.getElementById('nueva-comodidad-input').value = '';
    }

    async function guardarNuevaComodidad(viviendaId) {
      const input = document.getElementById('nueva-comodidad-input');
      const nombre = input.value.trim();

      if (!nombre) {
        alert('Por favor, escribe una comodidad.');
        return;
      }

      try {
        const response = await fetch(`/propiedades/${viviendaId}/amenities`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'add', amenity: nombre })
        });
        
        const data = await response.json();
        
        if (response.ok) {
          // Recargar la página para reflejar el cambio, o actualizar lista de amenities (elegimos recargar por consistencia con otros endpoints si no tenemos todo el render en JS, pero un refresh es rápido)
          window.location.reload();
        } else {
          alert('Error: ' + (data.message || data.error || 'No se pudo guardar'));
        }
      } catch (error) {
        console.error('Error al guardar la comodidad:', error);
        alert('Ocurrió un error en la solicitud.');
      }
    }

    function eliminarComodidad(viviendaId, nombre) {
      pendingDeleteAmenity = { id: viviendaId, nombre: nombre };
      document.getElementById('amenityToDeleteName').textContent = `"${nombre}"`;
      const modalElement = document.getElementById('modalConfirmDeleteAmenity');
      const modal = bootstrap.Modal.getInstance(modalElement) || new bootstrap.Modal(modalElement);
      modal.show();
    }

    async function ejecutarEliminarComodidad() {
      const { id: viviendaId, nombre } = pendingDeleteAmenity;
      if (!viviendaId || !nombre) return;
      
      const btn = document.getElementById('btnConfirmDeleteAmenity');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Eliminando...';

      try {
        const response = await fetch(`/propiedades/${viviendaId}/amenities`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'remove', amenity: nombre })
        });
        
        const data = await response.json();

        if (response.ok) {
          window.location.reload();
        } else {
          alert('Error: ' + (data.message || data.error || 'No se pudo eliminar'));
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-trash me-1"></i>Eliminar';
        }
      } catch (error) {
        console.error('Error al eliminar la comodidad:', error);
        alert('Ocurrió un error en la solicitud.');
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-trash me-1"></i>Eliminar';
      }
    }
  </script>
</body>
</html>
