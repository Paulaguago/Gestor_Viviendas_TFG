                    <span class="ficha-label">Planta</span>
                    <button class="btn-edit-field" data-field="planta" data-value="<%= vivienda.planta != null ? vivienda.planta : '' %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
