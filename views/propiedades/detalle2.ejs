                    <button class="btn-edit-field" data-field="fecha_registro" data-value="<%= vivienda.fecha_registro ? new Date(vivienda.fecha_registro).toISOString().split('T')[0] : '' %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
                  </div>
                </div>
              </div>

              <!-- PLATAFORMAS (enlaces) -->
              <div class="prop-section">
                <div class="prop-section-hdr">
                  <span class="prop-sec-label"><i class="fas fa-link"></i>Plataformas</span>
                </div>
                <div class="plat-rows">
                  <div class="ficha-item p-airbnb">
                    <div class="p-row-icon"><i class="fab fa-airbnb"></i></div>
                    <div class="p-row-info">
                      <span class="p-row-name">Airbnb</span>
                      <span class="ficha-value<%= vivienda.url_airbnb ? ' url-val' : '' %>" title="<%= vivienda.url_airbnb || '' %>"><%= vivienda.url_airbnb ? 'airbnb.com · Ver enlace' : 'No configurado' %></span>
                    </div>
                    <span class="ficha-label" style="display:none;">URL Airbnb</span>
                    <% if (vivienda.url_airbnb) { %><i class="fas fa-external-link-alt" style="color:#cbd5e1;font-size:0.7rem;"></i><% } %>
                    <button class="btn-edit-field" data-field="url_airbnb" data-value="<%= (vivienda.url_airbnb || '').replace(/'/g,'&#39;') %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
                  </div>
                  <div class="ficha-item p-booking">
                    <div class="p-row-icon"><i class="fas fa-bed"></i></div>
                    <div class="p-row-info">
                      <span class="p-row-name">Booking.com</span>
                      <span class="ficha-value<%= vivienda.url_booking ? ' url-val' : '' %>" title="<%= vivienda.url_booking || '' %>"><%= vivienda.url_booking ? 'booking.com · Ver enlace' : 'No configurado' %></span>
                    </div>
                    <span class="ficha-label" style="display:none;">URL Booking</span>
                    <% if (vivienda.url_booking) { %><i class="fas fa-external-link-alt" style="color:#cbd5e1;font-size:0.7rem;"></i><% } %>
                    <button class="btn-edit-field" data-field="url_booking" data-value="<%= (vivienda.url_booking || '').replace(/'/g,'&#39;') %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
                  </div>
                  <div class="ficha-item" style="border-bottom:none!important;">
                    <div class="p-row-icon" style="background:#F1F5F9;color:#64748b;"><i class="fas fa-sync-alt"></i></div>
                    <div class="p-row-info">
                      <span class="p-row-name">iCal Airbnb</span>
                      <span class="ficha-value<%= vivienda.url_ical_airbnb ? ' url-val' : '' %>" title="<%= vivienda.url_ical_airbnb || '' %>"><%= vivienda.url_ical_airbnb ? 'Configurado ✓' : 'No configurado' %></span>
                    </div>
                    <span class="ficha-label" style="display:none;">iCal Airbnb</span>
                    <button class="btn-edit-field" data-field="url_ical_airbnb" data-value="<%= (vivienda.url_ical_airbnb || '').replace(/'/g,'&#39;') %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
                  </div>
                  <div class="ficha-item" style="border-bottom:none!important;">
                    <div class="p-row-icon" style="background:#F1F5F9;color:#64748b;"><i class="fas fa-sync"></i></div>
                    <div class="p-row-info">
                      <span class="p-row-name">iCal Booking</span>
                      <span class="ficha-value<%= vivienda.url_ical_booking ? ' url-val' : '' %>" title="<%= vivienda.url_ical_booking || '' %>"><%= vivienda.url_ical_booking ? 'Configurado ✓' : 'No configurado' %></span>
                    </div>
                    <span class="ficha-label" style="display:none;">iCal Booking</span>
                    <button class="btn-edit-field" data-field="url_ical_booking" data-value="<%= (vivienda.url_ical_booking || '').replace(/'/g,'&#39;') %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
                  </div>
                </div>
              </div>

              <!-- COMODIDADES -->
              <div class="prop-section" style="border-bottom:none; margin-bottom: 2rem;">
                <div class="prop-section-hdr">
                  <span class="prop-sec-label"><i class="fas fa-star"></i>Comodidades</span>
                </div>
                <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.25rem;">
                  <div class="amenities-list" id="amenities-display">
                    <% 
                      let amenitiesList = [];
                      if (vivienda.amenities) {
                        try {
                          const parsed = JSON.parse(vivienda.amenities);
                          amenitiesList = Array.isArray(parsed) ? parsed : [];
                        } catch(e) {}
                      }
                      if (amenitiesList.length > 0) {
                        amenitiesList.forEach(function(amenity) {
                          const nombre = (typeof amenity === 'string') ? amenity : (amenity.nombre || amenity.name || String(amenity));
                          const icon = (typeof amenity === 'object' && amenity.icon) ? amenity.icon : 'check-circle';
                    %>
                          <div class="amenity-tag" style="background:#f1f5f9; position:relative; padding-right:2.5rem;">
                            <i class="fas fa-<%= icon %>" style="color:#64748b;"></i>
                            <span style="font-weight:600;"><%= nombre %></span>
                            <button type="button" title="Eliminar comodidad" onclick="eliminarComodidad('<%= vivienda.id_vivienda %>', '<%= nombre %>')" style="position:absolute; right:0; top:0; height:100%; width:2.2rem; display:flex; align-items:center; justify-content:center; background:none; border:none; border-left:1px solid #e2e8f0; color:#ef4444; border-radius: 0 0.5rem 0.5rem 0; cursor:pointer; transition:all 0.2s; opacity:0.8;">
                              <i class="fas fa-times"></i>
                            </button>
                          </div>
                    <%    });
                      } else { %>
                        <p id="no-amenities-msg" style="color:#94a3b8;font-size:0.85rem;margin:0;width:100%;font-style:italic;">No hay comodidades especificadas</p>
                    <% } %>
                  </div>

                  <!-- Botón y formulario para añadir -->
                  <div style="margin-top:1.25rem; border-top:1px dashed #e2e8f0; padding-top:1rem;">
                    <div id="btn-add-amenity-wrap">
                      <button type="button" class="btn-primary" onclick="mostrarInputComodidad()" style="font-size:0.85rem; padding:0.4rem 0.8rem; border-radius:0.5rem; background:transparent; color:#0f172a; border:1px dashed #94a3b8;"><i class="fas fa-plus"></i> Añadir Comodidad</button>
                    </div>
                    <div id="add-amenity-form" style="display:none; align-items:center; gap:0.5rem; animation:fadeIn 0.3s ease;">
                      <input type="text" id="nueva-comodidad-input" placeholder="Ej. Piscina, Barbacoa, WiFi rápido..." class="input-form" style="padding:0.4rem 0.8rem; font-size:0.85rem; flex:1; max-width:250px; border-radius:0.5rem; margin:0;" onkeypress="if(event.key==='Enter') guardarNuevaComodidad('<%= vivienda.id_vivienda %>')">
                      <button type="button" onclick="guardarNuevaComodidad('<%= vivienda.id_vivienda %>')" style="background:#0f172a; color:#fff; border:none; padding:0.45rem 1rem; border-radius:0.5rem; font-size:0.85rem; font-weight:600; cursor:pointer;" onmouseover="this.style.background='#1e293b'" onmouseout="this.style.background='#0f172a'"><i class="fas fa-save"></i> Guardar</button>
                      <button type="button" onclick="ocultarInputComodidad()" style="background:#f1f5f9; color:#64748b; border:1px solid #cbd5e1; padding:0.45rem; border-radius:0.5rem; font-size:0.85rem; cursor:pointer;" title="Cancelar"><i class="fas fa-undo"></i></button>
                    </div>

              <div class="prop-card" style="margin-bottom:0;">
                <div class="prop-section" style="padding-bottom:0.9rem;">
                  <span class="prop-sec-label"><i class="fas fa-map-marker-alt"></i>Ubicación</span>
                </div>
                <% if (vivienda.latitud && vivienda.longitud) { %>
                  <div class="map-container" id="mapa" style="height:280px;border-radius:0;margin:0;box-shadow:none;border:none;border-bottom:1px solid #F1F5F9;"></div>
                <% } else { %>
                  <div style="height:280px;display:flex;align-items:center;justify-content:center;background:#f8fafc;border-bottom:1px solid #F1F5F9;">
                    <div style="text-align:center;color:#64748b;">
                      <i class="fas fa-map-marked-alt" style="font-size:3rem;margin-bottom:1rem;opacity:0.3;display:block;"></i>
                      <p style="margin:0;font-size:0.85rem;">Coordenadas no configuradas</p>
                    </div>
                  </div>
                <% } %>
                <div class="prop-map-info">
                  <div class="prop-map-info-item">
                    <i class="fas fa-map-signs"></i>
                    <div>
                      <div class="prop-map-info-label">Barrio</div>
                      <div class="prop-map-info-val"><%= vivienda.barrio || '—' %></div>
                    </div>
                  </div>
                  <div class="prop-map-divider"></div>
                  <div class="prop-map-info-item">
                    <i class="fas fa-mail-bulk"></i>
                    <div>
                      <div class="prop-map-info-label">C.P.</div>
                      <div class="prop-map-info-val"><%= vivienda.codigo_postal || '—' %></div>
                    </div>
                  </div>
                  <div class="prop-map-divider"></div>
                  <div class="prop-map-info-item" style="position:relative;">
                    <i class="fas fa-map-pin"></i>
                    <div>
                      <div class="prop-map-info-label">Coordenadas</div>
                      <div class="prop-map-info-val" style="font-size:0.72rem;">
                        <% if(vivienda.latitud && vivienda.longitud) { %>
                          <%= parseFloat(vivienda.latitud).toFixed(5) %>, <%= parseFloat(vivienda.longitud).toFixed(5) %>
                        <% } else { %>—<% } %>
                      </div>
                    </div>
                    <button class="btn-edit-field" type="button" onclick="startEditCoordinates('<%= vivienda.id_vivienda %>', '<%= vivienda.latitud || '' %>', '<%= vivienda.longitud || '' %>')" style="position:absolute;right:0;top:50%;transform:translateY(-50%);padding:0.4rem 0.6rem;border:none;background:transparent;color:#64748b;cursor:pointer;transition:all .2s;" title="Editar coordenadas"><i class="fas fa-pen"></i></button>
                  </div>
                </div>
              </div>

              <!-- PLATAFORMAS DE ALQUILER (CTA) -->
              <div class="prop-card" style="margin-bottom:0;">
                <div class="prop-section" style="padding-bottom:0.9rem;">
                  <span class="prop-sec-label"><i class="fas fa-globe"></i>Plataformas de Alquiler</span>
                </div>
                <div style="padding:1rem 1.5rem 1.5rem;display:flex;flex-direction:column;gap:0.75rem;">
                  <a href="<%= vivienda.url_airbnb || '#' %>" <%= vivienda.url_airbnb ? 'target="_blank"' : '' %> class="prop-plat-btn airbnb">
                    <i class="fab fa-airbnb prop-plat-ico"></i>
                    <span>Ver en Airbnb</span>
                    <i class="fas fa-external-link-alt prop-plat-ext"></i>
                  </a>
                  <a href="<%= vivienda.url_booking || '#' %>" <%= vivienda.url_booking ? 'target="_blank"' : '' %> class="prop-plat-btn booking">
                    <i class="fas fa-bed prop-plat-ico"></i>
                    <span>Ver en Booking.com</span>
                    <i class="fas fa-external-link-alt prop-plat-ext"></i>
                  </a>

                </div>
              </div>

            </div><!-- /right col -->

          </div><!-- /prop-two-col -->
        </div>

        <!-- TAB 4: Documentos Legales -->
        <div class="tab-content" id="tab-documents">
          <div class="card">
            <div class="card-header-custom">
              <div class="card-header-left">
                <div class="card-icon">
                  <i class="fas fa-file-contract"></i>
                </div>
                <h3>Documentación Legal</h3>
              </div>
              <button class="btn-add" onclick="openDocumentModal()">
                <i class="fas fa-plus"></i>
                Añadir Documento
              </button>
            </div>
            <div class="documents-list">
              <!-- Documentos subidos por el propietario -->
              <% if (typeof documentos !== 'undefined' && documentos.length > 0) { %>
                <% documentos.forEach(doc => { %>
                <div class="document-item">
                  <div class="document-info">
                    <div class="document-icon">
                      <i class="fas fa-file-alt"></i>
                    </div>
                    <div>
                      <div class="document-name"><%= doc.tipo_documento %></div>
                      <div class="document-date"><%= new Date(doc.fecha_subida).toLocaleDateString('es-ES') %></div>
                    </div>
                  </div>
                  <div style="display:flex;gap:0.5rem;align-items:center;">
                    <a href="<%= doc.url_documento %>" class="btn-download" target="_blank" title="Descargar documento">
                      <i class="fas fa-download"></i>
                      Descargar
                    </a>
                    <button class="btn-download" style="background:#FEF2F2;color:#ef4444;border:1px solid #fecaca;padding:0.4rem 0.6rem;" onclick="confirmarEliminarDoc(<%= doc.id_documento %>, '<%= vivienda.id_vivienda %>')" title="Eliminar documento">
                      <i class="fas fa-trash-alt"></i>
                    </button>
                  </div>
                </div>
                <% }) %>
              <% } else { %>
              <div style="text-align:center;padding:3rem 2rem;color:#94a3b8;">
                <i class="fas fa-folder-open" style="font-size:2.5rem;margin-bottom:0.75rem;opacity:0.35;display:block;"></i>
                <p style="margin:0 0 0.25rem;font-size:0.9rem;font-weight:600;color:#64748b;">Sin documentos</p>
                <p style="margin:0;font-size:0.8rem;">Usa el botón <strong>Añadir Documento</strong> para subir archivos a esta vivienda.</p>
              </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- TAB 5: Reservas -->
        <div class="tab-content" id="tab-channels">
          <div class="card">
            <div class="card-header-custom">
              <div class="card-header-left" style="display: flex; align-items: center; gap: 0.75rem;">
                <div class="card-icon"><i class="fas fa-calendar-check"></i></div>
                <h3>Gestión de Reservas</h3>
              </div>
              <button class="btn-add" onclick="openNewReservationModal()">
                <i class="fas fa-plus"></i>
                Nueva Reserva
              </button>
            </div>

            <!-- Búsqueda -->
            <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap; align-items: center;">
              <div style="flex: 1; min-width: 220px; position: relative;">
                <i class="fas fa-hashtag" style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: #94a3b8; pointer-events: none;"></i>
                <input type="text" id="searchReservaNumero" placeholder="Buscar por nº de reserva o referencia..."
                  style="width: 100%; padding: 0.6rem 0.75rem 0.6rem 2.25rem; border: 1px solid #e2e8f0; border-radius: 0.5rem; font-size: 0.875rem; outline: none;"
                  oninput="filtrarReservas()">
              </div>
              <div style="flex: 1; min-width: 220px; position: relative;">
                <i class="fas fa-id-card" style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: #94a3b8; pointer-events: none;"></i>
                <input type="text" id="searchDNI" placeholder="Buscar por DNI del titular..."
                  style="width: 100%; padding: 0.6rem 0.75rem 0.6rem 2.25rem; border: 1px solid #e2e8f0; border-radius: 0.5rem; font-size: 0.875rem; outline: none;"
                  oninput="filtrarReservas()">
              </div>
              <select id="searchEstado" onchange="filtrarReservas()" style="padding:.6rem .75rem;border:1px solid #e2e8f0;border-radius:.5rem;font-size:.8rem;color:#1a2332;background:#fff;cursor:pointer;min-width:150px;outline:none;">
                <option value="">Todos los estados</option>
                <option value="confirmada">Confirmada</option>
                <option value="pendiente">Pendiente</option>
                <option value="cancelada">Cancelada</option>
              </select>
              <select id="searchPagado" onchange="filtrarReservas()" style="padding:.6rem .75rem;border:1px solid #e2e8f0;border-radius:.5rem;font-size:.8rem;color:#1a2332;background:#fff;cursor:pointer;min-width:150px;outline:none;">
                <option value="">Pago: todos</option>
                <option value="pagado">Pagado</option>
                <option value="pendiente">Pendiente pago</option>
              </select>
              <button id="btnToggleInactivas" onclick="toggleInactivas()" style="white-space:nowrap;padding:.6rem 1rem;border:1.5px solid #e2e8f0;background:#fff;border-radius:.5rem;font-size:.8rem;font-weight:600;color:#64748b;cursor:pointer;display:flex;align-items:center;gap:.4rem;">
                <i class="fas fa-eye-slash"></i> Ver inactivas
              </button>
            </div>

            <!-- Tabla -->
            <div style="overflow-x: auto;">
              <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
                <thead>
                  <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                    <th style="padding: 0.75rem 1rem; text-align: left; font-weight: 600; color: #64748b; white-space: nowrap;">Nº Reserva</th>
                    <th style="padding: 0.75rem 1rem; text-align: left; font-weight: 600; color: #64748b;">Huésped</th>
                    <th style="padding: 0.75rem 1rem; text-align: left; font-weight: 600; color: #64748b;">DNI</th>
                    <th style="padding: 0.75rem 1rem; text-align: left; font-weight: 600; color: #64748b; white-space: nowrap;">Entrada</th>
                    <th style="padding: 0.75rem 1rem; text-align: left; font-weight: 600; color: #64748b; white-space: nowrap;">Salida</th>
                    <th style="padding: 0.75rem 1rem; text-align: center; font-weight: 600; color: #64748b;">Pers.</th>
                    <th style="padding: 0.75rem 1rem; text-align: left; font-weight: 600; color: #64748b;">Importe</th>
                    <th style="padding: 0.75rem 1rem; text-align: left; font-weight: 600; color: #64748b;">Pago</th>
                    <th style="padding: 0.75rem 1rem; text-align: left; font-weight: 600; color: #64748b;">Estado</th>
                    <th style="padding: 0.75rem 1rem; text-align: center; font-weight: 600; color: #64748b;">Activa</th>
                    <th style="padding: 0.75rem 1rem; text-align: left; font-weight: 600; color: #64748b;">Acciones</th>
                  </tr>
                </thead>
                <tbody id="reservasTableBody">
                  <!-- Rendered by JS -->
                </tbody>
              </table>
            </div>
          </div>

          <!-- ====== Vista: Detalles de la Reserva (visible al pulsar el ojo) ====== -->
          <div id="reservaDetailView" style="display:none;">
            <!-- Header -->
            <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;">
              <button class="rd-back-btn" onclick="closeReservaDetail()">
                <i class="fas fa-arrow-left"></i> Volver a Gestión de Reservas
              </button>
              <h3 id="rdTitle" style="margin:0;font-size:1.25rem;font-weight:700;color:#1a2332;">Reserva</h3>
            </div>

            <!-- Dos columnas -->
            <div class="rd-grid">
              <!-- Section A: Datos editables -->
              <div class="card" style="margin:0;">
                <div class="card-header-custom">
                  <div class="card-header-left">
                    <div class="card-icon"><i class="fas fa-calendar-day"></i></div>
                    <h3>Datos de la Reserva</h3>
                  </div>
                </div>
                <div style="padding:1.5rem;display:flex;flex-direction:column;gap:1rem;">
                  <div class="form-row">
                    <div class="form-group">
                      <label>Fecha de entrada</label>
                      <input type="date" id="rdFechaInicio">
                    </div>
                    <div class="form-group">
                      <label>Hora de llegada</label>
                      <input type="time" id="rdHoraLlegada">
                    </div>
                  </div>
                  <div class="form-row">
                    <div class="form-group">
                      <label>Fecha de salida</label>
                      <input type="date" id="rdFechaFin">
                    </div>
                    <div class="form-group">
                      <label>Hora de salida</label>
                      <input type="time" id="rdHoraSalida">
                    </div>
                  </div>
                  <div class="form-row">
                    <div class="form-group">
                      <label>Importe total (€)
                        <!-- NOTE: Al guardar, si la reserva está Pagada el servidor
                        actualiza también la transacción vinculada y el Análisis
                        Financiero se refresca vía recargarTransacciones(). -->
                      </label>
                      <input type="number" id="rdImporte" step="0.01" min="0" placeholder="0.00">
                    </div>
                    <div class="form-group">
                      <label>Nº personas</label>
                      <input type="number" id="rdNumHuespedes" min="1" placeholder="1">
                    </div>
                  </div>
                  <div class="form-row">
                    <div class="form-group">
                      <label>Plataforma</label>
                      <select id="rdPlataforma">
                        <option value="airbnb">Airbnb</option>
                        <option value="booking">Booking.com</option>
                        <option value="bocaboca">Boca a boca</option>
                        <option value="otros">Otros</option>
                      </select>
                    </div>
                    <div class="form-group">
                      <label>Estado</label>
                      <select id="rdEstado">
                        <option value="confirmada">Confirmada</option>
                        <option value="pendiente">Pendiente</option>
                        <option value="cancelada">Cancelada</option>
                      </select>
                    </div>
                  </div>
                  <div style="display:flex;gap:1.5rem;align-items:center;flex-wrap:wrap;padding:.25rem 0;">
                    <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-weight:500;font-size:.875rem;">
                      <input type="checkbox" id="rdCheckin"> Check-in realizado
                    </label>
                    <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-weight:500;font-size:.875rem;">
                      <input type="checkbox" id="rdCheckout"> Check-out realizado
                    </label>
                    <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-weight:500;font-size:.875rem;">
                      <input type="checkbox" id="rdPagado"> Pagado
                    </label>
                  </div>
                  <button class="rd-btn-save" id="rdBtnGuardar" onclick="guardarCambiosReservaDetalle()">
                    <i class="fas fa-save"></i> Guardar cambios en la reserva
                  </button>
                </div>
              </div>

              <!-- Section B: Huéspedes -->
              <div class="card" style="margin:0;">
                <div class="card-header-custom">
                  <div class="card-header-left">
                    <div class="card-icon"><i class="fas fa-users"></i></div>
                    <h3>Huéspedes</h3>
                  </div>
                  <button class="btn-add" onclick="openHuespedModal(null)">
                    <i class="fas fa-user-plus"></i> Añadir huésped
                  </button>
                </div>
                <div style="overflow-x:auto;padding:0 1.5rem 1.5rem;">
                  <table class="rd-table">
                    <thead>
                      <tr>
                        <th>Nombre</th>
                        <th>DNI / Pasaporte</th>
                        <th>Teléfono</th>
                        <th>Email</th>
                        <th style="text-align:center;">Acciones</th>
                      </tr>
                    </thead>
                    <tbody id="rdHuespedesBody">
                      <tr><td colspan="5" style="text-align:center;padding:2rem;color:#94a3b8;">Cargando…</td></tr>
                    </tbody>
                  </table>
                </div>
              </div>
