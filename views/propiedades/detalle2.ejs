    document.addEventListener('DOMContentLoaded', () => filtrarReservas());
    document.addEventListener('DOMContentLoaded', () => recargarTareas());

  // ── Field-edit modal ──────────────────────────────────────────────
  const viviendaIdGlobal = '<%= vivienda.id_vivienda %>';
  let _editBtn = null;

  function showToast(msg, type) {
    type = type || 'success';
    let t = document.getElementById('toastNotify');
    if (!t) {
      t = document.createElement('div');
      t.id = 'toastNotify';
      t.className = 'toast-notify';
      document.body.appendChild(t);
    }
    t.textContent = msg;
    t.className = 'toast-notify ' + type;
    setTimeout(function(){ t.classList.add('show'); }, 10);
    setTimeout(function(){ t.classList.remove('show'); }, 3000);
  }

  function startEditField(btn) {
    _editBtn = btn;
    const field = btn.dataset.field;
    const value = btn.dataset.value || '';
    const label = btn.closest('.ficha-item').querySelector('.ficha-label').textContent.trim();
    document.getElementById('editFieldLabel').textContent = label;
    document.getElementById('editFieldName').value = field;
    const container = document.getElementById('editFieldInputContainer');
    
    // Campos con opciones predefinidas
    const selectFields = {
      'tipo_vivienda': ['Apartamento', 'Chalet', 'Adosado', 'Pareado', 'Loft', 'Estudio', 'Ático', 'Duplex', 'Casa', 'Villa', 'Bungalow'],
      'categoria': ['Apartamento turístico', 'Vivienda turística', 'Vivienda de uso turístico', 'Casa Rural'],
      'estado_legal': ['Activa', 'En trámite', 'No aplica'],
      'activa': ['Activa', 'Inactiva']
    };
    
    // Para campos con select
    if (selectFields[field]) {
      const options = selectFields[field];
      let selectHtml = '<select id="editFieldInput" style="width:100%;border:1.5px solid #e2e8f0;border-radius:.4rem;padding:.5rem .75rem;font-size:0.875rem;color:#1a2332;outline:none;transition:border .2s;"><option value="">-- Seleccionar --</option>';
      
      options.forEach(opt => {
        selectHtml += '<option value="' + opt + '" ' + (value === opt ? 'selected' : '') + '>' + opt + '</option>';
      });
      selectHtml += '</select>';
      
      container.innerHTML = selectHtml;
      document.getElementById('editFieldInput').value = value;
    } else if (field === 'activa') {
      // Para el campo activa con valores booleanos
      container.innerHTML = '<select id="editFieldInput" style="width:100%;border:1.5px solid #e2e8f0;border-radius:.4rem;padding:.5rem .75rem;font-size:0.875rem;color:#1a2332;outline:none;transition:border .2s;"><option value="1">Activa</option><option value="0">Inactiva</option></select>';
      document.getElementById('editFieldInput').value = value;
    } else {
      // TextArea para otros campos
      container.innerHTML = '<textarea id="editFieldInput" rows="1" style="width:100%;border:1.5px solid #e2e8f0;border-radius:.4rem;padding:.5rem .75rem;font-size:0.875rem;color:#1a2332;outline:none;resize:vertical;transition:border .2s;font-family:inherit;" onfocus="this.style.borderColor=\'#1a2332\'" onblur="this.style.borderColor=\'#e2e8f0\'"></textarea>';
      const newTextarea = document.getElementById('editFieldInput');
      newTextarea.rows = (field.indexOf('url') === 0) ? 3 : 1;
      newTextarea.value = value;
    }
    
    const modal = new bootstrap.Modal(document.getElementById('modalEditField'));
    modal.show();
    setTimeout(function(){ 
      const input = document.getElementById('editFieldInput');
      if (input) input.focus(); 
    }, 300);
  }

  function startEditCoordinates(viviendaId, lat, lng) {
    console.log('Abriendo editor de coordenadas para vivienda:', viviendaId);
    console.log('Coordenadas actuales - Latitud:', lat, 'Longitud:', lng);
    
    const editCoordLat = document.getElementById('editCoordLat');
    const editCoordLng = document.getElementById('editCoordLng');
    
    if (!editCoordLat || !editCoordLng) {
      console.error('No se encontraron los campos de entrada de coordenadas');
      showToast('Error: No se puede abrir el editor de coordenadas', 'error');
      return;
    }
    
    // Establecer valores, convirtiendo cadenas vacías a vacío
    editCoordLat.value = lat && lat.trim() ? parseFloat(lat) : '';
    editCoordLng.value = lng && lng.trim() ? parseFloat(lng) : '';
    
    const modalElement = document.getElementById('modalEditCoordinates');
    if (!modalElement) {
      console.error('No se encontró el modal modalEditCoordinates');
      showToast('Error: No se puede abrir el modal', 'error');
      return;
    }
    
    try {
      const modal = new bootstrap.Modal(modalElement);
      modal.show();
      console.log('Modal de coordenadas mostrado');
      
      setTimeout(function() { 
        editCoordLat.focus();
      }, 300);
    } catch (e) {
      console.error('Error mostrando modal:', e);
      showToast('Error al abrir el editor de coordenadas', 'error');
    }
  }

  function startEditAmenities(viviendaId) {
    console.log('Abriendo editor de comodidades para vivienda:', viviendaId);
    
    // Leer comodidades actuales del elemento amenities-display
    const amenitiesDisplay = document.getElementById('amenities-display');
    let currentAmenities = [];
    
    if (amenitiesDisplay) {
      const amenityTags = amenitiesDisplay.querySelectorAll('.amenity-tag span');
      amenityTags.forEach(tag => {
        const text = tag.textContent.trim();
        if (text) {
          currentAmenities.push(text);
        }
      });
    }
    
    console.log('Comodidades actuales:', currentAmenities);
    
    const amenitiesContainer = document.getElementById('amenitiesEditList');
    if (!amenitiesContainer) {
      console.error('No se encontró el contenedor de comodidades');
      showToast('Error: No se puede abrir el editor de comodidades', 'error');
      return;
    }
    
    amenitiesContainer.innerHTML = '';
    
    // Lista de comodidades predefinidas
    const predefinedAmenities = [
      'WiFi',
      'Aire acondicionado',
      'Calefacción',
      'Cocina',
      'Parking',
      'Piscina',
      'Jardín',
      'Terraza',
      'Ascensor',
      'Calentador de agua',
      'Máquina de lavadora',
      'Lavarropa',
      'Electrodomésticos',
      'Jacuzzi',
      'Lavadora',
      'Nevera'
    ];
    
    // Crear mapa de todas las comodidades
    const allAmenities = {};
    
    // Añadir predefinidas
    predefinedAmenities.forEach(name => {
      allAmenities[name] = true;
    });
    
    // Añadir personalizadas
    currentAmenities.forEach(name => {
      allAmenities[name] = true;
    });
    
    // Mostrar checkboxes
    Object.keys(allAmenities).sort().forEach(amenityName => {
      const isChecked = currentAmenities.includes(amenityName);
      const label = document.createElement('label');
      label.style.cssText = 'display:flex;align-items:center;padding:0.6rem;cursor:pointer;border-radius:.4rem;margin-bottom:0.4rem;transition:background .2s;';
      
      const checkbox = document.createElement('input');
      checkbox.type = 'checkbox';
      checkbox.className = 'amenity-checkbox';
      checkbox.value = amenityName;
      checkbox.checked = isChecked;
      checkbox.style.cssText = 'width:18px;height:18px;cursor:pointer;';
      
      const icon = document.createElement('i');
      icon.className = 'fas fa-check-circle';
      icon.style.cssText = 'margin:0 0.5rem;color:#64748b;width:20px;text-align:center;';
      
      const span = document.createElement('span');
      span.textContent = amenityName;
      span.style.flex = '1';
      
      label.appendChild(checkbox);
      label.appendChild(icon);
      label.appendChild(span);
      
      label.addEventListener('mouseenter', function() { 
        this.style.background = '#f1f5f9'; 
      });
      label.addEventListener('mouseleave', function() { 
        this.style.background = 'transparent'; 
      });
      
      amenitiesContainer.appendChild(label);
    });
    
    // Limpiar campo de entrada
    const newAmenityInput = document.getElementById('newAmenityInput');
    if (newAmenityInput) {
      newAmenityInput.value = '';
    }
    
    // Mostrar modal
    const modalElement = document.getElementById('modalEditAmenities');
    if (modalElement) {
      const modal = new bootstrap.Modal(modalElement);
      modal.show();
      console.log('Modal mostrado');
    } else {
      console.error('No se encontró el modal modalEditAmenities');
      showToast('Error: No se puede abrir el modal', 'error');
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('btnSaveField').addEventListener('click', function() {
      const field = document.getElementById('editFieldName').value;
      let newValue = document.getElementById('editFieldInput').value;
      if (typeof newValue === 'string') newValue = newValue.trim();
      
      // Validación de campos numéricos
      const noNegativeFields = ['superficie', 'superficie_parcela', 'num_habitaciones', 'num_banos', 'capacidad_maxima', 'ano_construccion', 'planta', 'precio_compra', 'escalera', 'piso', 'codigo_postal'];
      const noDecimalFields = ['num_habitaciones', 'num_banos', 'capacidad_maxima', 'planta', 'escalera', 'piso', 'codigo_postal'];
      
      // Validar campos numéricos
      if (noNegativeFields.includes(field) && newValue !== '') {
        // Verificar que no contiene signo negativo
        if (newValue.includes('-')) {
          showToast('No se permiten valores negativos en este campo', 'error');
          return;
        }
        
        const numValue = parseFloat(newValue);
        
        if (isNaN(numValue)) {
          showToast('El valor debe ser un número válido', 'error');
          return;
        }
        
        if (numValue < 0) {
          showToast('No se permiten valores negativos en este campo', 'error');
          return;
        }
        
        if (noDecimalFields.includes(field) && !Number.isInteger(numValue)) {
          showToast('Este campo no acepta decimales', 'error');
          return;
        }
      }
      
      const saveBtn = document.getElementById('btnSaveField');
      saveBtn.disabled = true;
      saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando\u2026';

      fetch('/propiedades/' + viviendaIdGlobal + '/campo', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ field: field, value: newValue })
      })
      .then(function(r){ return r.json(); })
      .then(function(d) {
        saveBtn.disabled = false;
        saveBtn.innerHTML = '<i class="fas fa-check me-1"></i>Guardar';
        if (d.success) {
          if (_editBtn) {
            const item = _editBtn.closest('.ficha-item');
            const valueEl = item.querySelector('.ficha-value');
            if (field === 'superficie' || field === 'superficie_parcela') {
              valueEl.textContent = newValue ? newValue + ' m\u00b2' : '\u2014';
            } else if (field === 'capacidad_maxima') {
              valueEl.textContent = newValue ? newValue + ' personas' : '\u2014';
            } else if (field === 'activa') {
              valueEl.textContent = newValue === '1' || newValue === true ? 'Activa' : 'Inactiva';
              const parent = item.parentElement;
              if (parent) {
                parent.classList.remove('i-activa', 'i-inactiva');
                parent.classList.add(newValue === '1' || newValue === true ? 'i-activa' : 'i-inactiva');
              }
            } else if (field.indexOf('url') === 0) {
              valueEl.textContent = newValue ? 'Ver enlace' : '\u2014';
              valueEl.title = newValue;
            } else {
              valueEl.textContent = newValue || '\u2014';
            }
            _editBtn.dataset.value = newValue;
          }
          bootstrap.Modal.getInstance(document.getElementById('modalEditField')).hide();
          showToast('Campo guardado correctamente', 'success');
        } else {
          showToast(d.error || 'Error al guardar', 'error');
        }
      })
      .catch(function() {
        saveBtn.disabled = false;
        saveBtn.innerHTML = '<i class="fas fa-check me-1"></i>Guardar';
        showToast('Error de conexi\u00f3n', 'error');
      });
    });
    
    // Guardar coordenadas
    const btnSaveCoordinates = document.getElementById('btnSaveCoordinates');
    if (btnSaveCoordinates) {
      btnSaveCoordinates.addEventListener('click', function() {
        const lat = document.getElementById('editCoordLat').value.trim();
        const lng = document.getElementById('editCoordLng').value.trim();
        
        if (!lat || !lng) {
          showToast('Por favor ingresa ambas coordenadas', 'error');
          return;
        }
        
        const latNum = parseFloat(lat);
        const lngNum = parseFloat(lng);
        
        if (isNaN(latNum) || isNaN(lngNum)) {
          showToast('Las coordenadas deben ser números válidos', 'error');
          return;
        }
        
        // Validar rangos de coordenadas
        if (latNum < -90 || latNum > 90) {
          showToast('La latitud debe estar entre -90 y 90', 'error');
          return;
        }
        
        if (lngNum < -180 || lngNum > 180) {
          showToast('La longitud debe estar entre -180 y 180', 'error');
          return;
        }
        
        this.disabled = true;
        this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando\u2026';
        
        fetch('/propiedades/' + viviendaIdGlobal + '/coordinates', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ latitud: latNum, longitud: lngNum })
        })
        .then(r => r.json())
        .then(d => {
          this.disabled = false;
          this.innerHTML = '<i class="fas fa-check me-1"></i>Guardar';
          if (d.success) {
            // Actualizar el display de coordenadas en la página
            const coordDisplay = document.querySelector('.prop-map-info-val');
            if (coordDisplay) {
              coordDisplay.textContent = latNum.toFixed(5) + ', ' + lngNum.toFixed(5);
            }
            
            bootstrap.Modal.getInstance(document.getElementById('modalEditCoordinates')).hide();
            showToast('Coordenadas guardadas correctamente', 'success');
            
            // Recargar página para actualizar mapa si existe
            setTimeout(() => {
              if (document.getElementById('map')) {
                location.reload();
              }
            }, 1000);
          } else {
            showToast(d.error || 'Error al guardar', 'error');
          }
        })
        .catch(err => {
          this.disabled = false;
          this.innerHTML = '<i class="fas fa-check me-1"></i>Guardar';
          console.error('Error:', err);
          showToast('Error de conexión', 'error');
        });
      });
    }
    
    // Guardar comodidades
    const btnSaveAmenities = document.getElementById('btnSaveAmenities');
    if (btnSaveAmenities) {
      btnSaveAmenities.addEventListener('click', function() {
        const checkboxes = document.querySelectorAll('.amenity-checkbox:checked');
        const selectedAmenities = Array.from(checkboxes).map(cb => cb.value);
        this.disabled = true;
        this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando\u2026';
        
        fetch('/propiedades/' + viviendaIdGlobal + '/amenities', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ amenities: selectedAmenities })
        })
        .then(r => r.json())
        .then(d => {
          this.disabled = false;
          this.innerHTML = '<i class="fas fa-check me-1"></i>Guardar';
          if (d.success) {
            // Actualizar display
            const amenitiesDisplay = document.getElementById('amenities-display');
            amenitiesDisplay.innerHTML = selectedAmenities.length > 0 
              ? selectedAmenities.map(a => '<div class="amenity-tag"><i class="fas fa-check-circle"></i><span>' + a + '</span></div>').join('')
              : '<p style="color:#94a3b8;font-size:0.8rem;margin:0;">No hay comodidades especificadas</p>';
            bootstrap.Modal.getInstance(document.getElementById('modalEditAmenities')).hide();
            showToast('Comodidades guardadas correctamente', 'success');
          } else {
            showToast(d.error || 'Error al guardar', 'error');
          }
        })
        .catch(err => {
          this.disabled = false;
          this.innerHTML = '<i class="fas fa-check me-1"></i>Guardar';
          showToast('Error de conexi\u00f3n', 'error');
        });
      });
    }
    
    // Evento para añadir nueva comodidad
    const btnAddAmenity = document.getElementById('btnAddAmenity');
    if (btnAddAmenity) {
      btnAddAmenity.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        console.log('Botón de añadir comodidad presionado');
        
        const newAmenityInput = document.getElementById('newAmenityInput');
        if (!newAmenityInput) {
          console.error('No se encontró el campo de entrada');
          return;
        }
        
        const newAmenity = newAmenityInput.value.trim();
        
        if (!newAmenity) {
          showToast('Por favor ingresa un nombre de comodidad', 'error');
          return;
        }
        
        // Verificar que no exista ya
        const existingCheckboxes = document.querySelectorAll('input.amenity-checkbox');
        let alreadyExists = false;
        
        existingCheckboxes.forEach(checkbox => {
          if (checkbox.value === newAmenity) {
            alreadyExists = true;
          }
        });
        
        if (alreadyExists) {
          showToast('Esta comodidad ya está en la lista', 'error');
          newAmenityInput.value = '';
          return;
        }
        
        // Crear el nuevo elemento
        const label = document.createElement('label');
        label.style.cssText = 'display:flex;align-items:center;padding:0.6rem;cursor:pointer;border-radius:.4rem;margin-bottom:0.4rem;transition:background .2s;';
        
        const checkbox = document.createElement('input');
        checkbox.type = 'checkbox';
        checkbox.className = 'amenity-checkbox';
        checkbox.value = newAmenity;
        checkbox.checked = true;
        checkbox.style.cssText = 'width:18px;height:18px;cursor:pointer;';
        
        const icon = document.createElement('i');
        icon.className = 'fas fa-check-circle';
        icon.style.cssText = 'margin:0 0.5rem;color:#64748b;width:20px;text-align:center;';
        
        const span = document.createElement('span');
        span.textContent = newAmenity;
        span.style.flex = '1';
        
        label.appendChild(checkbox);
        label.appendChild(icon);
        label.appendChild(span);
        
        label.addEventListener('mouseenter', function() {
          this.style.background = '#f1f5f9';
        });
        label.addEventListener('mouseleave', function() {
          this.style.background = 'transparent';
        });
        
        const amenitiesContainer = document.getElementById('amenitiesEditList');
        if (amenitiesContainer) {
          amenitiesContainer.appendChild(label);
        }
        
        newAmenityInput.value = '';
        newAmenityInput.focus();
        showToast('Comodidad añadida', 'success');
      });
    }
  });

  </script>
    
