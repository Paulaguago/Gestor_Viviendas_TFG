                    <button class="btn-edit-field" data-field="num_habitaciones" data-value="<%= vivienda.num_habitaciones != null ? vivienda.num_habitaciones : '' %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
                  </div>
                  <div class="ficha-item">
                    <div class="c-stat-icon" style="background:#E0E7FF;color:#4338CA;"><i class="fas fa-bath"></i></div>
