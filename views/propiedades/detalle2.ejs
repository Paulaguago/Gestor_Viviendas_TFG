              ['Apellidos', h.apellidos || '—'],
              ['Sexo', sexoMap[h.sexo] || '—'],
              ['Fecha de nacimiento', fmt(h.fecha_nacimiento)],
              ['Nacionalidad', h.nacionalidad || '—'],
              ['Tipo de documento', h.tipo_documento || '—'],
              ['Número de documento', h.dni || '—'],
              ['Fecha de expedición', fmt(h.fecha_expedicion_documento)],
              ['Dirección habitual', h.direccion || '—'],
              ['Localidad', h.localidad || '—'],
              ['País', h.pais || '—'],
              ['Teléfono móvil', h.telefono || '—'],
              ['Correo electrónico', h.email || '—'],
              ['Parentesco con responsable', h.parentesco || (i === 0 ? 'Titular' : '—')]
            ]);
          }).join('');

          document.getElementById('parteViajerosContent').innerHTML = `
            <div style="font-family:'Inter',sans-serif;color:#1a2332;">
              <h2 style="text-align:center;font-size:1.1rem;font-weight:700;border-bottom:2px solid #1a2332;padding-bottom:.75rem;margin-bottom:1.5rem;">PARTE DE ENTRADA DE VIAJEROS</h2>
