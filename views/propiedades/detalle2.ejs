    function renderTareas(tareas) {
      const container = document.getElementById('tareasContainer');
      if (!container) return;
      if (!tareas || tareas.length === 0) {
        container.innerHTML = '<div style="text-align:center;padding:2rem;color:#64748b;">'
          + '<i class="fas fa-clipboard-list" style="font-size:3rem;margin-bottom:1rem;opacity:0.3;"></i>'
          + '<p style="margin:0;font-weight:500;">No hay tareas pendientes</p>'
          + '<small>Las tareas aparecerán aquí</small></div>';
        return;
      }
      var estadoColor = { 'Pendiente': '#f59e0b', 'En progreso': '#3b82f6', 'Completada': '#10b981' };
      var estadoBg    = { 'Pendiente': '#fef3c7', 'En progreso': '#dbeafe', 'Completada': '#d1fae5' };
      var html = '<div style="display:flex;flex-direction:column;gap:0.5rem;padding:0.5rem;">';
      tareas.forEach(function(t) {
        var color   = estadoColor[t.estado] || '#64748b';
        var bg      = estadoBg[t.estado]    || '#f1f5f9';
        var fechaStr = '';
        var vencida  = false;
        if (t.fecha_limite) {
          var fl = new Date(t.fecha_limite + 'T00:00:00');
          fechaStr = fl.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
          var hoyT = new Date(); hoyT.setHours(0,0,0,0);
          vencida = fl < hoyT && t.estado !== 'Completada';
        }
        var cal = t.vinculada_calendario ? '<i class="fas fa-calendar-check" title="Vinculada al calendario" style="color:#6366f1;margin-left:5px;font-size:0.72rem;"></i>' : '';
        
        var isCompleted = t.estado === 'Completada';
        var checkIcon = isCompleted ? 'fa-check-circle' : 'fa-circle';
        var checkColor = isCompleted ? '#10b981' : '#cbd5e1';
        var nextState = isCompleted ? 'Pendiente' : 'Completada';
        var displayStatus = vencida ? 'Vencida' : t.estado;
        var displayColor = vencida ? '#ef4444' : color;
        var displayBg = vencida ? '#fee2e2' : bg;

        html += '<div style="display:flex;align-items:center;gap:0.75rem;padding:0.65rem 0.75rem;background:#f8fafc;border-radius:0.5rem;border:1px solid #e2e8f0;opacity:' + (isCompleted ? '0.6' : '1') + ';">'
          + '<button onclick="toggleTaskStatus(' + t.id_tarea + ', \'' + nextState + '\')" title="Marcar como ' + nextState.toLowerCase() + '" style="background:none;border:none;padding:0;cursor:pointer;color:' + checkColor + ';font-size:1.3rem;display:flex;align-items:center;justify-content:center;transition:color 0.2s;"><i class="' + (isCompleted ? 'fas' : 'far') + ' ' + checkIcon + '"></i></button>'
          + '<div style="flex:1;min-width:0;text-decoration:' + (isCompleted ? 'line-through' : 'none') + ';">'
          + '<div style="font-size:0.85rem;font-weight:600;color:#1a2332;">' + escapeHtml(t.descripcion) + cal + '</div>'
          + (fechaStr ? '<div style="font-size:0.75rem;color:' + (vencida ? '#ef4444' : '#64748b') + ';margin-top:2px;"><i class="fas fa-clock" style="margin-right:3px;"></i>' + fechaStr + (vencida ? '&nbsp;⚠ Vencida' : '') + '</div>' : '')
          + '</div>'
          + '<span style="font-size:0.7rem;font-weight:700;padding:2px 10px;border-radius:20px;white-space:nowrap;color:' + displayColor + ';background:' + displayBg + ';border:1px solid ' + displayColor + '40;">' + escapeHtml(displayStatus) + '</span>'
          + '<button onclick="deleteTask(' + t.id_tarea + ')" title="Eliminar tarea" style="width:28px;height:28px;border:none;background:#fee2e2;color:#dc2626;border-radius:50%;cursor:pointer;font-size:0.72rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">'
          + '<i class="fas fa-trash"></i></button>'
          + '</div>';
      });
      html += '</div>';
      container.innerHTML = html;
    }

