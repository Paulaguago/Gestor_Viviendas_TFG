                  <div class="stat-label" id="labelGastosTotal" style="font-size:.72rem;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.04em;margin-bottom:.35rem;">Gastos Totales</div>
                  <div class="stat-value" style="color:#991b1b;font-size:1.35rem;font-weight:800;line-height:1;" id="statGastosTotal">0€</div>
                </div>
                <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:.75rem;padding:1rem 1.25rem;">
                  <div class="stat-label" id="labelIngresosEsperados" style="font-size:.72rem;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.04em;margin-bottom:.35rem;">Ingresos Pendientes</div>
                  <div class="stat-value" style="color:#1d4ed8;font-size:1.35rem;font-weight:800;line-height:1;" id="statIngresosEsperados">0€</div>
                </div>
                <div style="background:#f5f3ff;border:1px solid #ddd6fe;border-radius:.75rem;padding:1rem 1.25rem;">
                  <div class="stat-label" id="labelReservasMes" style="font-size:.72rem;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.04em;margin-bottom:.35rem;">Reservas</div>
                  <div class="stat-value" style="color:#7c3aed;font-size:1.35rem;font-weight:800;line-height:1;" id="statReservasMes">0</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Últimos Ingresos + Últimos Gastos -->
