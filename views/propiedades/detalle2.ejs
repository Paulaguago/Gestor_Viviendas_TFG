    function closeParte() { document.getElementById('parteViajerosModal').style.display = 'none'; }
    function imprimirParte() {
      const content = document.getElementById('parteViajerosContent').innerHTML;
      const win = window.open('', '_blank', 'width=900,height=700');
      win.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Parte de Viajeros</title>
