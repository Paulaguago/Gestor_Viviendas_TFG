                  <div class="ficha-item">
                    <span class="ficha-label">Escalera</span>
                    <span class="ficha-value"><%= vivienda.escalera || '—' %></span>
                    <button class="btn-edit-field" data-field="escalera" data-value="<%= vivienda.escalera || '' %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
                  </div>
                  <div class="ficha-item">
                    <span class="ficha-label">Piso</span>
                    <span class="ficha-value"><%= vivienda.piso || '—' %></span>
                    <button class="btn-edit-field" data-field="piso" data-value="<%= vivienda.piso || '' %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
