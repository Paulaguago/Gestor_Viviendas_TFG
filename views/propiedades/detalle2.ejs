              <div class="card-header-custom">
                <div class="card-header-left">
                  <div class="card-icon" style="background: #d1fae5;"><i class="fas fa-arrow-down" style="color: #065f46;"></i></div>
                  <h3 id="tituloTablaIngresos">Últimos Ingresos</h3>
