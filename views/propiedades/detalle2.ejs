    // ── Transacciones (global) ────────────────────────────────────────────────────────────────────────
    window._transacciones = <%- JSON.stringify(typeof ultimasTransacciones !== 'undefined' ? ultimasTransacciones : []) %>;
    window._tareas = [];

    // ── Navegación mensual ────────────────────────────────────────────────────────────────────────────
    window._viewYear = null;
    window._viewMonth = null; // 0-11, null = todo el historial

    function navMonth(dir) {
      if (window._viewYear === null) {
        var now = new Date();
        window._viewYear = now.getFullYear();
        window._viewMonth = now.getMonth();
      } else {
        window._viewMonth += dir;
        if (window._viewMonth > 11) { window._viewMonth = 0; window._viewYear++; }
        if (window._viewMonth < 0)  { window._viewMonth = 11; window._viewYear--; }
      }
      _updateMonthNavUI();
      updateFinancialSummary();
      renderTransacciones();
    }

    function resetMonthView() {
      window._viewYear = null;
      window._viewMonth = null;
      _updateMonthNavUI();
      updateFinancialSummary();
      renderTransacciones();
    }

    function _updateMonthNavUI() {
      var lbl = document.getElementById('monthNavLabel');
      var btn = document.getElementById('btnResetMonth');
      var lI  = document.getElementById('labelIngresosTotal');
      var lG  = document.getElementById('labelGastosTotal');
      var lP  = document.getElementById('labelIngresosEsperados');
      var lR  = document.getElementById('labelReservasMes');
      var tI  = document.getElementById('tituloTablaIngresos');
      var tG  = document.getElementById('tituloTablaGastos');
      if (window._viewYear === null) {
        if (lbl) lbl.textContent = 'Todo el historial';
        if (btn) btn.style.display = 'none';
        if (lI) lI.textContent = 'Ingresos Totales';
        if (lG) lG.textContent = 'Gastos Totales';
        if (lP) lP.textContent = 'Ingresos Pendientes';
        if (lR) lR.textContent = 'Reservas (año)';
        if (tI) tI.textContent = 'Últimos Ingresos';
        if (tG) tG.textContent = 'Últimos Gastos';
      } else {
        var d = new Date(window._viewYear, window._viewMonth, 1);
        var mesStr = d.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });
        var mesCorto = d.toLocaleDateString('es-ES', { month: 'long' });
        if (lbl) lbl.textContent = mesStr.charAt(0).toUpperCase() + mesStr.slice(1);
        if (btn) btn.style.display = '';
        if (lI) lI.textContent = 'Ingresos ' + mesCorto.charAt(0).toUpperCase() + mesCorto.slice(1);
        if (lG) lG.textContent = 'Gastos ' + mesCorto.charAt(0).toUpperCase() + mesCorto.slice(1);
        if (lP) lP.textContent = 'Pendientes ' + mesCorto.charAt(0).toUpperCase() + mesCorto.slice(1);
        if (lR) lR.textContent = 'Reservas ' + mesCorto.charAt(0).toUpperCase() + mesCorto.slice(1);
        if (tI) tI.textContent = 'Ingresos — ' + mesStr.charAt(0).toUpperCase() + mesStr.slice(1);
        if (tG) tG.textContent = 'Gastos — ' + mesStr.charAt(0).toUpperCase() + mesStr.slice(1);
      }
    }

    function _filterTransByMonth(trans) {
      if (window._viewYear === null) return trans;
      return trans.filter(function(t) {
        var d = new Date(t.fecha);
        return d.getFullYear() === window._viewYear && d.getMonth() === window._viewMonth;
      });
    }

    function _getDailyData(trans, year, month) {
      var daysInMonth = new Date(year, month + 1, 0).getDate();
      var labels = [], ingr = [], gast = [];
      for (var day = 1; day <= daysInMonth; day++) {
        labels.push(day + '');
        ingr.push(0); gast.push(0);
      }
      trans.forEach(function(t) {
        var d = new Date(t.fecha);
        if (d.getFullYear() === year && d.getMonth() === month) {
          var idx = d.getDate() - 1;
          if (t.tipo === 'ingreso') ingr[idx] += parseFloat(t.importe || 0);
          else gast[idx] += parseFloat(t.importe || 0);
        }
      });
      return { labels: labels, ingresos: ingr, gastos: gast };
    }

    function _getMonthlyData(trans) {
      var now = new Date();
      var labels = [], mkeys = [];
      for (var i = 11; i >= 0; i--) {
        var d = new Date(now.getFullYear(), now.getMonth() - i, 1);
        labels.push(d.toLocaleDateString('es-ES', { month: 'short', year: '2-digit' }));
        mkeys.push(d.getFullYear() + '-' + d.getMonth());
      }
      var byKey = {};
      trans.forEach(function(t) {
        var d2 = new Date(t.fecha);
        var k = d2.getFullYear() + '-' + d2.getMonth();
        if (!byKey[k]) byKey[k] = { ingreso: 0, gasto: 0 };
        byKey[k][t.tipo] = (byKey[k][t.tipo] || 0) + parseFloat(t.importe || 0);
      });
      return {
        labels: labels,
        ingresos: mkeys.map(function(k){ return byKey[k] ? byKey[k].ingreso : 0; }),
        gastos:   mkeys.map(function(k){ return byKey[k] ? byKey[k].gasto   : 0; })
      };
    }

    function _buildChart() {
      var ctx = document.getElementById('financialChart');
      if (!ctx) return;
      if (window._chartInstance) { window._chartInstance.destroy(); window._chartInstance = null; }

      var isMonthView = window._viewYear !== null;
      var md, chartType;
      if (isMonthView) {
        md = _getDailyData(window._transacciones, window._viewYear, window._viewMonth);
        chartType = 'bar';
      } else {
        md = _getMonthlyData(window._transacciones);
        chartType = 'line';
      }

      var commonTooltip = { mode: 'index', intersect: false, backgroundColor: 'rgba(26,35,50,0.95)', padding: 12,
        callbacks: { label: function(c){ return c.dataset.label + ': €' + parseFloat(c.parsed.y).toLocaleString('es-ES', {minimumFractionDigits:2,maximumFractionDigits:2}); } } };

      window._chartInstance = new Chart(ctx, {
        type: chartType,
        data: {
          labels: md.labels,
          datasets: isMonthView
            ? [
                { label: 'Ingresos', data: md.ingresos, backgroundColor: 'rgba(6,95,70,0.75)', borderColor: '#065f46', borderWidth: 1.5, borderRadius: 4 },
                { label: 'Gastos',   data: md.gastos,   backgroundColor: 'rgba(153,27,27,0.75)', borderColor: '#991b1b', borderWidth: 1.5, borderRadius: 4 }
              ]
            : [
                { label: 'Ingresos', data: md.ingresos, borderColor: '#065f46', backgroundColor: 'rgba(6,95,70,0.08)', borderWidth: 2.5, fill: true, tension: 0.4, pointBackgroundColor: '#065f46', pointRadius: 4 },
                { label: 'Gastos',   data: md.gastos,   borderColor: '#991b1b', backgroundColor: 'rgba(153,27,27,0.08)', borderWidth: 2.5, fill: true, tension: 0.4, pointBackgroundColor: '#991b1b', pointRadius: 4 }
              ]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: {
            legend: { display: true, position: 'top', labels: { usePointStyle: true, padding: 15, font: { size: 12, weight: '600' } } },
            tooltip: commonTooltip
          },
          scales: {
            y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { callback: function(v){ return '€' + v.toLocaleString('es-ES'); } } },
            x: { grid: { display: false }, ticks: isMonthView ? { maxTicksLimit: 10 } : {} }
          }
        }
      });
    }

    function renderTransacciones() {
      var fmt = function(d) { return d ? new Date(d).toLocaleDateString('es-ES', {day:'2-digit',month:'short',year:'numeric'}) : '—'; };
      var emptyHtml = function(msg) { return '<div style="text-align:center;padding:2.5rem;color:#94a3b8;"><i class="fas fa-receipt" style="font-size:2.5rem;margin-bottom:0.75rem;opacity:0.3;display:block;"></i><p style="margin:0;font-size:0.85rem;">' + msg + '</p></div>'; };
      function makeTable(rows, color, sign, tipo) {
        if (!rows.length) return emptyHtml(tipo === 'ingreso' ? 'No hay ingresos registrados' : 'No hay gastos registrados');
        return '<table style="width:100%;border-collapse:collapse;font-size:0.82rem;">'
          + '<thead><tr style="background:#f8fafc;border-bottom:1px solid #e2e8f0;">'
          + '<th style="padding:.5rem .75rem;text-align:left;color:#64748b;font-weight:600;">Fecha</th>'
          + '<th style="padding:.5rem .75rem;text-align:left;color:#64748b;font-weight:600;">Descripción</th>'
          + '<th style="padding:.5rem .75rem;text-align:right;color:#64748b;font-weight:600;">Importe</th>'
          + '<th style="padding:.5rem .75rem;width:2rem;"></th>'
          + '</tr></thead><tbody>'
          + rows.map(function(t) {
            return '<tr style="border-bottom:1px solid #f1f5f9;" onmouseover="this.style.background=\'#f8fafc\'" onmouseout="this.style.background=\'\'">'
              + '<td style="padding:.5rem .75rem;color:#64748b;white-space:nowrap;">' + fmt(t.fecha) + '</td>'
              + '<td style="padding:.5rem .75rem;color:#1a2332;">' + (t.descripcion || '—') + '</td>'
              + '<td style="padding:.5rem .75rem;text-align:right;font-weight:700;color:' + color + ';">' + sign + parseFloat(t.importe).toFixed(2) + ' €</td>'
              + '<td style="padding:.5rem .75rem;text-align:center;"><button onclick="deleteTransaccion(' + t.id_transaccion + ',\'' + tipo + '\')" title="Eliminar" style="border:none;background:none;color:#cbd5e1;cursor:pointer;font-size:.8rem;padding:.2rem .4rem;border-radius:.25rem;" onmouseover="this.style.color=\'#991b1b\'" onmouseout="this.style.color=\'#cbd5e1\'"><i class="fas fa-trash"></i></button></td>'
              + '</tr>';
          }).join('')
          + '</tbody></table>';
      }
      var ti = document.getElementById('tablaIngresos');
      var tg = document.getElementById('tablaGastos');
      var transFiltradas = _filterTransByMonth(window._transacciones);
      if (ti) ti.innerHTML = makeTable(transFiltradas.filter(function(t){ return t.tipo==='ingreso'; }), '#065f46', '+', 'ingreso');
      if (tg) tg.innerHTML = makeTable(transFiltradas.filter(function(t){ return t.tipo==='gasto'; }), '#991b1b', '-', 'gasto');
    }

    function updateFinancialSummary() {
      var transFiltradas = _filterTransByMonth(window._transacciones);
      var ingresoTotal = transFiltradas.filter(function(t){ return t.tipo==='ingreso'; }).reduce(function(s,t){ return s+parseFloat(t.importe||0); }, 0);
      var gastoTotal   = transFiltradas.filter(function(t){ return t.tipo==='gasto';   }).reduce(function(s,t){ return s+parseFloat(t.importe||0); }, 0);
      var si = document.getElementById('statIngresosTotal'); if (si) si.textContent = ingresoTotal.toFixed(2) + '€';
      var sg = document.getElementById('statGastosTotal');   if (sg) sg.textContent = gastoTotal.toFixed(2) + '€';
      // KPI anuales (enero—diciembre año actual) — independientes del navegador de mes
      var anioActual = new Date().getFullYear();
      var ingresosAnuales = window._transacciones
        .filter(function(t) { var d = new Date(t.fecha); return t.tipo === 'ingreso' && d.getFullYear() === anioActual; })
        .reduce(function(s,t){ return s + parseFloat(t.importe||0); }, 0);
      var gastosAnuales = window._transacciones
        .filter(function(t) { var d = new Date(t.fecha); return t.tipo === 'gasto' && d.getFullYear() === anioActual; })
        .reduce(function(s,t){ return s + parseFloat(t.importe||0); }, 0);
      var kia = document.getElementById('kpiIngresosAnuales'); if (kia) kia.textContent = ingresosAnuales.toFixed(2) + '€';
      var kga = document.getElementById('kpiGastosAnuales');   if (kga) kga.textContent = gastosAnuales.toFixed(2) + '€';
      // Balance anual = ingresos - gastos del año
      var balanceAnualDin = ingresosAnuales - gastosAnuales;
      var kba = document.getElementById('kpiBalanceAnual');
      if (kba) {
        kba.textContent = (balanceAnualDin >= 0 ? '+' : '') + balanceAnualDin.toFixed(2) + '€';
        kba.style.color  = balanceAnualDin >= 0 ? '#065f46' : '#991b1b';
      }
      var kbaIcon = document.getElementById('kpiBalanceAnualIcon');
      if (kbaIcon) {
        kbaIcon.style.background = balanceAnualDin >= 0 ? '#d1fae5' : '#fee2e2';
        kbaIcon.innerHTML = balanceAnualDin >= 0
          ? '<i class="fas fa-coins" style="color:#065f46;"></i>'
          : '<i class="fas fa-coins" style="color:#991b1b;"></i>';
      }

      // KPI pendientes del año actual
      var pendientesAnio = (typeof reservasGestion !== 'undefined' ? reservasGestion : [])
        .filter(function(r) {
          if (!r.activa || r.pagado || !r.importe_total) return false;
          return new Date(r.fecha_fin).getFullYear() === anioActual;
        })
        .reduce(function(s,r){ return s + parseFloat(r.importe_total||0); }, 0);
      var ke = document.getElementById('kpiIngresosEsperados'); if (ke) ke.textContent = pendientesAnio.toFixed(2) + '€';
      // Pendientes mensuales para el stat de la derecha del gráfico
      var pendientes = (typeof reservasGestion !== 'undefined' ? reservasGestion : [])
        .filter(function(r) {
          if (!r.activa || r.pagado || !r.importe_total) return false;
          if (window._viewYear === null) return true;
          var df = new Date(r.fecha_fin);
          return df.getFullYear() === window._viewYear && df.getMonth() === window._viewMonth;
        })
        .reduce(function(s,r){ return s+parseFloat(r.importe_total||0); }, 0);
      var se = document.getElementById('statIngresosEsperados'); if (se) se.textContent = pendientes.toFixed(2) + '€';
      // KPI reservas anuales
      var reservasAnuales = (typeof reservasGestion !== 'undefined' ? reservasGestion : [])
        .filter(function(r) { return r.activa && new Date(r.fecha_fin).getFullYear() === anioActual; })
        .length;
      var kra = document.getElementById('kpiReservasAnuales'); if (kra) kra.textContent = reservasAnuales;
      // Reservas mensuales para el stat lateral
      var reservasMes = (typeof reservasGestion !== 'undefined' ? reservasGestion : [])
        .filter(function(r) {
          if (!r.activa) return false;
          if (window._viewYear === null) { return new Date(r.fecha_fin).getFullYear() === anioActual; }
          var df = new Date(r.fecha_fin);
          return df.getFullYear() === window._viewYear && df.getMonth() === window._viewMonth;
        })
        .length;
      var srm = document.getElementById('statReservasMes'); if (srm) srm.textContent = reservasMes;
      _buildChart();
    }

    function updateReservaEstado(id, nuevoEstado) {
      var r = reservasGestion.find(function(x){ return x.id === id; });
      if (!r) return;
      r.estado = nuevoEstado;
      fetch('/propiedades/' + viviendaIdGlobal + '/reservas/' + id, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ estado: nuevoEstado })
      })
      .then(function(res){ return res.json(); })
      .then(function(d){
        if (d.success) {
          filtrarReservas();
          updateFinancialSummary();
          showToast('Estado actualizado: ' + nuevoEstado, 'success');
        } else { showToast(d.error || 'Error al actualizar estado', 'error'); }
      })
      .catch(function(){ showToast('Error de conexión', 'error'); });
    }

    function updateReservaPagado(id) {
      var r = reservasGestion.find(function(x){ return x.id === id; });
      if (!r) return;
      var nuevoPagado = !r.pagado;
      r.pagado = nuevoPagado; // optimista
      filtrarReservas(); // actualizar badge inmediatamente
      fetch('/propiedades/' + viviendaIdGlobal + '/reservas/' + id, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pagado: nuevoPagado })
      })
      .then(function(res){ return res.json(); })
      .then(function(d){
        if (d.success) {
          // Recargar transacciones desde BD (se creó o eliminó una automática)
          recargarTransacciones();
          showToast(nuevoPagado ? 'Reserva marcada como pagada' : 'Reserva marcada como pendiente', 'success');
        } else {
          r.pagado = !nuevoPagado; // revertir
          filtrarReservas();
          showToast(d.error || 'Error al actualizar pago', 'error');
        }
      })
      .catch(function(){ r.pagado = !nuevoPagado; filtrarReservas(); showToast('Error de conexión', 'error'); });
    }

    var _pendingDeleteId = null, _pendingDeleteTipo = null;
    var _pendingDeleteReservaId = null;
    function deleteReserva(id) {
      _pendingDeleteReservaId = id;
      document.getElementById('confirmDeleteMsg').textContent = '¿Eliminar la reserva #' + id + '? Esta acción no se puede deshacer.';
      document.getElementById('confirmDeleteModal').classList.add('show');
      // Override confirm button for this context
      document.querySelector('#confirmDeleteModal .btn-primary').onclick = _doDeleteReserva;
    }
    function _doDeleteReserva() {
      var id = _pendingDeleteReservaId;
      document.getElementById('confirmDeleteModal').classList.remove('show');
      document.querySelector('#confirmDeleteModal .btn-primary').onclick = _doDeleteTransaccion;
      _pendingDeleteReservaId = null;
      fetch('/propiedades/' + viviendaIdGlobal + '/reservas/' + id, { method: 'DELETE' })
        .then(function(r){ return r.json(); })
        .then(function(d) {
          if (d.success) {
            var r = reservasGestion.find(function(x){ return x.id === id; });
            if (r) r.activa = false;
            filtrarReservas();
            // Si tenía transacción vinculada, recargar para actualizar ingresos totales
            if (d.eraPagada) {
              recargarTransacciones().then(function() {
                showToast('Reserva desactivada e ingreso eliminado del análisis financiero', 'success');
              });
            } else {
              updateFinancialSummary(); // actualiza ingresos pendientes
              showToast('Reserva desactivada correctamente', 'success');
            }
          } else { showToast(d.error || 'Error al desactivar la reserva', 'error'); }
        })
        .catch(function(){ showToast('Error de conexión', 'error'); });
    }
    function deleteTransaccion(id, tipo) {
      _pendingDeleteId = id; _pendingDeleteTipo = tipo;
      document.getElementById('confirmDeleteMsg').textContent = '¿Eliminar este ' + tipo + '?';
      document.getElementById('confirmDeleteModal').classList.add('show');
    }
    function _doDeleteTransaccion() {
      var id = _pendingDeleteId, tipo = _pendingDeleteTipo;
      document.getElementById('confirmDeleteModal').classList.remove('show');
      _pendingDeleteId = null; _pendingDeleteTipo = null;
      fetch('/propiedades/' + viviendaIdGlobal + '/transacciones/' + id, { method: 'DELETE' })
        .then(function(r){ return r.json(); })
        .then(function(d) {
          if (d.success) {
            window._transacciones = window._transacciones.filter(function(t){ return t.id_transaccion !== id; });
            renderTransacciones();
            updateFinancialSummary();
            showToast((tipo === 'gasto' ? 'Gasto' : 'Ingreso') + ' eliminado', 'success');
          } else { showToast(d.error || 'Error al eliminar', 'error'); }
        })
        .catch(function(){ showToast('Error de conexión', 'error'); });
    }

    // Initialize financial data and reservas on load
    document.addEventListener('DOMContentLoaded', function() {
      renderTransacciones();
      updateFinancialSummary();
      filtrarReservas();
    });

    // Initialize calendar if reservations exist
    <% if (typeof reservasMes !== 'undefined') { %>
      document.addEventListener('DOMContentLoaded', function() {
        const calendarEl = document.getElementById('calendario');
        if (calendarEl) {
          const reservas = <%- JSON.stringify(typeof todasReservas !== 'undefined' ? todasReservas : (typeof reservasMes !== 'undefined' ? reservasMes : [])) %>;
          
          const events = reservas
            .filter(r => r.activa !== false)
            .map(reserva => ({
            title: (reserva.nombre_huesped || 'Reservado'),
            start: reserva.fecha_inicio,
            end: reserva.fecha_fin,
            backgroundColor: '#1a2332',
            borderColor: '#141d28',
            textColor: '#ffffff'
          }));

          const calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            locale: 'es',
            events: events,
            headerToolbar: {
              left: 'prev,next today',
              center: 'title',
              right: 'dayGridMonth,timeGridWeek'
            },
            buttonText: {
              today: 'Hoy',
              month: 'Mes',
              week: 'Semana'
            },
            height: 'auto',
            dayMaxEvents: true,
            eventDisplay: 'block',
            fixedWeekCount: false,
            firstDay: 1,
            eventTimeFormat: {
              hour: '2-digit',
              minute: '2-digit',
              meridiem: false
            }
          });
          
          window._calInstance = calendar;
          calendar.render();
        }
      });
    <% } %>

    // ── Sincronizar calendario (reservas + tareas vinculadas) ────────────────────────────────────────
    function _syncCalendar() {
      if (!window._calInstance) return;
      window._calInstance.removeAllEvents();
      var reservaEvents = reservasGestion
        .filter(function(r) { return r.activa !== false && r.fecha_inicio && r.fecha_fin; })
        .map(function(r) {
          return {
            title: (r.nombre_huesped || 'Reservado'),
            start: r.fecha_inicio,
            end: r.fecha_fin,
            backgroundColor: '#1a2332',
            borderColor: '#141d28',
            textColor: '#ffffff'
          };
        });
      var tareaEvents = (window._tareas || [])
        .filter(function(t) { return t.vinculada_calendario && t.fecha_limite && t.estado !== 'Completada'; })
        .map(function(t) {
          return {
            title: '\u2713 ' + t.descripcion,
            start: t.fecha_limite,
            allDay: true,
            backgroundColor: '#6366f1',
            borderColor: '#4f46e5',
            textColor: '#ffffff'
          };
        });
      window._calInstance.addEventSource(reservaEvents.concat(tareaEvents));
    }

    // ===== RESERVAS =====

    // Recarga reservas desde servidor vía AJAX y actualiza reservasGestion
    function recargarReservas() {
      return fetch('/propiedades/' + viviendaIdGlobal + '/reservas')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data.success) return;
          reservasGestion = data.reservas.map(function(r) {
            var h0 = (r.Huespedes && r.Huespedes[0]) || {};
            return {
              id: r.id_reserva,
              nombre_huesped: h0.nombre || '',
              apellidos_huesped: h0.apellidos || '',
              dni: h0.dni || '',
              tipo_documento: h0.tipo_documento || 'DNI',
              fecha_expedicion: h0.fecha_expedicion_documento || '',
              email: h0.email || '',
              telefono: h0.telefono || '',
              nacionalidad: h0.nacionalidad || '',
              sexo: h0.sexo || '',
              fecha_nacimiento: h0.fecha_nacimiento || '',
              fecha_inicio: r.fecha_inicio,
              fecha_fin: r.fecha_fin,
              hora_llegada: r.hora_llegada || '15:00',
              hora_salida_str: r.hora_salida || '11:00',
              num_huespedes: r.num_huespedes,
              importe_total: r.importe_total || null,
              plataforma: r.plataforma || 'airbnb',
              id_reserva_externo: r.id_reserva_externo || '',
              estado: r.estado || 'confirmada',
              checkin_realizado: !!r.checkin_realizado,
              checkout_realizado: !!r.checkout_realizado,
              activa: !!r.activa,
              pagado: !!r.pagado,
              tipo_pago: r.tipo_pago || '',
              metodo_pago: r.metodo_pago || '',
              titular_pago: r.titular_pago || '',
              fecha_caducidad_pago: r.fecha_caducidad_pago || '',
              fecha_pago: r.fecha_pago || ''
            };
          });
          filtrarReservas();
          // Sincronizar el calendario con las reservas actualizadas
          _syncCalendar();
        })
        .catch(function(e) { console.error('Error al recargar reservas:', e); });
    }

    // Recarga transacciones desde servidor vía AJAX
    function recargarTransacciones() {
      return fetch('/propiedades/' + viviendaIdGlobal + '/transacciones')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data.success) return;
          window._transacciones = data.transacciones;
          renderTransacciones();
          updateFinancialSummary();
        })
        .catch(function(e) { console.error('Error al recargar transacciones:', e); });
    }

    const reservasData = <%- JSON.stringify(typeof todasReservas !== 'undefined' ? todasReservas : (typeof proximasReservas !== 'undefined' ? proximasReservas : [])) %>;
    let reservasGestion = reservasData.map((r, i) => {
      const h0 = (r.Huespedes && r.Huespedes[0]) || {};
      return {
        id: r.id_reserva,
        nombre_huesped: h0.nombre || r.nombre_huesped || '',
        apellidos_huesped: h0.apellidos || r.apellidos_huesped || '',
        dni: h0.dni || r.dni || '',
        tipo_documento: h0.tipo_documento || r.tipo_documento || 'DNI',
        fecha_expedicion: h0.fecha_expedicion_documento || r.fecha_expedicion_documento || '',
        email: h0.email || r.email || '',
        telefono: h0.telefono || r.telefono || '',
        nacionalidad: h0.nacionalidad || r.nacionalidad || '',
        sexo: h0.sexo || r.sexo || '',
        fecha_nacimiento: h0.fecha_nacimiento || r.fecha_nacimiento || '',
        fecha_inicio: r.fecha_inicio,
        fecha_fin: r.fecha_fin,
        hora_llegada: r.hora_llegada || '15:00',
        hora_salida_str: r.hora_salida || '11:00',
        num_huespedes: r.num_huespedes,
        importe_total: r.importe_total || null,
        plataforma: r.plataforma || 'airbnb',
        id_reserva_externo: r.id_reserva_externo || '',
        estado: r.estado || 'confirmada',
        checkin_realizado: r.checkin_realizado || false,
        checkout_realizado: r.checkout_realizado || false,
        activa: !!r.activa,
        pagado: !!r.pagado,
        tipo_pago: r.tipo_pago || '',
        metodo_pago: r.metodo_pago || '',
        titular_pago: r.titular_pago || '',
        fecha_caducidad_pago: r.fecha_caducidad_pago || '',
        fecha_pago: r.fecha_pago || ''
      };
    });

    function renderTablaReservas(data) {
      const tbody = document.getElementById('reservasTableBody');
      if (!tbody) return;
      if (!data || data.length === 0) {
        tbody.innerHTML = `<tr><td colspan="11" style="text-align:center;padding:3rem 1rem;color:#64748b;">
          <i class="fas fa-calendar-times" style="font-size:2.5rem;opacity:0.3;margin-bottom:0.75rem;display:block;"></i>
          No hay reservas registradas</td></tr>`;
        return;
      }
      tbody.innerHTML = data.map(r => {
        const confirmada = r.estado === 'confirmada';
        const estadoBg    = confirmada ? '#d1fae5' : '#fee2e2';
        const estadoColor = confirmada ? '#065f46' : '#991b1b';
        const realIdx = reservasGestion.indexOf(r);
        const fmt = d => d ? new Date(d).toLocaleDateString('es-ES') : '—';
        const pagadoBadge = r.pagado
          ? `<span onclick="updateReservaPagado(${r.id})" title="Marcar como pendiente" style="display:inline-flex;align-items:center;gap:.3rem;padding:.2rem .65rem;border-radius:9999px;font-size:.72rem;font-weight:600;background:#d1fae5;color:#065f46;cursor:pointer;border:1px solid #a7f3d0;"><i class="fas fa-check-circle"></i> Pagado</span>`
          : `<span onclick="updateReservaPagado(${r.id})" title="Marcar como pagado" style="display:inline-flex;align-items:center;gap:.3rem;padding:.2rem .65rem;border-radius:9999px;font-size:.72rem;font-weight:600;background:#fff7ed;color:#c2410c;cursor:pointer;border:1px solid #fed7aa;"><i class="fas fa-clock"></i> Pendiente</span>`;
        const estadoSelect = `<select onchange="updateReservaEstado(${r.id}, this.value)" style="padding:.25rem .5rem;border-radius:.375rem;border:1.5px solid ${estadoBg};background:${estadoBg};color:${estadoColor};font-size:.75rem;font-weight:600;cursor:pointer;outline:none;">
          <option value="confirmada" ${r.estado==='confirmada'?'selected':''}>confirmada</option>
          <option value="pendiente" ${r.estado==='pendiente'?'selected':''}>pendiente</option>
          <option value="cancelada" ${r.estado==='cancelada'?'selected':''}>cancelada</option>
        </select>`;
        const activaBadge = r.activa
          ? '<span style="display:inline-flex;align-items:center;gap:.3rem;padding:.2rem .6rem;border-radius:9999px;font-size:.72rem;font-weight:600;background:#d1fae5;color:#065f46;"><i class=\"fas fa-check\"></i> Activa</span>'
          : '<span style="display:inline-flex;align-items:center;gap:.3rem;padding:.2rem .6rem;border-radius:9999px;font-size:.72rem;font-weight:600;background:#f1f5f9;color:#94a3b8;"><i class=\"fas fa-ban\"></i> Inactiva</span>';
        return `<tr style="border-bottom:1px solid #f1f5f9;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
          <td style="padding:.75rem 1rem;font-weight:600;color:#1a2332;">#${r.id}</td>
          <td style="padding:.75rem 1rem;color:#1a2332;">${r.nombre_huesped ? r.nombre_huesped + ' ' + (r.apellidos_huesped || '') : '—'}</td>
          <td style="padding:.75rem 1rem;color:#64748b;font-size:.8rem;">${r.dni || '—'}</td>
          <td style="padding:.75rem 1rem;white-space:nowrap;">${fmt(r.fecha_inicio)}</td>
          <td style="padding:.75rem 1rem;white-space:nowrap;">${fmt(r.fecha_fin)}</td>
          <td style="padding:.75rem 1rem;text-align:center;">${r.num_huespedes || '—'}</td>
          <td style="padding:.75rem 1rem;font-weight:600;color:#065f46;">${r.importe_total ? parseFloat(r.importe_total).toFixed(2) + ' €' : '—'}</td>
          <td style="padding:.75rem 1rem;">${pagadoBadge}</td>
          <td style="padding:.75rem 1rem;">${estadoSelect}</td>
          <td style="padding:.75rem 1rem;text-align:center;">${activaBadge}</td>
          <td style="padding:.75rem 1rem;white-space:nowrap;">
            <button onclick="openReservaDetail(${r.id})" title="Ver / Editar detalles" style="padding:.35rem .65rem;background:#0f766e;color:white;border:none;border-radius:.375rem;font-size:.75rem;cursor:pointer;">
              <i class="fas fa-eye"></i>
            </button>
            <button onclick="openEditReservaModal(${r.id})" title="Editar reserva rápido" style="padding:.35rem .65rem;background:#1e40af;color:white;border:none;border-radius:.375rem;font-size:.75rem;cursor:pointer;margin-left:.3rem;">
              <i class="fas fa-edit"></i>
            </button>
            <button onclick="exportarParteViajeros(${realIdx})" style="padding:.35rem .65rem;background:#1a2332;color:white;border:none;border-radius:.375rem;font-size:.75rem;cursor:pointer;margin-left:.35rem;">
              <i class="fas fa-file-export"></i> Parte
            </button>
            ${r.activa
              ? `<button onclick="deleteReserva(${r.id})" style="padding:.35rem .65rem;background:#991b1b;color:white;border:none;border-radius:.375rem;font-size:.75rem;cursor:pointer;margin-left:.35rem;" title="Desactivar reserva"><i class="fas fa-ban"></i></button>`
              : ''}
          </td>
        </tr>`;
      }).join('');
    }

    var _mostrarInactivas = false;
    function toggleInactivas() {
      _mostrarInactivas = !_mostrarInactivas;
      var btn = document.getElementById('btnToggleInactivas');
      btn.innerHTML = _mostrarInactivas
        ? '<i class="fas fa-eye"></i> Ver solo activas'
        : '<i class="fas fa-eye-slash"></i> Ver inactivas';
      btn.style.borderColor = _mostrarInactivas ? '#1a2332' : '#e2e8f0';
      btn.style.color = _mostrarInactivas ? '#1a2332' : '#64748b';
      filtrarReservas();
    }

    function filtrarReservas() {
      const q1     = (document.getElementById('searchReservaNumero')?.value || '').toLowerCase();
      const q2     = (document.getElementById('searchDNI')?.value || '').toLowerCase();
      const qEst   = (document.getElementById('searchEstado')?.value || '').toLowerCase();
      const qPago  = (document.getElementById('searchPagado')?.value || '');
      const filtered = reservasGestion.filter(r =>
        (_mostrarInactivas || r.activa) &&
        (!q1    || String(r.id).toLowerCase().includes(q1) || String(r.id_reserva_externo||'').toLowerCase().includes(q1)) &&
        (!q2    || String(r.dni||'').toLowerCase().includes(q2)) &&
        (!qEst  || (r.estado||'').toLowerCase() === qEst) &&
        (!qPago || (qPago === 'pagado' ? r.pagado : !r.pagado))
      );
      renderTablaReservas(filtered);
    }

    function openNewReservationModal() {
      switchNrTab('reserva');
      document.getElementById('newReservationModal').style.display = 'flex';
    }
    function closeNewReservationModal() {
      document.getElementById('newReservationModal').style.display = 'none';
    }

    function _clearNrErrors() {
      ['nrFechaInicio','nrFechaFin','nrNumHuespedes'].forEach(function(id) {
        const el = document.getElementById(id);
        if (el) el.classList.remove('input-error');
      });
    }

    function _validateReservaTab() {
      let ok = true;
      ['nrFechaInicio','nrFechaFin','nrNumHuespedes'].forEach(function(id) {
        const el = document.getElementById(id);
        if (!el) return;
        if (!el.value || el.value === '') {
          el.classList.add('input-error');
          el.addEventListener('input', function h() { el.classList.remove('input-error'); el.removeEventListener('input', h); });
          ok = false;
        } else {
          el.classList.remove('input-error');
        }
      });
      return ok;
    }

    function _validateHuespedTab() {
      const container = document.getElementById('nrHuespedesContainer');
      if (!container) return true;
      const item = container.querySelector('.nh-accordion-item[data-idx="1"]');
      if (!item) return true;
      let ok = true;
      ['Nombre','Apellidos','Dni'].forEach(function(field) {
        const inp = item.querySelector('[data-field="'+field+'"]');
        if (!inp) return;
        if (!inp.value.trim()) {
          inp.classList.add('input-error');
          inp.addEventListener('input', function h() { inp.classList.remove('input-error'); inp.removeEventListener('input', h); });
          // Open the accordion if closed
          const body = item.querySelector('.nh-accordion-body');
          if (body && body.style.display === 'none') item.querySelector('div').click();
          ok = false;
        } else {
          inp.classList.remove('input-error');
        }
      });
      return ok;
    }

    function nrGoToHuesped() {
      if (!_validateReservaTab()) {
        showToast('Rellena los campos obligatorios marcados con *', 'error');
        return;
      }
      if (new Date(document.getElementById('nrFechaInicio').value) >= new Date(document.getElementById('nrFechaFin').value)) {
        document.getElementById('nrFechaFin').classList.add('input-error');
        showToast('La fecha de entrada debe ser anterior a la de salida.', 'error');
        return;
      }
      switchNrTab('huesped');
    }
    function switchNrTab(tab) {
      document.getElementById('nrPanelReserva').style.display = tab === 'reserva' ? 'block' : 'none';
      document.getElementById('nrPanelHuesped').style.display = tab === 'huesped' ? 'block' : 'none';
      document.getElementById('nrPanelPago').style.display    = tab === 'pago'    ? 'block' : 'none';
      document.getElementById('nrBtnSiguiente').style.display = tab === 'reserva' ? '' : 'none';
      document.getElementById('nrBtnGuardar').style.display   = tab === 'reserva' ? 'none' : '';
      [['nrTabReservaBtn','reserva'],['nrTabHuespedBtn','huesped'],['nrTabPagoBtn','pago']].forEach(function(pair) {
        const active = pair[1] === tab;
        const btn = document.getElementById(pair[0]);
        btn.style.borderBottomColor = active ? '#1a2332' : 'transparent';
        btn.style.fontWeight = active ? '700' : '500';
        btn.style.color = active ? '#1a2332' : '#94a3b8';
      });
      if (tab === 'huesped') buildHuespedesAccordion();
    }

    function buildHuespedesAccordion() {
      const n = parseInt(document.getElementById('nrNumHuespedes').value) || 1;
      const container = document.getElementById('nrHuespedesContainer');
      // Preserve existing values if already rendered
      const existing = {};
      container.querySelectorAll('.nh-accordion-item').forEach(function(el) {
        const idx = el.dataset.idx;
        ['Nombre','Apellidos','Dni','TipoDocumento','FechaExpedicion','FechaNacimiento','Sexo','Nacionalidad','Email','Telefono','Direccion','Localidad','Pais','Parentesco'].forEach(function(f) {
          const inp = el.querySelector('[data-field="' + f + '"]');
          if (inp) { existing[idx + '_' + f] = inp.value; }
        });
      });

      container.innerHTML = '';
      for (var i = 1; i <= n; i++) {
        const idx = i;
        const item = document.createElement('div');
        item.className = 'nh-accordion-item';
        item.dataset.idx = idx;
        item.style.cssText = 'border:1.5px solid #e2e8f0;border-radius:0.5rem;margin-bottom:0.5rem;overflow:hidden;';

        const header = document.createElement('div');
        header.style.cssText = 'display:flex;align-items:center;justify-content:space-between;padding:0.6rem 1rem;background:#f8fafc;cursor:pointer;user-select:none;';
        const responsableBadge = idx === 1
          ? ' <span style="font-size:0.7rem;font-weight:600;background:#eef2ff;color:#4f46e5;border:1px solid #c7d2fe;border-radius:20px;padding:1px 8px;margin-left:6px;vertical-align:middle;">Responsable de reserva</span>'
          : '';
        header.innerHTML = '<span style="font-weight:600;font-size:0.85rem;color:#1a2332;display:flex;align-items:center;gap:0.4rem;"><i class="fas fa-user" style="color:#64748b;font-size:0.8rem;"></i>Huésped ' + idx + responsableBadge + '</span>'
          + '<button type="button" class="nh-toggle-btn" style="width:26px;height:26px;border-radius:50%;border:1.5px solid #1a2332;background:#fff;color:#1a2332;font-size:1rem;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;"><i class="fas fa-plus" style="font-size:0.65rem;"></i></button>';

        const body = document.createElement('div');
        body.className = 'nh-accordion-body';
        body.style.cssText = 'display:none;padding:1rem;border-top:1px solid #e2e8f0;background:#fff;';
        body.innerHTML = nhFormHTML(idx, existing);

        header.addEventListener('click', function(item, body, header) {
          return function() {
            const open = body.style.display !== 'none';
            body.style.display = open ? 'none' : 'block';
            const ico = header.querySelector('.nh-toggle-btn i');
            const btn = header.querySelector('.nh-toggle-btn');
            if (open) {
              ico.className = 'fas fa-plus'; ico.style.fontSize = '0.65rem';
              btn.style.background = '#fff'; btn.style.color = '#1a2332';
            } else {
              ico.className = 'fas fa-check'; ico.style.fontSize = '0.7rem';
              btn.style.background = '#1a2332'; btn.style.color = '#fff';
            }
          };
        }(item, body, header));

        item.appendChild(header);
        item.appendChild(body);
        container.appendChild(item);
      }
    }

