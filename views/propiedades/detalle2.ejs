        </button>
      </div>
      <div class="modal-body">
        <p style="margin:0;font-size:0.9rem;color:#374151;">¿Seguro que quieres eliminar esta tarea? Esta acción no se puede deshacer.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancel" onclick="closeTaskDeleteModal()">Cancelar</button>
        <button type="button" class="btn-primary" id="taskDeleteConfirmBtn" style="background:#991b1b;">
          <i class="fas fa-trash-alt"></i> Eliminar
        </button>
      </div>
    </div>
  </div>

  <!-- Modal: Añadir Gasto -->
  <div id="expenseModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h3><i class="fas fa-minus-circle"></i> Añadir Nuevo Gasto</h3>
        <button class="modal-close" onclick="closeExpenseModal()">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class="modal-body">
        <form id="expenseForm">
          <div class="form-group">
            <label for="expenseCategory">Categoría *</label>
            <select id="expenseCategory" name="expenseCategory" required>
              <option value="">Selecciona una categoría</option>
              <% if (categoriasGasto && categoriasGasto.length > 0) { %>
                <% categoriasGasto.forEach(function(cat) { %>
                  <option value="<%= cat.id_categoria %>"><%= cat.nombre %></option>
                <% }); %>
              <% } else { %>
                <option value="" disabled>— Sin categorías guardadas —</option>
              <% } %>
              <option value="__nueva__">＋ Nueva categoría…</option>
            </select>
            <input type="text" id="expenseCategoryNueva" name="expenseCategoryNueva"
              placeholder="Escribe el nombre de la nueva categoría"
              style="display:none; margin-top:0.5rem;"
              class="form-control">
          </div>
          <div class="form-group">
            <label for="expenseAmount">Importe (€) *</label>
            <input type="number" id="expenseAmount" name="expenseAmount" min="0" step="0.01" required placeholder="0.00">
          </div>
          <div class="form-group">
            <label for="expenseDescription">Descripción</label>
            <textarea id="expenseDescription" name="expenseDescription" placeholder="Detalles del gasto (opcional)"></textarea>
          </div>
          <div class="form-group">
            <label for="expenseDate">Fecha del Gasto</label>
            <input type="date" id="expenseDate" name="expenseDate" value="<%= new Date().toISOString().split('T')[0] %>">
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancel" onclick="closeExpenseModal()">Cancelar</button>
        <button type="button" class="btn-primary" onclick="saveExpense()" style="background: #991b1b;">
          <i class="fas fa-save"></i>
          Registrar Gasto
        </button>
      </div>
    </div>
  </div>

  <!-- Modal: Añadir Ingreso -->
  <div id="incomeModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h3><i class="fas fa-plus-circle"></i> Añadir Nuevo Ingreso</h3>
        <button class="modal-close" onclick="closeIncomeModal()">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class="modal-body">
        <form id="incomeForm">
          <div class="form-group">
            <label for="incomeCategory">Categoría *</label>
            <select id="incomeCategory" name="incomeCategory" required>
              <option value="">Selecciona una categoría</option>
              <% if (categoriasIngreso && categoriasIngreso.length > 0) { %>
                <% categoriasIngreso.forEach(function(cat) { %>
                  <option value="<%= cat.id_categoria %>"><%= cat.nombre %></option>
                <% }); %>
              <% } else { %>
                <option value="" disabled>— Sin categorías guardadas —</option>
              <% } %>
              <option value="__nueva__">＋ Nueva categoría…</option>
            </select>
            <input type="text" id="incomeCategoryNueva" name="incomeCategoryNueva"
              placeholder="Escribe el nombre de la nueva categoría"
              style="display:none; margin-top:0.5rem;"
              class="form-control">
          </div>
          <div class="form-group">
            <label for="incomeAmount">Importe (€) *</label>
            <input type="number" id="incomeAmount" name="incomeAmount" min="0" step="0.01" required placeholder="0.00">
          </div>
          <div class="form-group">
            <label for="incomeDescription">Descripción</label>
            <textarea id="incomeDescription" name="incomeDescription" placeholder="Detalles del ingreso (opcional)"></textarea>
          </div>
          <div class="form-group">
            <label for="incomeDate">Fecha del Ingreso</label>
            <input type="date" id="incomeDate" name="incomeDate" value="<%= new Date().toISOString().split('T')[0] %>">
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancel" onclick="closeIncomeModal()">Cancelar</button>
        <button type="button" class="btn-primary" onclick="saveIncome()" style="background: #065f46;">
          <i class="fas fa-save"></i>
          Registrar Ingreso
        </button>
      </div>
    </div>
  </div>

  <!-- Confirm Delete Modal -->
  <div id="confirmDeleteModal" class="modal">
    <div class="modal-content" style="max-width:380px;">
      <div class="modal-header">
        <h3><i class="fas fa-exclamation-triangle" style="color:#991b1b;margin-right:0.5rem;"></i>Confirmar eliminación</h3>
      </div>
      <div class="modal-body" style="padding:1.25rem 1.5rem;">
        <p id="confirmDeleteMsg" style="margin:0;color:#374151;font-size:0.95rem;"></p>
      </div>
      <div class="modal-footer">
        <button class="btn-cancel" onclick="document.getElementById('confirmDeleteModal').classList.remove('show')">Cancelar</button>
        <button class="btn-primary" onclick="_doDeleteTransaccion()" style="background:#991b1b;"><i class="fas fa-trash"></i> Eliminar</button>
      </div>
    </div>
  </div>

  <!-- Leaflet JS -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  
  <!-- FullCalendar JS -->
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
  
  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  
  <script>
    // ── Gasto / Ingreso modals ───────────────────────────────────────
    function openExpenseModal() {
      document.getElementById('expenseModal').classList.add('show');
    }
    function closeExpenseModal() {
      document.getElementById('expenseModal').classList.remove('show');
      document.getElementById('expenseForm').reset();
      var en = document.getElementById('expenseCategoryNueva');
      if (en) { en.style.display = 'none'; en.value = ''; }
    }
    function openIncomeModal() {
      document.getElementById('incomeModal').classList.add('show');
    }
    function closeIncomeModal() {
      document.getElementById('incomeModal').classList.remove('show');
      document.getElementById('incomeForm').reset();
      var in_ = document.getElementById('incomeCategoryNueva');
      if (in_) { in_.style.display = 'none'; in_.value = ''; }
    }

    // Mostrar/ocultar campo de nueva categoría al seleccionar "＋ Nueva categoría…"
    ['expense', 'income'].forEach(function(pfx) {
      const sel = document.getElementById(pfx + 'Category');
      const inp = document.getElementById(pfx + 'CategoryNueva');
      if (sel && inp) {
        sel.addEventListener('change', function() {
          inp.style.display = this.value === '__nueva__' ? 'block' : 'none';
          if (this.value !== '__nueva__') inp.value = '';
        });
      }
    });

    function _saveTransaccion(tipo, formId, closeFn) {
      const form = document.getElementById(formId);
      const prefix = tipo === 'gasto' ? 'expense' : 'income';
      const importe = document.getElementById(prefix + 'Amount').value;
      const descripcion = document.getElementById(prefix + 'Description').value;
      const fecha = document.getElementById(prefix + 'Date').value;
      const categoryEl = document.getElementById(prefix + 'Category');
      const categoryNuevaEl = document.getElementById(prefix + 'CategoryNueva');
      let categoria = '';
      if (categoryEl) {
        if (categoryEl.value === '__nueva__') {
          categoria = categoryNuevaEl ? categoryNuevaEl.value.trim() : '';
          if (!categoria) { showToast('Escribe el nombre de la nueva categoría.', 'error'); return; }
        } else if (categoryEl.value) {
          categoria = categoryEl.selectedOptions[0].text;
        }
      }
      if (!importe || !fecha) { showToast('Completa el importe y la fecha.', 'error'); return; }

      const btn = form.closest('.modal-content').querySelector('.btn-primary');
      const originText = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando…';

      fetch('/propiedades/' + viviendaIdGlobal + '/transacciones', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tipo, importe, descripcion, fecha, categoria })
      })
      .then(function(r){ return r.json(); })
      .then(function(d) {
        btn.disabled = false; btn.innerHTML = originText;
        if (d.success) {
          if (d.transaccion) { window._transacciones.unshift(d.transaccion); }
          renderTransacciones();
          updateFinancialSummary();
          showToast((tipo === 'gasto' ? 'Gasto' : 'Ingreso') + ' registrado correctamente', 'success');
          closeFn();
        } else {
          showToast(d.error || 'Error al guardar', 'error');
        }
      })
      .catch(function() { btn.disabled = false; btn.innerHTML = originText; showToast('Error de conexión', 'error'); });
    }

    function saveExpense() { _saveTransaccion('gasto', 'expenseForm', closeExpenseModal); }
    function saveIncome()  { _saveTransaccion('ingreso', 'incomeForm', closeIncomeModal); }

    // Tab Navigation
    document.addEventListener('DOMContentLoaded', function() {
      const navItems = document.querySelectorAll('.nav-item');
      const tabContents = document.querySelectorAll('.tab-content');

      navItems.forEach(item => {
        item.addEventListener('click', function() {
          const tabId = this.getAttribute('data-tab');
          
          navItems.forEach(nav => nav.classList.remove('active'));
          tabContents.forEach(tab => tab.classList.remove('active'));
          
          this.classList.add('active');
          document.getElementById('tab-' + tabId).classList.add('active');

          // Re-render FullCalendar when its tab becomes visible
          if (tabId === 'general' && window._calInstance) {
            setTimeout(() => window._calInstance.updateSize(), 80);
          }
          // Re-render Leaflet map when Información tab becomes visible
          if (tabId === 'property' && window._mapInstance) {
            setTimeout(function() { window._mapInstance.invalidateSize(); }, 80);
          }
        });
      });

      // Auto-activate tab from URL ?tab= param (e.g. ?tab=channels from Reserva button)
      const urlTab = new URLSearchParams(window.location.search).get('tab');
      if (urlTab) {
        const targetNav = document.querySelector('.nav-item[data-tab="' + urlTab + '"]');
        if (targetNav) targetNav.click();
      }
    });

    // ---- EDITAR RESERVA ----
    function openEditReservaModal(id) {
      var r = reservasGestion.find(function(x){ return x.id === id; });
      if (!r) return;
      document.getElementById('editReservaId').value = id;
      document.getElementById('editReservaTitle').textContent = '#' + id;
      document.getElementById('erFechaInicio').value          = r.fecha_inicio ? r.fecha_inicio.split('T')[0] : '';
      document.getElementById('erFechaFin').value             = r.fecha_fin    ? r.fecha_fin.split('T')[0]    : '';
      document.getElementById('erNumHuespedes').value         = r.num_huespedes || '';
      document.getElementById('erPlataforma').value           = r.plataforma || 'otros';
      document.getElementById('erEstado').value               = r.estado || 'confirmada';
      document.getElementById('erIdExterno').value            = r.id_reserva_externo || '';
      document.getElementById('erCheckinRealizado').checked   = !!r.checkin_realizado;
      document.getElementById('erCheckoutRealizado').checked  = !!r.checkout_realizado;
      // Clear previous errors
      ['erFechaInicio','erFechaFin'].forEach(function(i){ document.getElementById(i).classList.remove('input-error'); });
      document.getElementById('editReservaModal').style.display = 'flex';
    }

    function closeEditReservaModal() {
      document.getElementById('editReservaModal').style.display = 'none';
    }

    function guardarEdicionReserva() {
      var fi = document.getElementById('erFechaInicio').value;
      var ff = document.getElementById('erFechaFin').value;
      if (!fi) { document.getElementById('erFechaInicio').classList.add('input-error'); showToast('Indica la fecha de entrada.', 'error'); return; }
      if (!ff) { document.getElementById('erFechaFin').classList.add('input-error');    showToast('Indica la fecha de salida.', 'error'); return; }
      if (new Date(fi) >= new Date(ff)) {
        document.getElementById('erFechaFin').classList.add('input-error');
        showToast('La fecha de entrada debe ser anterior a la de salida.', 'error'); return;
      }
      var id  = document.getElementById('editReservaId').value;
      var btn = document.getElementById('erBtnGuardar');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando\u2026';
      fetch('/propiedades/' + viviendaIdGlobal + '/reservas/' + id, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          fecha_inicio:         fi,
          fecha_fin:            ff,
          num_huespedes:        parseInt(document.getElementById('erNumHuespedes').value) || null,
          plataforma:           document.getElementById('erPlataforma').value,
          estado:               document.getElementById('erEstado').value,
          id_reserva_externo:   document.getElementById('erIdExterno').value || null,
          checkin_realizado:    document.getElementById('erCheckinRealizado').checked,
          checkout_realizado:   document.getElementById('erCheckoutRealizado').checked,
          hora_llegada:         document.getElementById('erHoraLlegada').value || '15:00',
          hora_salida:          document.getElementById('erHoraSalida').value  || '11:00'
        })
      })
      .then(function(r){ return r.json(); })
      .then(function(d) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Guardar cambios';
        if (d.success) {
          closeEditReservaModal();
          Promise.all([recargarReservas(), recargarTransacciones()]).then(function() {
            showToast('Reserva actualizada correctamente', 'success');
          });
        } else {
          showToast(d.error || 'Error al guardar los cambios', 'error');
        }
      })
      .catch(function() {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Guardar cambios';
        showToast('Error de conexi\u00f3n', 'error');
      });
    }

    // ======================================================
    // VISTA DETALLE RESERVA
    // ======================================================
    var _rdReservaId = null;
    var _rdHuespedes = [];

    function openReservaDetail(id) {
      var r = reservasGestion.find(function(x){ return x.id === id; });
      if (!r) return;
      _rdReservaId = id;
      document.getElementById('rdTitle').textContent = 'Reserva #' + id;
      document.getElementById('rdFechaInicio').value  = r.fecha_inicio ? r.fecha_inicio.split('T')[0] : '';
      document.getElementById('rdFechaFin').value     = r.fecha_fin    ? r.fecha_fin.split('T')[0]    : '';
      document.getElementById('rdHoraLlegada').value  = r.hora_llegada    || '15:00';
      document.getElementById('rdHoraSalida').value   = r.hora_salida_str || '11:00';
      document.getElementById('rdImporte').value      = r.importe_total != null ? r.importe_total : '';
      document.getElementById('rdNumHuespedes').value = r.num_huespedes || '';
      document.getElementById('rdPlataforma').value   = r.plataforma || 'otros';
      document.getElementById('rdEstado').value       = r.estado || 'confirmada';
      document.getElementById('rdCheckin').checked    = !!r.checkin_realizado;
      document.getElementById('rdCheckout').checked   = !!r.checkout_realizado;
      document.getElementById('rdPagado').checked     = !!r.pagado;
      document.querySelector('#tab-channels .card').style.display = 'none';
      document.getElementById('reservaDetailView').style.display  = 'block';
      cargarHuespedes(id);
    }

    function closeReservaDetail() {
      document.getElementById('reservaDetailView').style.display = 'none';
      document.querySelector('#tab-channels .card').style.display = '';
      _rdReservaId = null;
    }

    function guardarCambiosReservaDetalle() {
      if (!_rdReservaId) return;
      var fi = document.getElementById('rdFechaInicio').value;
      var ff = document.getElementById('rdFechaFin').value;
      if (!fi || !ff) { showToast('Las fechas son obligatorias.', 'error'); return; }
      if (new Date(fi) >= new Date(ff)) { showToast('La fecha de entrada debe ser anterior a la de salida.', 'error'); return; }
      var btn = document.getElementById('rdBtnGuardar');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando&hellip;';
      fetch('/propiedades/' + viviendaIdGlobal + '/reservas/' + _rdReservaId, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          fecha_inicio:       fi,
          fecha_fin:          ff,
          hora_llegada:       document.getElementById('rdHoraLlegada').value  || '15:00',
          hora_salida:        document.getElementById('rdHoraSalida').value   || '11:00',
          importe_total:      parseFloat(document.getElementById('rdImporte').value) || null,
          num_huespedes:      parseInt(document.getElementById('rdNumHuespedes').value)  || null,
          plataforma:         document.getElementById('rdPlataforma').value,
          estado:             document.getElementById('rdEstado').value,
          checkin_realizado:  document.getElementById('rdCheckin').checked,
          checkout_realizado: document.getElementById('rdCheckout').checked,
          pagado:             document.getElementById('rdPagado').checked
        })
      })
      .then(function(r){ return r.json(); })
      .then(function(d) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Guardar cambios en la reserva';
        if (d.success) {
          Promise.all([recargarReservas(), recargarTransacciones()]).then(function() {
            showToast('Reserva actualizada correctamente', 'success');
          });
        } else { showToast(d.error || 'Error al guardar.', 'error'); }
      })
      .catch(function() {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Guardar cambios en la reserva';
        showToast('Error de conexion', 'error');
      });
    }

    // Huespedes (detalle reserva)
    function cargarHuespedes(reservaId) {
      document.getElementById('rdHuespedesBody').innerHTML =
        '<tr><td colspan="5" style="text-align:center;padding:2rem;color:#94a3b8;">' +
        '<i class="fas fa-spinner fa-spin"></i> Cargando...</td></tr>';
      fetch('/propiedades/' + viviendaIdGlobal + '/reservas/' + reservaId + '/huespedes')
        .then(function(r){ return r.json(); })
        .then(function(d) {
          if (d.success) { _rdHuespedes = d.huespedes || []; renderHuespedes(); }
          else showToast(d.error || 'Error al cargar huespedes', 'error');
        })
        .catch(function(){ showToast('Error de conexion al cargar huespedes', 'error'); });
    }

    function renderHuespedes() {
      var tbody = document.getElementById('rdHuespedesBody');
      if (!_rdHuespedes.length) {
        tbody.innerHTML =
          '<tr><td colspan="5" style="text-align:center;padding:2.5rem 1rem;color:#94a3b8;">' +
          '<i class="fas fa-user-slash" style="font-size:2rem;opacity:.35;display:block;margin-bottom:.5rem;"></i>' +
          'Sin huespedes registrados</td></tr>';
        return;
      }
      tbody.innerHTML = _rdHuespedes.map(function(h) {
        return '<tr style="border-bottom:1px solid #f1f5f9;" ' +
          'onmouseover="this.style.background=\'#f8fafc\'" onmouseout="this.style.background=\'white\'">' +
          '<td style="padding:.65rem 1rem;">' + escapeHtml((h.nombre||'') + ' ' + (h.apellidos||'')) + '</td>' +
          '<td style="padding:.65rem 1rem;color:#64748b;font-size:.8rem;">' +
            escapeHtml((h.tipo_documento || 'DNI') + ' - ' + (h.dni || '-')) + '</td>' +
          '<td style="padding:.65rem 1rem;font-size:.8rem;color:#475569;">' + escapeHtml(h.telefono || '-') + '</td>' +
          '<td style="padding:.65rem 1rem;font-size:.8rem;color:#475569;">'  + escapeHtml(h.email    || '-') + '</td>' +
          '<td style="padding:.65rem 1rem;text-align:center;white-space:nowrap;">' +
            '<button onclick="openHuespedModal(' + h.id_huesped + ')" title="Editar" ' +
              'style="padding:.3rem .6rem;background:#1e40af;color:white;border:none;border-radius:.35rem;font-size:.75rem;cursor:pointer;">' +
              '<i class="fas fa-edit"></i></button> ' +
            '<button onclick="deleteHuespedDetalle(' + h.id_huesped + ')" title="Eliminar" ' +
              'style="padding:.3rem .6rem;background:#991b1b;color:white;border:none;border-radius:.35rem;font-size:.75rem;cursor:pointer;">' +
              '<i class="fas fa-trash"></i></button>' +
          '</td></tr>';
      }).join('');
    }

    function openHuespedModal(id) {
      var h = id ? _rdHuespedes.find(function(x){ return x.id_huesped === id; }) : null;
      document.getElementById('hdmTitle').innerHTML =
        h ? '<i class="fas fa-user-edit"></i> Editar Huesped'
          : '<i class="fas fa-user-plus"></i> Anadir Huesped';
      document.getElementById('hdmHuespedId').value      = h ? h.id_huesped : '';
      document.getElementById('hdmNombre').value         = h ? (h.nombre    || '') : '';
      document.getElementById('hdmApellidos').value      = h ? (h.apellidos || '') : '';
      document.getElementById('hdmDni').value            = h ? (h.dni       || '') : '';
      document.getElementById('hdmTipoDoc').value        = h ? (h.tipo_documento || 'DNI') : 'DNI';
      document.getElementById('hdmTelefono').value       = h ? (h.telefono  || '') : '';
      document.getElementById('hdmEmail').value          = h ? (h.email     || '') : '';
      document.getElementById('hdmNacionalidad').value   = h ? (h.nacionalidad || '') : '';
      document.getElementById('hdmSexo').value           = h ? (h.sexo      || '') : '';
      document.getElementById('hdmFechaNac').value        = h && h.fecha_nacimiento           ? h.fecha_nacimiento.split('T')[0]           : '';
      document.getElementById('hdmFechaExpedicion').value = h && h.fecha_expedicion_documento ? h.fecha_expedicion_documento.split('T')[0] : '';
      document.getElementById('hdmDireccion').value  = h ? (h.direccion  || '') : '';
      document.getElementById('hdmLocalidad').value  = h ? (h.localidad  || '') : '';
      document.getElementById('hdmPais').value       = h ? (h.pais       || '') : '';
      document.getElementById('hdmParentesco').value = h ? (h.parentesco || '') : '';
      ['hdmNombre','hdmApellidos','hdmDni'].forEach(function(i){
        document.getElementById(i).classList.remove('input-error');
      });
      document.getElementById('huespedDetalleModal').style.display = 'flex';
    }

    function closeHuespedModal() {
      document.getElementById('huespedDetalleModal').style.display = 'none';
    }

    function guardarHuespedDetalle() {
      var nombre    = document.getElementById('hdmNombre').value.trim();
      var apellidos = document.getElementById('hdmApellidos').value.trim();
      var dni       = document.getElementById('hdmDni').value.trim();
      var ok = true;
      if (!nombre)    { document.getElementById('hdmNombre').classList.add('input-error');    ok = false; }
      if (!apellidos) { document.getElementById('hdmApellidos').classList.add('input-error'); ok = false; }
      if (!dni)       { document.getElementById('hdmDni').classList.add('input-error');       ok = false; }
      if (!ok) { showToast('Rellena los campos obligatorios: nombre, apellidos y numero de documento.', 'error'); return; }
