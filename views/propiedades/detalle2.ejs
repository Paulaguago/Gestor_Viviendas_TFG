                  </div>
                  <div class="ficha-item">
                    <span class="ficha-label">Barrio</span>
                    <span class="ficha-value"><%= vivienda.barrio || '—' %></span>
                    <button class="btn-edit-field" data-field="barrio" data-value="<%= vivienda.barrio || '' %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
                  </div>
                  <div class="ficha-item">
                    <span class="ficha-label">Ciudad</span>
                    <span class="ficha-value"><%= vivienda.ciudad || '—' %></span>
                    <button class="btn-edit-field" data-field="ciudad" data-value="<%= vivienda.ciudad || '' %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
                  </div>
                  <div class="ficha-item">
                    <span class="ficha-label">País</span>
                    <span class="ficha-value"><%= vivienda.pais || '—' %></span>
                    <button class="btn-edit-field" data-field="pais" data-value="<%= vivienda.pais || '' %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
                  </div>
                  <div class="ficha-item" style="grid-column:1/-1;">
                    <span class="ficha-label">Código Postal</span>
                    <span class="ficha-value"><%= vivienda.codigo_postal || '—' %></span>
                    <button class="btn-edit-field" data-field="codigo_postal" data-value="<%= vivienda.codigo_postal || '' %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
                  </div>
                </div>
              </div>

              <!-- CARACTERÍSTICAS -->
              <div class="prop-section">
                <div class="prop-section-hdr">
                  <span class="prop-sec-label"><i class="fas fa-ruler-combined"></i>Características</span>
