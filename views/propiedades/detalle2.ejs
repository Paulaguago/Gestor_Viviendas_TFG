                ['Nombre comercial','<%= vivienda.nombre || "" %>'],
                ['Tipo de alojamiento','Vivienda turística'],
                ['Dirección completa','<%= [vivienda.calle,vivienda.bloque_portal,vivienda.piso,vivienda.letra_numero].filter(Boolean).join(", ") %>'],
                ['Código postal','<%= vivienda.codigo_postal || "" %>'],
                ['Localidad y provincia','<%= vivienda.ciudad || "" %>'],
                ['Nº registro turístico','<%= vivienda.numero_registro_autonomico || "" %>']
              ])}
              ${parteSection('2. Datos del Titular o Empresa Arrendadora',[
                ['Nombre o razón social','<%= user.razon_social || user.username || "" %>'],
                ['NIF/CIF','<%= user.dni_cif || "" %>'],
                ['Teléfono','<%= user.telefono || "" %>'],
                ['Correo electrónico','<%= user.email || "" %>']
              ])}
              ${viajerosHTML}
              ${parteSection('4. Datos de la Estancia',[
                ['Fecha y hora de entrada', r.fecha_inicio ? fmt(r.fecha_inicio)+' '+(r.hora_llegada||'') : '—'],
                ['Fecha y hora de salida', r.fecha_fin ? fmt(r.fecha_fin)+' '+(r.hora_salida_str||'') : '—'],
                ['Nº reserva / referencia', r.id_reserva_externo || r.id || '—'],
                ['Número de personas', r.num_huespedes || '—']
              ])}
              ${parteSection('5. Datos del Pago',[
                ['Tipo de pago', r.tipo_pago || '—'],
                ['Método de pago', r.metodo_pago || '—'],
                ['Titular del medio de pago', r.titular_pago || '—'],
                ['Fecha de caducidad', r.fecha_caducidad_pago || '—'],
                ['Fecha del pago', r.fecha_pago ? fmt(r.fecha_pago) : '—'],
                ['Importe total', r.importe_total ? r.importe_total+' €' : '—']
              ])}
              <div style="border:1px solid #e2e8f0;border-radius:.5rem;padding:1rem;margin-top:1rem;">
                <strong>6. Firma del Viajero</strong>
                <div style="margin-top:1.5rem;padding-top:2.5rem;border-top:1px dashed #94a3b8;color:#64748b;font-size:.8rem;text-align:center;">Firma manuscrita o digital</div>
              </div>
