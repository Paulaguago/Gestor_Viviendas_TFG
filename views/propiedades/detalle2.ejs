      return '<div class="form-row">'
        +'<div class="form-group"><label>Nombre <span class="req">*</span></label><input type="text" data-field="Nombre" '+val('Nombre')+' placeholder="Nombre"></div>'
        +'<div class="form-group"><label>Apellidos <span class="req">*</span></label><input type="text" data-field="Apellidos" '+val('Apellidos')+' placeholder="Primer y segundo apellido"></div>'
        +'</div>'
        +'<div class="form-row">'
        +'<div class="form-group"><label>Tipo de documento</label><select data-field="TipoDocumento"><option value="DNI">DNI</option><option value="NIE">NIE</option><option value="Pasaporte">Pasaporte</option><option value="Otro">Otro</option></select></div>'
        +'<div class="form-group"><label>Nº de documento <span class="req">*</span></label><input type="text" data-field="Dni" '+val('Dni')+' placeholder="Ej: 12345678A"></div>'
        +'</div>'
        +'<div class="form-row">'
        +'<div class="form-group"><label>Fecha expedición doc.</label><input type="date" data-field="FechaExpedicion" '+val('FechaExpedicion')+'></div>'
        +'<div class="form-group"><label>Fecha de nacimiento</label><input type="date" data-field="FechaNacimiento" '+val('FechaNacimiento')+'></div>'
        +'</div>'
        +'<div class="form-row">'
        +'<div class="form-group"><label>Sexo</label><select data-field="Sexo"><option value="M">Masculino</option><option value="F">Femenino</option><option value="O">Otro</option></select></div>'
        +'<div class="form-group"><label>Nacionalidad</label><input type="text" data-field="Nacionalidad" '+val('Nacionalidad')+' placeholder="Ej: Española"></div>'
        +'</div>'
        +'<div class="form-row">'
        +'<div class="form-group"><label>Email</label><input type="email" data-field="Email" '+val('Email')+' placeholder="correo@ejemplo.com"></div>'
        +'<div class="form-group"><label>Teléfono</label><input type="tel" data-field="Telefono" '+val('Telefono')+' placeholder="+34 600 000 000"></div>'
        +'</div>'
        +'<div class="form-row">'
        +'<div class="form-group"><label>Dirección habitual</label><input type="text" data-field="Direccion" '+val('Direccion')+' placeholder="Calle, número, piso…"></div>'
        +'<div class="form-group"><label>Localidad</label><input type="text" data-field="Localidad" '+val('Localidad')+' placeholder="Ciudad"></div>'
        +'</div>'
        +'<div class="form-row">'
        +'<div class="form-group"><label>País</label><input type="text" data-field="Pais" '+val('Pais')+' placeholder="España"></div>'
        +'<div class="form-group"><label>Parentesco (menores)</label><input type="text" data-field="Parentesco" '+val('Parentesco')+' placeholder="Hijo/a, sobrino/a…"></div>'
        +'</div>';
    }

    function getHuespedField(idx, field) {
      const container = document.getElementById('nrHuespedesContainer');
      if (!container) return '';
      const item = container.querySelector('.nh-accordion-item[data-idx="'+idx+'"]');
      if (!item) return '';
      const inp = item.querySelector('[data-field="'+field+'"]');
      return inp ? inp.value : '';
    }

    function guardarNuevaReserva() {
      // Validate reserva tab fields
      if (!_validateReservaTab()) {
        showToast('Rellena los campos obligatorios marcados con * en la pestaña de reserva.', 'error');
        switchNrTab('reserva'); return;
      }
      const fi = document.getElementById('nrFechaInicio').value;
      const ff = document.getElementById('nrFechaFin').value;
      const nh = document.getElementById('nrNumHuespedes').value;
      if (new Date(fi) >= new Date(ff)) {
        document.getElementById('nrFechaFin').classList.add('input-error');
        showToast('La fecha de entrada debe ser anterior a la fecha de salida.', 'error');
        switchNrTab('reserva'); return;
      }
      // Validate required huésped fields (responsable)
      if (!_validateHuespedTab()) {
        showToast('Rellena los campos obligatorios del huésped: nombre, apellidos y nº de documento.', 'error');
        return;
      }

      const payload = {
        fecha_inicio: fi,
        fecha_fin: ff,
        num_huespedes: parseInt(nh),
        importe_total: parseFloat(document.getElementById('nrImporte').value) || null,
        plataforma: document.getElementById('nrPlataforma').value,
        id_reserva_externo: document.getElementById('nrIdExterno').value,
        estado: document.getElementById('nrEstado').value,
        checkin_realizado: document.getElementById('nrCheckinRealizado').checked,
        checkout_realizado: document.getElementById('nrCheckoutRealizado').checked,
        pagado: document.getElementById('nrPagado').checked,
        hora_llegada: document.getElementById('nrHoraLlegada').value || '15:00',
        hora_salida:  document.getElementById('nrHoraSalida').value  || '11:00',
        nombre_huesped: getHuespedField(1,'Nombre'),
        apellidos_huesped: getHuespedField(1,'Apellidos'),
        dni: getHuespedField(1,'Dni'),
        tipo_documento: getHuespedField(1,'TipoDocumento'),
        fecha_expedicion: getHuespedField(1,'FechaExpedicion'),
        email: getHuespedField(1,'Email'),
        telefono: getHuespedField(1,'Telefono'),
        nacionalidad: getHuespedField(1,'Nacionalidad'),
        sexo: getHuespedField(1,'Sexo'),
        fecha_nacimiento: getHuespedField(1,'FechaNacimiento'),
        direccion: getHuespedField(1,'Direccion') || null,
        localidad_h: getHuespedField(1,'Localidad') || null,
        pais_h: getHuespedField(1,'Pais') || null,
        parentesco: getHuespedField(1,'Parentesco') || null,
        tipo_pago:            document.getElementById('nrTipoPago').value            || null,
        metodo_pago:          document.getElementById('nrMetodoPago').value          || null,
        titular_pago:         document.getElementById('nrTitularPago').value         || null,
        fecha_caducidad_pago: document.getElementById('nrFechaCaducidadPago').value  || null,
        fecha_pago:           document.getElementById('nrFechaPago').value           || null
      };

      const saveBtn = document.getElementById('nrBtnGuardar');
      const origText = saveBtn.innerHTML;
      saveBtn.disabled = true;
      saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando…';

      fetch('/propiedades/' + viviendaIdGlobal + '/reservas', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      .then(function(r){ return r.json(); })
      .then(function(d) {
        saveBtn.disabled = false; saveBtn.innerHTML = origText;
        if (d.success) {
          closeNewReservationModal();
          // Reset form fields
          ['nrFechaInicio','nrFechaFin','nrImporte','nrIdExterno'].forEach(function(id) {
            const el = document.getElementById(id); if (el) el.value = '';
          });
          document.getElementById('nrHoraLlegada').value = '15:00';
          document.getElementById('nrHoraSalida').value = '11:00';
          document.getElementById('nrCheckinRealizado').checked = false;
          document.getElementById('nrCheckoutRealizado').checked = false;
          document.getElementById('nrPagado').checked = false;
          document.getElementById('nrHuespedesContainer').innerHTML = '';
          ['nrTipoPago','nrMetodoPago','nrTitularPago','nrFechaCaducidadPago','nrFechaPago'].forEach(function(fid){ const el=document.getElementById(fid); if(el) el.value=''; });
          // Recargar reservas Y transacciones desde BD para consistencia total
          Promise.all([recargarReservas(), recargarTransacciones()]).then(function() {
            showToast('Reserva creada correctamente', 'success');
            if (d.transaccionAutoCreada) {
              var mesStr = new Date(d.transaccionAutoCreada.fecha).toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });
              setTimeout(function() {
                showToast('💰 Ingreso de ' + parseFloat(d.transaccionAutoCreada.importe).toFixed(2) + ' € registrado en ' + mesStr, 'success');
              }, 1500);
            }
          });
        } else {
          showToast(d.error || 'Error al guardar la reserva', 'error');
        }
      })
      .catch(function() {
        saveBtn.disabled = false; saveBtn.innerHTML = origText;
        showToast('Error de conexión', 'error');
      });
    }

    function parteSection(title, rows) {
      return `<div style="margin-bottom:1.25rem;border:1px solid #e2e8f0;border-radius:.5rem;overflow:hidden;">${
        `<div style="background:#f8fafc;padding:0.5rem 1rem;font-weight:700;font-size:.8rem;border-bottom:1px solid #e2e8f0;">${title}</div>`
      }<table style="width:100%;border-collapse:collapse;font-size:.8rem;">${
        rows.map(([k,v]) => `<tr style="border-bottom:1px solid #f1f5f9;"><td style="padding:.4rem 1rem;color:#64748b;width:45%;font-weight:500;">${k}</td><td style="padding:.4rem 1rem;color:#1a2332;">${v}</td></tr>`).join('')
      }</table></div>`;
    }

    function exportarParteViajeros(idx) {
      const r = reservasGestion[idx]; if (!r) return;
      const fmt = d => d ? new Date(d).toLocaleDateString('es-ES') : '—';
      const sexoMap = { M: 'Masculino', F: 'Femenino', O: 'Otro' };

      // Fetch all guests then build PDF
      fetch('/propiedades/' + viviendaIdGlobal + '/reservas/' + r.id + '/huespedes')
        .then(function(res){ return res.json(); })
        .then(function(data) {
          const huespedes = (data.success && data.huespedes && data.huespedes.length)
            ? data.huespedes
            : [{
                nombre: r.nombre_huesped, apellidos: r.apellidos_huesped,
                dni: r.dni, tipo_documento: r.tipo_documento,
                fecha_expedicion_documento: r.fecha_expedicion,
                fecha_nacimiento: r.fecha_nacimiento, sexo: r.sexo,
                nacionalidad: r.nacionalidad, telefono: r.telefono, email: r.email,
                direccion: '', localidad: '', pais: '', parentesco: ''
              }];

          const viajerosHTML = huespedes.map(function(h, i) {
            return parteSection('3.' + (i+1) + '. Datos del Viajero ' + (huespedes.length > 1 ? (i+1) : ''),[
