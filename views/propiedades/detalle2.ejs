    function saveTask() {
      const descEl = document.getElementById('taskDescription');
      const desc = descEl.value.trim();
      if (!desc) {
        descEl.classList.add('input-error');
        descEl.addEventListener('input', function h(){ descEl.classList.remove('input-error'); descEl.removeEventListener('input', h); });
        showToast('La descripción de la tarea es obligatoria.', 'error');
        return;
