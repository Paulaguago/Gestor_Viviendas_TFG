                  <div class="ficha-item">
                    <div class="c-stat-icon" style="background:#D1FAE5;color:#065f46;"><i class="fas fa-users"></i></div>
                    <span class="ficha-value"><%= vivienda.capacidad_maxima != null ? vivienda.capacidad_maxima : '—' %></span>
                    <span class="ficha-label">Capacidad</span>
                    <button class="btn-edit-field" data-field="capacidad_maxima" data-value="<%= vivienda.capacidad_maxima != null ? vivienda.capacidad_maxima : '' %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
                  </div>
                  <div class="ficha-item">
                    <div class="c-stat-icon" style="background:#FEF3C7;color:#92400E;"><i class="fas fa-ruler-combined"></i></div>
                    <span class="ficha-value" style="font-size:1.2rem!important;"><%= vivienda.superficie ? vivienda.superficie + 'm²' : '—' %></span>
                    <span class="ficha-label">Superficie</span>
                    <button class="btn-edit-field" data-field="superficie" data-value="<%= vivienda.superficie || '' %>" onclick="startEditField(this)" title="Editar"><i class="fas fa-pen"></i></button>
