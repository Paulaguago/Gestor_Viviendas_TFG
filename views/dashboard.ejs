<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Dashboard - Gestor Viviendas' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    
    <%- include('partials/navbar') %>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar Izquierdo (1/4 de la pantalla) -->
            <aside class="col-lg-3 col-md-4 sidebar-dashboard">
                <div class="sidebar-content">
                    <h5 class="sidebar-title">Calendario</h5>
                    
                    <!-- Mini Calendario dinámico -->
                    <div id="miniCalendarContainer">
                        <!-- El calendario se genera dinámicamente con JavaScript -->
                    </div>

                            <div class="mt-4">
                        <h6 class="sidebar-subtitle">Resumen Rápido</h6>
                        <div class="card summary-card">
                            <div class="card-body">
                                <div class="summary-item">
                                    <span class="summary-label">Propiedades activas</span>
                                    <span class="summary-value"><%= stats.totalViviendas %></span>
                                </div>
                                <div class="summary-item">
                                    <span class="summary-label">Reservas totales</span>
                                    <span class="summary-value text-success"><%= stats.totalReservas %></span>
                                </div>
                                <div class="summary-item">
                                    <span class="summary-label">Incidencias</span>
                                    <span class="summary-value <%= stats.incidenciasPendientes > 0 ? 'text-danger' : 'text-success' %>"><%= stats.incidenciasPendientes %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- Panel Principal (3/4 de la pantalla) -->
            <main class="col-lg-9 col-md-8 main-content">
                <div class="content-wrapper">
                    <!-- Header del Dashboard -->
                    <div class="dashboard-header">
                        <h2>Bienvenido de nuevo, <span class="text-primary"><%= user ? user.nombre : 'Usuario' %></span></h2>
                        <p class="text-muted">Resumen de tu actividad y próximas reservas</p>
                    </div>

                    <!-- Tarjetas de Estadísticas -->
                    <div class="row stats-row mb-4">
                        <div class="col-lg-3 col-md-6 mb-3">
                            <div class="card stat-card">
                                <div class="card-body">
                                    <div class="stat-icon bg-primary">
                                        <i class="bi bi-calendar-check"></i>
                                    </div>
                                    <h6>Próximas Reservas</h6>
                                    <h3><%= stats.proximasReservas %></h3>
                                    <small class="text-muted">En los próximos 7 días</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-3">
                            <div class="card stat-card">
                                <div class="card-body">
                                    <div class="stat-icon bg-success">
                                        <i class="bi bi-currency-euro"></i>
                                    </div>
                                    <h6>Ingresos del Mes</h6>
                                    <h3><%= stats.ingresosMes %>€</h3>
                                    <small class="text-muted">Mes actual</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-3">
                            <div class="card stat-card">
                                <div class="card-body">
                                    <div class="stat-icon bg-warning">
                                        <i class="bi bi-exclamation-triangle"></i>
                                    </div>
                                    <h6>Tareas Pendientes</h6>
                                    <h3><%= stats.tareasPendientes %></h3>
                                    <small class="text-muted"><%= stats.tareasPendientes === 0 ? 'Sin tareas pendientes' : 'Revisar tareas' %></small>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-3">
                            <div class="card stat-card">
                                <div class="card-body">
                                    <div class="stat-icon bg-info">
                                        <i class="bi bi-house-door"></i>
                                    </div>
                                    <h6>Propiedades Activas</h6>
                                    <h3><%= stats.totalViviendas %></h3>
                                    <small class="text-muted"><%= stats.totalViviendas === 0 ? 'Añade tu primera propiedad' : 'Total de viviendas' %></small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Sección de Próximas Reservas -->
                    <div class="card reservas-card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="bi bi-calendar-event me-2"></i>Próximas Reservas</h5>
                            <a href="/reservas" class="btn btn-sm btn-outline-primary">Ver todas</a>
                        </div>
                        <div class="card-body">
                            <% if (listaProximasReservas && listaProximasReservas.length > 0) { %>
                                <div class="reservas-scroll-container">
                                    <% listaProximasReservas.forEach(reserva => { 
                                        const fechaInicio = new Date(reserva.fecha_inicio);
                                        const fechaFin = new Date(reserva.fecha_fin);
                                        const dia = fechaInicio.getDate();
                                        const mes = fechaInicio.toLocaleDateString('es-ES', { month: 'short' }).toUpperCase();
                                        const horaInicio = '15:00'; // Por defecto
                                        const horaFin = '11:00'; // Por defecto
                                        const noches = Math.ceil((fechaFin - fechaInicio) / (1000 * 60 * 60 * 24));
                                        const estado = reserva.estado || 'Confirmada';
                                        const estadoClass = estado === 'Confirmada' ? 'bg-success' : (estado === 'Pendiente' ? 'bg-warning' : 'bg-info');
                                    %>
                                    <div class="reserva-card">
                                        <div class="reserva-fecha">
                                            <div class="fecha-badge">
                                                <span class="dia"><%= dia %></span>
                                                <span class="mes"><%= mes %></span>
                                            </div>
                                        </div>
                                        <div class="reserva-info">
                                            <h6><%= reserva.Vivienda.direccion %></h6>
                                            <p class="mb-1"><i class="bi bi-moon-stars"></i> <%= noches %> <%= noches === 1 ? 'noche' : 'noches' %></p>
                                            <small class="text-muted">
                                                Check-in: <%= fechaInicio.toLocaleDateString('es-ES', { day: 'numeric', month: 'short' }) %> <%= horaInicio %> - 
                                                Check-out: <%= fechaFin.toLocaleDateString('es-ES', { day: 'numeric', month: 'short' }) %> <%= horaFin %>
                                            </small>
                                        </div>
                                        <div class="reserva-estado">
                                            <span class="badge <%= estadoClass %>"><%= estado %></span>
                                            <% if (reserva.precio_total) { %>
                                            <p class="reserva-precio mb-0"><%= reserva.precio_total %>€</p>
                                            <% } %>
                                        </div>
                                    </div>
                                    <% }); %>
                                </div>
                            <% } else { %>
                                <div class="empty-state text-center py-5">
                                    <i class="bi bi-calendar-x" style="font-size: 3rem; color: #6c757d; opacity: 0.5;"></i>
                                    <p class="mt-3 text-muted mb-0">Aún no tienes reservas pendientes</p>
                                    <small class="text-muted">Las reservas de los próximos 7 días aparecerán aquí</small>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Sección adicional: Alertas y Tareas -->
                    <div class="row mt-4">
                        <div class="col-lg-6 mb-3">
                            <div class="card">
                                <div class="card-header">
                                    <h6 class="mb-0"><i class="bi bi-bell me-2"></i>Notificaciones Recientes</h6>
                                </div>
                                <div class="card-body">
                                    <% if (notificaciones && notificaciones.length > 0) { %>
                                        <% notificaciones.forEach(notif => { %>
                                        <div class="notification-item">
                                            <i class="bi <%= notif.icono %> text-<%= notif.color %>"></i>
                                            <span><%= notif.mensaje %></span>
                                            <small><%= notif.tiempo %></small>
                                        </div>
                                        <% }); %>
                                    <% } else { %>
                                        <div class="empty-state text-center py-4">
                                            <i class="bi bi-bell-slash" style="font-size: 2.5rem; color: #6c757d; opacity: 0.5;"></i>
                                            <p class="mt-3 text-muted mb-0">No hay notificaciones recientes</p>
                                            <small class="text-muted">Las actualizaciones aparecerán aquí</small>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6 mb-3">
                            <div class="card">
                                <div class="card-header">
                                    <h6 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Rendimiento del Mes</h6>
                                </div>
                                <div class="card-body">
                                    <p class="text-muted small">Ocupación general:</p>
                                    <div class="performance-item">
                                        <span class="property-name">Porcentaje de ocupación</span>
                                        <span class="badge <%= stats.ocupacion >= 80 ? 'bg-success' : (stats.ocupacion >= 50 ? 'bg-warning' : 'bg-secondary') %>">
                                            <%= stats.ocupacion %>%
                                        </span>
                                    </div>
                                    <% if (stats.totalViviendas === 0) { %>
                                    <small class="text-muted">Añade propiedades y reservas para ver estadísticas</small>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/calendar.js"></script>
</body>
</html>
