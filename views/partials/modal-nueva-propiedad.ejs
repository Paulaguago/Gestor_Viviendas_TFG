<!-- Modal: Nueva Propiedad -->
<style>
  :root {
    --np-navy:   #1a2332;
    --np-navy2:  #141d28;
    --np-red:    #ef4444;
    --np-border: #e2e8f0;
    --np-bg:     #f8fafc;
    --np-label:  #374151;
    --np-muted:  #6b7280;
  }
  .np-input {
    width: 100%; padding: .55rem .875rem; font-size: .875rem; color: #1e293b;
    background: #fff; border: 1.5px solid var(--np-border); border-radius: .5rem;
    outline: none; transition: border-color .18s, box-shadow .18s; box-sizing: border-box;
  }
  .np-input:focus { border-color: var(--np-navy); box-shadow: 0 0 0 3px rgba(26,35,50,.09); }
  .np-input::placeholder { color: #94a3b8; }
  .np-label {
    display: flex; align-items: center; gap: .4rem;
    font-size: .8rem; font-weight: 600; color: var(--np-label); margin-bottom: .35rem;
  }
  .np-label i { color: var(--np-navy); font-size: .7rem; }
  .np-card { background: #fff; border: 1.5px solid var(--np-border); border-radius: .875rem; overflow: hidden; }
  .np-card-header {
    display: flex; align-items: center; gap: .5rem;
    padding: .6rem 1.125rem; background: var(--np-bg); border-bottom: 1.5px solid var(--np-border);
    font-size: .72rem; font-weight: 700; color: var(--np-navy);
    text-transform: uppercase; letter-spacing: .05em;
  }
  .np-card-header i { font-size: .68rem; opacity: .65; }
  .np-card-body { padding: 1.125rem; display: flex; flex-direction: column; gap: .875rem; }
  .np-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: .875rem; }
  .np-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: .875rem; }
  .np-grid-4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: .75rem; }
  @media (max-width: 540px) { .np-grid-2,.np-grid-3,.np-grid-4 { grid-template-columns: 1fr; } }
  @media (min-width:541px) and (max-width:720px) { .np-grid-3 { grid-template-columns:1fr 1fr; } .np-grid-4 { grid-template-columns:1fr 1fr; } }
  .np-select-wrap { position: relative; }
  .np-select-wrap select { appearance: none; padding-right: 2rem; }
  .np-chevron { position: absolute; right: .75rem; top: 50%; transform: translateY(-50%); pointer-events: none; color: #94a3b8; font-size: .6rem; }
  .np-price-box { background: linear-gradient(135deg,#eff6ff,#f0fdf4); border: 1.5px solid #bfdbfe; border-radius: .75rem; padding: 1rem 1.125rem; }
  .np-price-box .np-label { color: #1e40af; margin-bottom: .5rem; }
  .np-price-box .np-label i { color: #1e40af; }
  .np-price-wrap { position: relative; }
  .np-currency { position: absolute; left: .875rem; top: 50%; transform: translateY(-50%); font-weight: 700; color: #1e40af; pointer-events: none; }
  .np-price-input { width:100%; padding:.65rem .875rem .65rem 2.25rem; font-size:1.2rem; font-weight:700; color:#1e40af; background:#fff; border:1.5px solid #bfdbfe; border-radius:.5rem; outline:none; transition:border-color .18s,box-shadow .18s; box-sizing:border-box; }
  .np-price-input:focus { border-color:#3b82f6; box-shadow:0 0 0 3px rgba(59,130,246,.12); }
  .np-price-input::placeholder { color:#93c5fd; font-weight:400; }
  .np-upload { display:block; border:2px dashed #cbd5e1; border-radius:.75rem; padding:1.5rem; text-align:center; cursor:pointer; background:var(--np-bg); transition:border-color .2s,background .2s; }
  .np-upload:hover { border-color:var(--np-navy); background:#f1f5f9; }
  .np-upload i { font-size:1.6rem; color:#94a3b8; display:block; margin-bottom:.4rem; transition:color .2s; }
  .np-upload:hover i { color:var(--np-navy); }
  .np-upload-title { font-size:.875rem; font-weight:700; color:#334155; }
  .np-upload-sub { font-size:.75rem; color:#94a3b8; margin-top:.15rem; }
  .np-amenities-btn { width:100%; padding:.6rem 1rem; font-size:.875rem; font-weight:600; border:1.5px solid var(--np-navy); color:var(--np-navy); background:#fff; border-radius:.5rem; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:.5rem; transition:background .18s,color .18s; }
  .np-amenities-btn:hover { background:var(--np-navy); color:#fff; }
  .np-divider { display:flex; align-items:center; gap:.6rem; font-size:.68rem; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:.06em; }
  .np-divider::before,.np-divider::after { content:''; flex:1; height:1px; background:var(--np-border); }
  .np-btn-prev { display:flex; align-items:center; gap:.4rem; padding:.5rem 1.125rem; font-size:.875rem; font-weight:600; border:1.5px solid var(--np-border); color:#64748b; background:#fff; border-radius:.625rem; cursor:pointer; transition:all .18s; }
  .np-btn-prev:hover { border-color:#94a3b8; color:#374151; background:var(--np-bg); }
  .np-btn-next { display:flex; align-items:center; gap:.4rem; padding:.5rem 1.25rem; font-size:.875rem; font-weight:700; background:var(--np-navy); color:#fff; border:none; border-radius:.625rem; cursor:pointer; transition:background .18s; }
  .np-btn-next:hover { background:var(--np-navy2); }
  .np-btn-save { display:flex; align-items:center; gap:.4rem; padding:.5rem 1.25rem; font-size:.875rem; font-weight:700; background:#059669; color:#fff; border:none; border-radius:.625rem; cursor:pointer; transition:background .18s; }
  .np-btn-save:hover { background:#047857; }
  .np-btn-prev.hidden, .np-btn-next.hidden, .np-btn-save.hidden { display:none !important; }
</style>

<div id="modalNuevaPropiedad" class="modal-overlay">
  <div style="display:flex;flex-direction:row;width:100%;max-width:900px;background:#fff;border-radius:1rem;box-shadow:0 24px 60px rgba(0,0,0,.22);overflow:hidden;max-height:90vh;height:86vh;min-height:580px;margin:auto;">

    <!-- Sidebar -->
    <div style="width:214px;flex-shrink:0;background:var(--np-navy);display:flex;flex-direction:column;gap:1.25rem;padding:1.5rem 1.125rem;overflow-y:auto;">
      <!-- Logo / title -->
      <div>
        <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1rem;">
          <div style="width:2.375rem;height:2.375rem;border-radius:.5rem;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <i class="fas fa-home" style="color:#fff;font-size:.9375rem;"></i>
          </div>
          <div>
            <p style="font-size:.9375rem;font-weight:700;color:#fff;margin:0;line-height:1.2;">Nueva Propiedad</p>
            <p style="font-size:.7rem;color:rgba(255,255,255,.45);margin:0;">Formulario de alta</p>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:.625rem;">
          <div style="flex:1;height:.25rem;background:rgba(255,255,255,.15);border-radius:99px;overflow:hidden;">
            <div id="progressBar" style="height:100%;width:25%;background:#fff;border-radius:99px;transition:width .35s ease;"></div>
          </div>
          <span id="progressText" style="font-size:.7rem;font-weight:700;color:rgba(255,255,255,.65);white-space:nowrap;">Paso 1/4</span>
        </div>
      </div>

      <!-- Desktop nav -->
      <div style="display:flex;flex-direction:column;gap:.2rem;position:relative;">
        <div style="position:absolute;left:17px;top:40px;bottom:40px;width:2px;background:rgba(255,255,255,.12);"></div>
        <div id="progressLine" style="position:absolute;left:17px;top:40px;width:2px;height:0;background:rgba(255,255,255,.45);transition:height .35s ease;"></div>

        <button type="button" class="step-nav" data-step="1" onclick="goToStep(1)"
          style="display:flex;align-items:center;gap:.625rem;background:transparent;border:none;padding:.4rem .5rem;border-radius:.5rem;cursor:pointer;text-align:left;transition:background .15s;width:100%;">
          <div class="step-circle" style="width:2rem;height:2rem;border-radius:.5rem;background:rgba(255,255,255,.18);color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;z-index:1;">
            <i class="fas fa-house" style="font-size:.75rem;"></i>
            <i class="fas fa-check" style="font-size:.75rem;display:none;"></i>
          </div>
          <div style="min-width:0;">
            <p class="step-title" style="font-size:.8rem;font-weight:700;color:#fff;margin:0;line-height:1.2;">Datos Básicos</p>
            <p style="font-size:.68rem;color:rgba(255,255,255,.5);margin:0;">Información principal</p>
          </div>
        </button>

        <button type="button" class="step-nav" data-step="2" disabled onclick="goToStep(2)"
          style="display:flex;align-items:center;gap:.625rem;background:transparent;border:none;padding:.4rem .5rem;border-radius:.5rem;cursor:pointer;text-align:left;opacity:.45;transition:all .15s;width:100%;">
          <div class="step-circle" style="width:2rem;height:2rem;border-radius:.5rem;background:rgba(255,255,255,.1);color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;z-index:1;">
            <i class="fas fa-map-location-dot" style="font-size:.75rem;"></i>
            <i class="fas fa-check" style="font-size:.75rem;display:none;"></i>
          </div>
          <div style="min-width:0;">
            <p class="step-title" style="font-size:.8rem;font-weight:700;color:rgba(255,255,255,.65);margin:0;line-height:1.2;">Ubicación</p>
            <p style="font-size:.68rem;color:rgba(255,255,255,.35);margin:0;">Dirección y mapa</p>
          </div>
        </button>

        <button type="button" class="step-nav" data-step="3" disabled onclick="goToStep(3)"
          style="display:flex;align-items:center;gap:.625rem;background:transparent;border:none;padding:.4rem .5rem;border-radius:.5rem;cursor:pointer;text-align:left;opacity:.45;transition:all .15s;width:100%;">
          <div class="step-circle" style="width:2rem;height:2rem;border-radius:.5rem;background:rgba(255,255,255,.1);color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;z-index:1;">
            <i class="fas fa-tag" style="font-size:.75rem;"></i>
            <i class="fas fa-check" style="font-size:.75rem;display:none;"></i>
          </div>
          <div style="min-width:0;">
            <p class="step-title" style="font-size:.8rem;font-weight:700;color:rgba(255,255,255,.65);margin:0;line-height:1.2;">Marketing</p>
            <p style="font-size:.68rem;color:rgba(255,255,255,.35);margin:0;">Precios y plataformas</p>
          </div>
        </button>

        <button type="button" class="step-nav" data-step="4" disabled onclick="goToStep(4)"
          style="display:flex;align-items:center;gap:.625rem;background:transparent;border:none;padding:.4rem .5rem;border-radius:.5rem;cursor:pointer;text-align:left;opacity:.45;transition:all .15s;width:100%;">
          <div class="step-circle" style="width:2rem;height:2rem;border-radius:.5rem;background:rgba(255,255,255,.1);color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;z-index:1;">
            <i class="fas fa-file-contract" style="font-size:.75rem;"></i>
            <i class="fas fa-check" style="font-size:.75rem;display:none;"></i>
          </div>
          <div style="min-width:0;">
            <p class="step-title" style="font-size:.8rem;font-weight:700;color:rgba(255,255,255,.65);margin:0;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">Documentación</p>
            <p style="font-size:.68rem;color:rgba(255,255,255,.35);margin:0;">Información legal</p>
          </div>
        </button>
      </div>

      <!-- Mobile nav (hidden on desktop via JS/CSS from propiedades.js) -->
      <div class="md:hidden" style="display:none;">
        <div style="display:flex;gap:.5rem;overflow-x:auto;padding-bottom:.25rem;">
          <button type="button" class="step-nav-mobile" data-step="1" onclick="goToStep(1)" style="background:transparent;border:none;display:flex;flex-direction:column;align-items:center;gap:.25rem;flex-shrink:0;">
            <div class="step-circle-mobile" style="width:2.125rem;height:2.125rem;border-radius:.5rem;background:rgba(255,255,255,.15);color:#fff;display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-house" style="font-size:.68rem;"></i>
              <i class="fas fa-check" style="font-size:.68rem;display:none;"></i>
            </div>
            <span style="font-size:.55rem;font-weight:800;text-transform:uppercase;color:#fff;letter-spacing:.02em;">Datos</span>
          </button>
          <button type="button" class="step-nav-mobile" data-step="2" disabled onclick="goToStep(2)" style="background:transparent;border:none;display:flex;flex-direction:column;align-items:center;gap:.25rem;flex-shrink:0;opacity:.4;">
            <div class="step-circle-mobile" style="width:2.125rem;height:2.125rem;border-radius:.5rem;background:rgba(255,255,255,.1);color:#fff;display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-map-location-dot" style="font-size:.68rem;"></i>
              <i class="fas fa-check" style="font-size:.68rem;display:none;"></i>
            </div>
            <span style="font-size:.55rem;font-weight:800;text-transform:uppercase;color:rgba(255,255,255,.5);letter-spacing:.02em;">Ubicación</span>
          </button>
          <button type="button" class="step-nav-mobile" data-step="3" disabled onclick="goToStep(3)" style="background:transparent;border:none;display:flex;flex-direction:column;align-items:center;gap:.25rem;flex-shrink:0;opacity:.4;">
            <div class="step-circle-mobile" style="width:2.125rem;height:2.125rem;border-radius:.5rem;background:rgba(255,255,255,.1);color:#fff;display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-tag" style="font-size:.68rem;"></i>
              <i class="fas fa-check" style="font-size:.68rem;display:none;"></i>
            </div>
            <span style="font-size:.55rem;font-weight:800;text-transform:uppercase;color:rgba(255,255,255,.5);letter-spacing:.02em;">Marketing</span>
          </button>
          <button type="button" class="step-nav-mobile" data-step="4" disabled onclick="goToStep(4)" style="background:transparent;border:none;display:flex;flex-direction:column;align-items:center;gap:.25rem;flex-shrink:0;opacity:.4;">
            <div class="step-circle-mobile" style="width:2.125rem;height:2.125rem;border-radius:.5rem;background:rgba(255,255,255,.1);color:#fff;display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-file-contract" style="font-size:.68rem;"></i>
              <i class="fas fa-check" style="font-size:.68rem;display:none;"></i>
            </div>
            <span style="font-size:.55rem;font-weight:800;text-transform:uppercase;color:rgba(255,255,255,.5);letter-spacing:.02em;">Legal</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Main content -->
    <div style="flex:1;display:flex;flex-direction:column;overflow:hidden;background:#fff;min-width:0;">

      <!-- Top bar -->
      <div style="padding:1rem 1.625rem;border-bottom:1.5px solid var(--np-border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
        <div>
          <h3 id="stepTitle" style="font-size:1rem;font-weight:700;color:var(--np-navy);margin:0;line-height:1.2;">Información Básica de la Propiedad</h3>
          <p id="stepSubtitle" style="font-size:.78rem;color:var(--np-muted);margin:.2rem 0 0;">Complete los datos principales de su propiedad</p>
        </div>
        <button type="button" onclick="cerrarModalNuevaPropiedad()"
          style="width:2rem;height:2rem;border-radius:.5rem;background:var(--np-bg);border:1.5px solid var(--np-border);display:flex;align-items:center;justify-content:center;color:var(--np-muted);cursor:pointer;transition:all .18s;flex-shrink:0;"
          onmouseover="this.style.background='#e2e8f0';this.style.color='#374151';"
          onmouseout="this.style.background='var(--np-bg)';this.style.color='var(--np-muted)';">
          <i class="fas fa-times" style="font-size:.75rem;"></i>
        </button>
      </div>

      <!-- Scrollable form -->
      <div style="flex:1;overflow-y:auto;padding:1.375rem 1.625rem;">
        <form id="formNuevaPropiedad" action="/propiedades/" method="POST" enctype="multipart/form-data">

          <!-- ══ PASO 1 ══ -->
          <div id="step-1" class="step-content" style="display:flex;flex-direction:column;gap:1.125rem;">

            <div class="np-card">
              <div class="np-card-header"><i class="fas fa-signature"></i> Identificación</div>
              <div class="np-card-body">
                <div>
                  <label class="np-label"><i class="fas fa-signature"></i> Nombre de la Propiedad <span style="color:var(--np-red);">*</span></label>
                  <input type="text" name="nombre" required class="np-input" placeholder="Ej: Apartamento céntrico en Madrid">
                </div>
                <div class="np-grid-2">
                  <div>
                    <label class="np-label"><i class="fas fa-tag"></i> Categoría <span style="color:var(--np-red);">*</span></label>
                    <div class="np-select-wrap">
                      <select name="categoria" required class="np-input">
                        <option value="" disabled selected>Seleccionar Categoría</option>
                        <option value="Apartamento Turístico">Apartamento Turístico</option>
                        <option value="Vivienda Turística">Vivienda Turística</option>
                        <option value="Vivienda de Uso Turístico">Vivienda de Uso Turístico</option>
                        <option value="Casa Rural">Casa Rural</option>
                      </select>
                      <i class="fas fa-chevron-down np-chevron"></i>
                    </div>
                  </div>
                  <div>
                    <label class="np-label"><i class="fas fa-building"></i> Tipo de Vivienda <span style="color:var(--np-red);">*</span></label>
                    <div class="np-select-wrap">
                      <select name="tipo_vivienda" required class="np-input">
                        <option value="" disabled selected>Seleccionar</option>
                        <option value="Apartamento">Apartamento</option>
                        <option value="Chalet">Chalet</option>
                        <option value="Adosado">Adosado</option>
                        <option value="Pareado">Pareado</option>
                        <option value="Loft">Loft</option>
                        <option value="Estudio">Estudio</option>
                        <option value="Ático">Ático</option>
                        <option value="Dúplex">Dúplex</option>
                        <option value="Casa">Casa</option>
                        <option value="Villa">Villa</option>
                        <option value="Bungalow">Bungalow</option>
                      </select>
                      <i class="fas fa-chevron-down np-chevron"></i>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="np-card">
              <div class="np-card-header"><i class="fas fa-ruler-combined"></i> Métricas y Capacidad</div>
              <div class="np-card-body">
                <div class="np-grid-3">
                  <div>
                    <label class="np-label"><i class="fas fa-users"></i> Capacidad <span style="color:var(--np-red);">*</span></label>
                    <input type="number" name="capacidad_maxima" required min="1" class="np-input" placeholder="4" onkeydown="if(['-','+','e','E','.',','].includes(event.key)) event.preventDefault();">
                  </div>
                  <div>
                    <label class="np-label"><i class="fas fa-bed"></i> Dormitorios <span style="color:var(--np-red);">*</span></label>
                    <input type="number" name="num_habitaciones" required min="0" class="np-input" placeholder="2" onkeydown="if(['-','+','e','E','.',','].includes(event.key)) event.preventDefault();">
                  </div>
                  <div>
                    <label class="np-label"><i class="fas fa-bath"></i> Baños <span style="color:var(--np-red);">*</span></label>
                    <input type="number" name="num_banos" required min="0" class="np-input" placeholder="1" onkeydown="if(['-','+','e','E','.',','].includes(event.key)) event.preventDefault();">
                  </div>
                </div>
                <div class="np-grid-3">
                  <div>
                    <label class="np-label"><i class="fas fa-ruler-combined"></i> Superficie (m²) <span style="color:var(--np-red);">*</span></label>
                    <input type="number" name="superficie" required min="1" class="np-input" placeholder="75" onkeydown="if(['-','+','e','E','.',','].includes(event.key)) event.preventDefault();">
                  </div>
                  <div>
                    <label class="np-label"><i class="fas fa-tree"></i> Parcela (m²)</label>
                    <input type="number" name="superficie_parcela" min="0" class="np-input" placeholder="Opcional" onkeydown="if(['-','+','e','E','.',','].includes(event.key)) event.preventDefault();">
                  </div>
                  <div>
                    <label class="np-label"><i class="fas fa-calendar"></i> Año construcción</label>
                    <input type="number" name="ano_construccion" min="1800" max="2030" class="np-input" placeholder="2005" onkeydown="if(['-','+','e','E','.',','].includes(event.key)) event.preventDefault();">
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- ══ PASO 2 ══ -->
          <div id="step-2" class="step-content hidden" style="display:none;flex-direction:column;gap:1.125rem;">

            <div class="np-card">
              <div class="np-card-header"><i class="fas fa-map-pin"></i> Dirección</div>
              <div class="np-card-body">
                <div>
                  <label class="np-label"><i class="fas fa-road"></i> Calle <span style="color:var(--np-red);">*</span></label>
                  <input type="text" name="calle" required class="np-input" placeholder="Calle Mayor, 1">
                </div>
                <div class="np-grid-4">
                  <div>
                    <label class="np-label"><i class="fas fa-door-open"></i> Bloque</label>
                    <input type="text" name="bloque_portal" class="np-input" placeholder="B">
                  </div>
                  <div>
                    <label class="np-label"><i class="fas fa-stairs"></i> Escalera</label>
                    <input type="number" name="escalera" min="0" class="np-input" placeholder="2" onkeydown="if(['-','+','e','E','.',','].includes(event.key)) event.preventDefault();">
                  </div>
                  <div>
                    <label class="np-label"><i class="fas fa-layer-group"></i> Piso</label>
                    <input type="number" name="piso" min="0" class="np-input" placeholder="3" onkeydown="if(['-','+','e','E','.',','].includes(event.key)) event.preventDefault();">
                  </div>
                  <div>
                    <label class="np-label"><i class="fas fa-hashtag"></i> Puerta</label>
                    <input type="text" name="letra_numero" class="np-input" placeholder="A">
                  </div>
                </div>
                <input type="hidden" name="direccion" value="">
                <div class="np-grid-3">
                  <div>
                    <label class="np-label"><i class="fas fa-city"></i> Ciudad <span style="color:var(--np-red);">*</span></label>
                    <input type="text" name="ciudad" required class="np-input" placeholder="Madrid">
                  </div>
                  <div>
                    <label class="np-label"><i class="fas fa-envelope"></i> Código Postal</label>
                    <input type="number" name="codigo_postal" min="0" class="np-input" placeholder="28001" onkeydown="if(['-','+','e','E','.',','].includes(event.key)) event.preventDefault();">
                  </div>
                  <div>
                    <label class="np-label"><i class="fas fa-globe"></i> País <span style="color:var(--np-red);">*</span></label>
                    <input type="text" name="pais" value="España" required class="np-input" placeholder="España">
                  </div>
                </div>
                <div>
                  <label class="np-label"><i class="fas fa-map-pin"></i> Barrio</label>
                  <input type="text" name="barrio" class="np-input" placeholder="Centro">
                </div>
              </div>
            </div>

            <div class="np-card">
              <div class="np-card-header"><i class="fas fa-search-location"></i> Localizar en el mapa</div>
              <div class="np-card-body">
                <div style="display:flex;gap:.625rem;">
                  <input type="text" id="buscarDireccion" class="np-input" style="flex:1;" placeholder="Escribe la dirección para localizar…">
                  <button type="button" onclick="buscarUbicacion()"
                    style="padding:.5rem 1.125rem;background:var(--np-navy);color:#fff;font-size:.875rem;font-weight:700;border-radius:.5rem;border:none;cursor:pointer;display:flex;align-items:center;gap:.4rem;white-space:nowrap;transition:background .18s;flex-shrink:0;"
                    onmouseover="this.style.background='var(--np-navy2)'"
                    onmouseout="this.style.background='var(--np-navy)'">
                    <i class="fas fa-search"></i> Buscar
                  </button>
                </div>
                <div id="mapa-nuevo" style="width:100%;height:340px;border-radius:.625rem;border:1.5px solid var(--np-border);overflow:hidden;"></div>
                <input type="hidden" name="latitud" id="latitudInput" step="0.00000001">
                <input type="hidden" name="longitud" id="longitudInput" step="0.00000001">
              </div>
            </div>
          </div>

          <!-- ══ PASO 3 ══ -->
          <div id="step-3" class="step-content hidden" style="display:none;flex-direction:column;gap:1.125rem;">

            <div class="np-card">
              <div class="np-card-header"><i class="fas fa-euro-sign"></i> Precio</div>
              <div class="np-card-body">
                <div class="np-price-box">
                  <label class="np-label"><i class="fas fa-euro-sign"></i> Precio por Noche</label>
                  <div class="np-price-wrap">
                    <span class="np-currency">€</span>
                    <input type="number" name="precio_alquiler" step="0.01" min="0" class="np-price-input" placeholder="50.00" onkeydown="if(['-','+','e','E'].includes(event.key)) event.preventDefault();" oninput="if(this.value < 0) this.value = Math.abs(this.value);">
                  </div>
                </div>
              </div>
            </div>

            <div class="np-card">
              <div class="np-card-header"><i class="fas fa-align-left"></i> Descripción e Imagen</div>
              <div class="np-card-body">
                <div>
                  <label class="np-label"><i class="fas fa-align-left"></i> Descripción</label>
                  <textarea name="descripcion" rows="4" class="np-input" style="resize:none;line-height:1.55;" placeholder="Describe tu propiedad…"></textarea>
                </div>
                <div>
                  <label class="np-label"><i class="fas fa-image"></i> Imagen Principal</label>
                  <label for="fileInput" class="np-upload">
                    <i class="fas fa-cloud-upload-alt"></i>
                    <input type="file" name="imagen" accept="image/*" class="hidden" id="fileInput">
                    <span class="np-upload-title">Arrastra o haz clic para subir</span>
                    <span id="fileInputName" class="np-upload-sub">JPG, PNG, GIF, WEBP</span>
                  </label>
                </div>
              </div>
            </div>

            <div class="np-card">
              <div class="np-card-header"><i class="fas fa-star"></i> Comodidades</div>
              <div class="np-card-body">
                <button type="button" class="np-amenities-btn" onclick="abrirModalComodidades()">
                  <i class="fas fa-plus-circle"></i> Seleccionar comodidades
                </button>
                <div id="selectedAmenitiesDisplay" style="display:flex;flex-wrap:wrap;gap:.4rem;position:relative;z-index:1;">
                  <span style="font-size:.75rem;color:#94a3b8;">No se han seleccionado</span>
                </div>
                <div id="hiddenAmenitiesInputs"></div>
              </div>
            </div>

            <div class="np-card">
              <div class="np-card-header"><i class="fas fa-link"></i> Plataformas Externas</div>
              <div class="np-card-body">
                <div class="np-divider">Anuncios</div>
                <div class="np-grid-2">
                  <div>
                    <label class="np-label"><i class="fab fa-airbnb" style="color:#FF5A5F;"></i> URL Airbnb</label>
                    <input type="url" name="url_airbnb" class="np-input" placeholder="https://airbnb.com/...">
                  </div>
                  <div>
                    <label class="np-label"><i class="fas fa-bed" style="color:#003580;"></i> URL Booking</label>
                    <input type="url" name="url_booking" class="np-input" placeholder="https://booking.com/...">
                  </div>
                </div>
                <div class="np-divider">Calendarios iCal</div>
                <div class="np-grid-2">
                  <div>
                    <label class="np-label"><i class="fas fa-calendar-alt"></i> iCal Airbnb</label>
                    <input type="url" name="url_ical_airbnb" class="np-input" placeholder="https://airbnb.com/calendar/ical/...">
                  </div>
                  <div>
                    <label class="np-label"><i class="fas fa-calendar-alt"></i> iCal Booking</label>
                    <input type="url" name="url_ical_booking" class="np-input" placeholder="https://booking.com/calendar/ical/...">
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- ══ PASO 4 ══ -->
          <div id="step-4" class="step-content hidden" style="display:none;flex-direction:column;gap:1.125rem;">
            <div class="np-card">
              <div class="np-card-header"><i class="fas fa-file-contract"></i> Información Legal</div>
              <div class="np-card-body">
                <div>
                  <label class="np-label"><i class="fas fa-gavel"></i> Estado Legal</label>
                  <div class="np-select-wrap">
                    <select name="estado_legal" class="np-input">
                      <option value="">Seleccionar</option>
                      <option value="Activa">Activa</option>
                      <option value="En trámite">En trámite</option>
                      <option value="No aplica">No aplica</option>
                    </select>
                    <i class="fas fa-chevron-down np-chevron"></i>
                  </div>
                </div>
                <div class="np-grid-2">
                  <div>
                    <label class="np-label"><i class="fas fa-map-marker-alt"></i> Ref. Catastral</label>
                    <input type="text" name="referencia_catastral" class="np-input" placeholder="1234567VK1234S0001AA">
                  </div>
                  <div>
                    <label class="np-label"><i class="fas fa-clipboard-check"></i> Nº Registro Turístico</label>
                    <input type="text" name="numero_registro_autonomico" class="np-input" placeholder="VUT-12345">
                  </div>
                </div>
                <div>
                  <label class="np-label"><i class="fas fa-calendar-check"></i> Fecha de Registro <span style="color:var(--np-red);">*</span></label>
                  <input type="date" name="fecha_registro" class="np-input" style="max-width:16rem;" required>
                </div>
              </div>
            </div>
          </div>

        </form>
      </div>

      <!-- Footer -->
      <div style="padding:.75rem 1.625rem;border-top:1.5px solid var(--np-border);display:flex;align-items:center;justify-content:space-between;gap:.75rem;background:#fff;flex-shrink:0;">
        <button type="button" id="btnPrev" onclick="previousStep()" class="np-btn-prev hidden">
          <i class="fas fa-arrow-left" style="font-size:.7rem;"></i>
          <span>Anterior</span>
        </button>
        <div style="flex:1;"></div>
        <button type="button" id="btnNext" onclick="nextStep()" class="np-btn-next">
          <span>Siguiente</span>
          <i class="fas fa-arrow-right" style="font-size:.7rem;"></i>
        </button>
        <button type="button" id="btnSave" onclick="submitNuevaPropiedad()" class="np-btn-save hidden">
          <i class="fas fa-check" style="font-size:.7rem;"></i>
          <span>Crear Propiedad</span>
        </button>
      </div>
    </div>
  </div>
</div>
<script>
  document.getElementById('fileInput').addEventListener('change', function() {
    const lbl = document.getElementById('fileInputName');
    if (this.files && this.files[0]) {
      lbl.textContent = this.files[0].name;
      lbl.style.color = '#059669';
      lbl.style.fontWeight = '600';
    } else {
      lbl.textContent = 'JPG, PNG, GIF, WEBP';
      lbl.style.color = '';
      lbl.style.fontWeight = '';
    }
  });
</script>
