                        </div>

                        <!-- Mapa -->
                        <div id="mapa-nuevo" style="width: 100%; height: 400px; border-radius: 0.5rem; box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.1); border: 2px solid #e5e7eb; margin: 1rem 0;"></div>

                        <!-- Coordenadas Ocultas -->
                        <input type="hidden" name="latitud" id="latitudInput" step="0.00000001">
                        <input type="hidden" name="longitud" id="longitudInput" step="0.00000001">
                        </div>
                    </div>

                    <!-- PASO 3: Marketing & Precio -->
                    <div id="step-3" class="step-content hidden" style="display: none; flex-direction: column; gap: 1rem;">
                        <div style="background: #f9fafb; padding: 1.5rem; border-radius: 0.75rem; display: flex; flex-direction: column; gap: 1rem;">
                        <!-- Precio destacado -->
                        <div style="background: #e0f2fe; padding: 1rem; border-radius: 0.5rem; border: 0.125rem solid #bae6fd;">
                            <label class="block text-sm font-bold mb-2 flex items-center gap-2" style="color: #0c4a6e;">
                                <i class="fas fa-euro-sign" style="color: #1a2332;"></i>
                                Precio por Noche
                            </label>
                            <div class="relative">
                                <input type="number" name="precio_alquiler" step="0.01" min="0" 
                                    class="w-full pl-12 pr-4 py-3 text-xl font-bold bg-white border-2 border-blue-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" 
                                    placeholder="50.00">
                            </div>
                        </div>

                        <!-- descripción -->
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-1.5 flex items-center gap-2">
                                <i class="fas fa-align-left text-blue-600"></i>
                                Descripción
                            </label>
                            <textarea name="descripcion" rows="4" 
                                class="w-full px-4 py-2.5 text-sm bg-white border-2 border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all resize-none" 
                                placeholder="Describe tu propiedad..."></textarea>
                        </div>

                        <!-- Imagen -->
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-2 flex items-center gap-2">
                                <i class="fas fa-image text-blue-600"></i>
                                Imagen Principal
                            </label>
                            <div class="border-2 border-dashed border-slate-300 rounded-lg p-6 text-center hover:border-blue-400 transition-all cursor-pointer bg-slate-50">
                                <i class="fas fa-cloud-upload-alt text-3xl text-slate-400 mb-3"></i>
                                <input type="file" name="imagen" accept="image/*" class="hidden" id="fileInput">
                                <label for="fileInput" class="block cursor-pointer">
                                    <span class="text-sm font-bold text-slate-700">Arrastra o haz clic</span>
                                    <span class="block text-xs text-slate-500 mt-1">JPG, PNG, GIF, WEBP</span>
                                </label>
                            </div>
                        </div>

                        <!--Comodidades -->
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-1.5 flex items-center gap-2">
                                <i class="fas fa-sparkles" style="color: #1a2332;"></i>
                                Comodidades
                            </label>
                            <button type="button" onclick="abrirModalComodidades()" 
                                style="width: 100%; padding: 0.625rem 1rem; font-size: 0.875rem; border: 0.125rem solid #1a2332; color: #1a2332; font-weight: 700; border-radius: 0.5rem; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 0.5rem; background: white; cursor: pointer;"
                                onmouseover="this.style.background='#1a2332'; this.style.color='white'"
                                onmouseout="this.style.background='white'; this.style.color='#1a2332'">
                                <i class="fas fa-sparkles"></i>
                                Seleccionar
                            </button>
                            <div id="selectedAmenitiesDisplay" class="mt-3 flex flex-wrap gap-2" style="position: relative; z-index: 1;">
                                <span class="text-xs text-slate-500">No se han seleccionado</span>
                            </div>
                            <div id="hiddenAmenitiesInputs"></div>
                        </div>

                        <!-- Separador -->
                        <div style="height: 1px; background: #e5e7eb; margin: 1rem 0;"></div>

                        <!-- URLs Plataformas -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-bold text-slate-700 mb-1.5 flex items-center gap-2">
                                    <i class="fab fa-airbnb" style="color: #FF5A5F;"></i>
                                    URL Airbnb
                                </label>
                                <input type="url" name="url_airbnb" 
                                    class="w-full px-4 py-2.5 text-sm bg-white border-2 border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" 
                                    placeholder="https://airbnb.com/...">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-slate-700 mb-1.5 flex items-center gap-2">
                                    <i class="fas fa-bed" style="color: #003580;"></i>
                                    URL Booking
                                </label>
                                <input type="url" name="url_booking" 
                                    class="w-full px-4 py-2.5 text-sm bg-white border-2 border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" 
                                    placeholder="https://booking.com/...">
                            </div>
                        </div>

                        <!-- URLs iCal -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-bold text-slate-700 mb-1.5 flex items-center gap-2">
                                    <i class="fas fa-calendar-alt text-blue-600"></i>
                                    iCal Airbnb
                                </label>
                                <input type="url" name="url_ical_airbnb" 
                                    class="w-full px-4 py-2.5 text-sm bg-white border-2 border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" 
                                    placeholder="https://airbnb.com/calendar/ical/...">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-slate-700 mb-1.5 flex items-center gap-2">
                                    <i class="fas fa-calendar-alt text-blue-600"></i>
                                    iCal Booking
                                </label>
                                <input type="url" name="url_ical_booking" 
                                    class="w-full px-4 py-2.5 text-sm bg-white border-2 border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" 
                                    placeholder="https://booking.com/calendar/ical/...">
                            </div>
                        </div>
                        </div>
                    </div>

                    <!-- PASO 4: Legal & Estado -->
                    <div id="step-4" class="step-content hidden" style="display: none; flex-direction: column; gap: 1rem;">
                        <div style="background: #f9fafb; padding: 1.5rem; border-radius: 0.75rem; display: flex; flex-direction: column; gap: 1rem;">
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-1.5 flex items-center gap-2">
                                <i class="fas fa-gavel text-blue-600"></i>
                                Estado Legal
                            </label>
                            <select name="estado_legal" class="w-full px-4 py-2.5 text-sm bg-white border-2 border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                                <option value="">Seleccionar</option>
                                <option value="Activa">Activa</option>
                                <option value="En trámite">En trámite</option>
                                <option value="No aplica">No aplica</option>
                            </select>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-bold text-slate-700 mb-1.5 flex items-center gap-2">
                                    <i class="fas fa-map-marker-alt text-blue-600"></i>
                                    Ref. Catastral
                                </label>
                                <input type="text" name="referencia_catastral" 
                                    class="w-full px-4 py-2.5 text-sm bg-white border-2 border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" 
                                    placeholder="1234567VK1234S0001AA">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-slate-700 mb-1.5 flex items-center gap-2">
                                    <i class="fas fa-clipboard-check text-blue-600"></i>
                                    Nº Registro
                                </label>
                                <input type="text" name="numero_registro_autonomico" 
                                    class="w-full px-4 py-2.5 text-sm bg-white border-2 border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" 
                                    placeholder="VUT-12345">
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-1.5 flex items-center gap-2">
                                <i class="fas fa-calendar-check text-blue-600"></i>
                                Fecha de Registro
                            </label>
                            <input type="date" name="fecha_registro" 
                                class="w-full px-4 py-2.5 text-sm bg-white border-2 border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                        </div>
                        </div> 
                    </div>

                </form>
            </div>

            <!-- Footer Premium -->
            <div class="px-8 py-5 border-t border-slate-200/30 bg-white/80 backdrop-blur-xl flex items-center justify-between gap-4">
                <button type="button" id="btnPrev" onclick="previousStep()" 
                    class="group relative px-6 py-2.5 bg-white/60 backdrop-blur-sm border border-slate-200 text-slate-600 font-semibold rounded-2xl hover:bg-white/80 hover:border-slate-300 transform hover:scale-105 transition-all duration-300 shadow-lg hidden">
                    <i class="fas fa-arrow-left mr-2 group-hover:-translate-x-1 transition-transform"></i>
                    <span class="hidden sm:inline">Anterior</span><span class="sm:hidden">Atrás</span>
                </button>
                
                <div class="flex-1"></div>
                
                <button type="button" id="btnNext" onclick="nextStep()"
                    style="padding: 0.5rem 1.5rem; background: #1a2332; color: white; font-weight: 600; border-radius: 0.75rem; display: flex; align-items: center; gap: 0.5rem; border: none; cursor: pointer; transition: all 0.2s;"
                    onmouseover="this.style.background='#141d28'"
                    onmouseout="this.style.background='#1a2332'">
                    <span>Siguiente</span>
                    <i class="fas fa-arrow-right"></i>
                </button>

                
                <button type="button" id="btnSave" onclick="submitNuevaPropiedad()" 
                    class="group relative px-8 py-2.5 bg-emerald-600 text-white font-bold rounded-2xl hover:bg-emerald-700 transform hover:scale-105 transition-all duration-300 shadow-xl hover:shadow-emerald-500/25 hidden">
                    <i class="fas fa-check mr-2 group-hover:scale-110 transition-transform"></i>
                    <span class="hidden sm:inline">Crear Propiedad</span><span class="sm:hidden">Crear</span>
                </button>
            </div>
        </div>
    </div>
</div>
