<!-- Spinner Global Moderno -->
<div id="globalSpinner" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(26, 35, 50, 0.95); z-index: 999999; justify-content: center; align-items: center;">
    <div style="text-align: center;">
        <!-- Spinner animado -->
        <div class="spinner-container" style="position: relative; width: 120px; height: 120px; margin: 0 auto 2rem;">
            <div class="spinner-ring" style="position: absolute; width: 100%; height: 100%; border: 4px solid rgba(255, 255, 255, 0.1); border-radius: 50%;"></div>
            <div class="spinner-ring spinner-ring-1" style="position: absolute; width: 100%; height: 100%; border: 4px solid transparent; border-top-color: #fff; border-radius: 50%; animation: spin 1.5s cubic-bezier(0.68, -0.55, 0.265, 1.55) infinite;"></div>
            <div class="spinner-ring spinner-ring-2" style="position: absolute; width: 80%; height: 80%; top: 10%; left: 10%; border: 4px solid transparent; border-top-color: rgba(255, 255, 255, 0.6); border-radius: 50%; animation: spin 2s cubic-bezier(0.68, -0.55, 0.265, 1.55) infinite reverse;"></div>
            <div class="spinner-ring spinner-ring-3" style="position: absolute; width: 60%; height: 60%; top: 20%; left: 20%; border: 4px solid transparent; border-top-color: rgba(255, 255, 255, 0.3); border-radius: 50%; animation: spin 1s linear infinite;"></div>
            
            <!-- Icono central -->
            <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
                <i class="fas fa-home" id="spinnerIcon" style="color: white; font-size: 2rem; animation: pulse 2s ease-in-out infinite;"></i>
            </div>
        </div>
        
        <!-- Mensaje del spinner -->
        <div style="color: white;">
            <h3 id="spinnerMessage" style="font-size: 1.5rem; font-weight: 700; margin: 0 0 0.5rem 0; color: white;">Cargando...</h3>
            <p id="spinnerSubMessage" style="font-size: 1rem; color: rgba(255, 255, 255, 0.7); margin: 0;">Por favor espera un momento</p>
        </div>
        
        <!-- Puntos animados -->
        <div class="dots" style="display: flex; justify-content: center; gap: 0.5rem; margin-top: 1.5rem;">
            <span style="width: 8px; height: 8px; background: white; border-radius: 50%; animation: bounce 1.4s ease-in-out infinite;"></span>
            <span style="width: 8px; height: 8px; background: white; border-radius: 50%; animation: bounce 1.4s ease-in-out 0.2s infinite;"></span>
            <span style="width: 8px; height: 8px; background: white; border-radius: 50%; animation: bounce 1.4s ease-in-out 0.4s infinite;"></span>
        </div>
    </div>
</div>

<style>
@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

@keyframes pulse {
    0%, 100% { 
        transform: translate(-50%, -50%) scale(1); 
        opacity: 1;
    }
    50% { 
        transform: translate(-50%, -50%) scale(1.1); 
        opacity: 0.8;
    }
}

@keyframes bounce {
    0%, 80%, 100% { 
        transform: translateY(0); 
        opacity: 1;
    }
    40% { 
        transform: translateY(-12px); 
        opacity: 0.6;
    }
}

#globalSpinner {
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
}
</style>

<script>
// Funciones globales para controlar el spinner
window.showSpinner = function(message = 'Cargando...', subMessage = 'Por favor espera un momento', icon = 'fa-home') {
    const spinner = document.getElementById('globalSpinner');
    const messageEl = document.getElementById('spinnerMessage');
    const subMessageEl = document.getElementById('spinnerSubMessage');
    const iconEl = document.getElementById('spinnerIcon');
    
    if (spinner) {
        messageEl.textContent = message;
        subMessageEl.textContent = subMessage;
        
        // Cambiar icono
        iconEl.className = `fas ${icon}`;
        
        spinner.style.display = 'flex';
        document.body.style.overflow = 'hidden'; // Prevenir scroll
    }
};

window.hideSpinner = function() {
    const spinner = document.getElementById('globalSpinner');
    if (spinner) {
        spinner.style.display = 'none';
        document.body.style.overflow = ''; // Restaurar scroll
    }
};

// Función helper para operaciones async
window.withSpinner = async function(message, subMessage, icon, asyncFunction) {
    showSpinner(message, subMessage, icon);
    try {
        const result = await asyncFunction();
        return result;
    } finally {
        hideSpinner();
    }
};

// Al volver atrás (bfcache), ocultar el spinner que quedó visible
window.addEventListener('pageshow', function(event) {
    hideSpinner();
});
</script>
