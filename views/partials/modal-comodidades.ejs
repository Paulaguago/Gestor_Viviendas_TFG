<!-- Modal: Gestionar Comodidades -->
<div id="modalComodidades" class="modal-overlay">
    <div class="modal-amenities-modern">
        <div class="amenities-header-modern">
            <div class="title-group">
                <h2 class="amenities-title-text">Comodiddades & Servicios</h2>
                <p class="amenities-subtitle">Configura el equipamiento de tu propiedad</p>
            </div>
            <button class="amenities-close-modern" onclick="cerrarModalComodidades()">&times;</button>
        </div>

        <div class="amenities-toolbar">
            <div class="search-box">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" id="amenitiesSearchInput" placeholder="Buscar..." onkeyup="filtrarComodidades()">
            </div>
            
            <div class="categories-pills">
                <button class="pill active" onclick="filtrarPorCategoria('todos')">Todos <span>63</span></button>
                <button class="pill" onclick="filtrarPorCategoria('basicos')">Básicos</button>
                <button class="pill" onclick="filtrarPorCategoria('cocina')">Cocina</button>
                <button class="pill" onclick="filtrarPorCategoria('exterior')">Exterior</button>
            </div>
        </div>

        <div class="modal-content-layout">
            <div class="amenities-grid-wrapper">
                <div class="amenities-grid-modern" id="amenitiesGrid">
                </div>
            </div>

            <aside class="side-panel" style="padding:1rem;background:#f9f9f9;border-radius:8px;font-family:'Segoe UI',sans-serif;">
                <div class="custom-add-card">
                    <h4 style="margin-bottom:0.3rem;font-size:1rem;color:#333;">¿Falta algo?</h4>
                    <p style="font-size:0.85rem;color:#666;">Agrega un servicio personalizado</p>
                    <div style="display:flex;gap:0.5rem;margin-top:0.5rem;width:100%;">
                    <input type="text" id="customAmenityInput" placeholder="Ej: Jacuzzi" style="flex:1;min-width:0;padding:0.6rem 0.8rem;border:1px solid #ccc;border-radius:6px;font-size:0.85rem;">
                    <button onclick="añadirComodidadPersonalizada()" style="flex-shrink:0;min-width:40px;width:40px;height:40px;padding:0;background-color:#0078D4;color:white;border:none;border-radius:6px;cursor:pointer;font-size:1.2rem;display:flex;align-items:center;justify-content:center;font-weight:bold;">+</button>
                    </div>
                    <div id="customAmenitiesContainer" style="margin-top:0.5rem;display:flex;flex-wrap:wrap;gap:0.4rem;"></div>
                </div>
            </aside>

        </div>

        <div class="amenities-footer-modern">
            <div class="selected-status">
                <span id="selectedAmenitiesCount">0</span> seleccionadas
            </div>
            <div class="footer-actions">
                <button class="btn-cancel" onclick="cerrarModalComodidades()">Cancelar</button>
                <button class="btn-save" onclick="guardarComodidades()">Guardar Cambios</button>
            </div>
        </div>
    </div>
</div>
