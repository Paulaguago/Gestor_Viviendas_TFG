<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Gestor Viviendas' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Incluir el navbar como partial -->
    <%- include('partials/navbar-inicio') %>
    
    <!-- Content Wrapper -->
    <div class="content-wrapper">
        <!-- Container principal del contenido -->
        <div class="container mt-5">
        <div class="row">
            <div class="col-12">
                <div class="text-center mb-5">
                    <h1 class="display-4 fw-bold">Bienvenido a Gestor Viviendas</h1>
                    <p class="lead text-muted">Tu plataforma completa para la gestión inteligente de propiedades</p>
                </div>
            </div>
        </div>
        
        <!-- Container principal para futuras implementaciones -->
        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body p-5">
                        <!-- Aquí puedes añadir más contenido en el futuro -->
                        <div class="text-center text-muted">
                            <i class="bi bi-building display-1 mb-3"></i>
                            <p>Contenido en desarrollo...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        </div>
    </div>
    
    <%- include('partials/footer') %>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
