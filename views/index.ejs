<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Gestor Viviendas - Gestiona tus propiedades con IA' %></title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <!-- Landing Page CSS / css propio-->
    <link rel="stylesheet" href="/css/landing.css">
    <style>
        body {
            zoom: 0.8;
        }
        @media (max-width: 768px) {
            body {
                zoom: 0.85;
            }
        }
    </style>
</head>
<body class="min-h-screen text-white">
    
    <%- include('partials/spinner') %>
    
    <!-- Navbar integrado -->
    <nav class="w-full py-4 px-6 lg:px-12 fixed top-0 z-50 bg-[#1a2332] backdrop-blur-sm border-b border-blue-700/20">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-3">
                <img src="/images/logo.png" alt="Gestor Viviendas Logo" class="h-12 lg:h-14">
                <span class="text-xl lg:text-2xl font-bold text-white">Gestor Viviendas</span>
            </a>
            
            <!-- Enlaces de navegación (centrados) -->
            <div class="hidden md:flex items-center gap-8 absolute left-1/2 transform -translate-x-1/2">
                <a href="#funciones" class="text-gray-200 hover:text-white transition text-base font-medium">Funciones</a>
                <a href="#reseñas" class="text-gray-200 hover:text-white transition text-base font-medium">Reseñas</a>
                <a href="#precios" class="text-gray-200 hover:text-white transition text-base font-medium">Precios</a>
            </div>
            
            <!-- Botones de acción -->
            <div class="flex items-center gap-4">
                <a href="/auth/login" class="hidden md:inline-block text-white hover:text-gray-200 transition font-medium text-base">Acceder</a>
                <a href="/auth/register" class="bg-yellow-400 hover:bg-yellow-500 text-black font-bold px-6 py-2.5 rounded-full transition text-base">
                    Empieza gratis
                </a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="pt-32 pb-20 px-6 lg:px-12 min-h-screen flex items-center relative overflow-hidden">
        <!-- Mockup flotante derecho (fondo decorativo) -->
        <div class="hidden lg:block absolute right-0 top-1/4 w-1/3 opacity-20 transform translate-x-10 rotate-6">
            <div class="bg-gradient-to-br from-blue-600/30 to-purple-600/30 rounded-3xl p-4 backdrop-blur-xl border border-blue-500/20">
                <div class="bg-blue-900/50 rounded-2xl p-4 space-y-3">
                    <div class="h-8 bg-gradient-to-r from-yellow-400/40 to-green-400/40 rounded"></div>
                    <div class="h-20 bg-blue-800/60 rounded"></div>
                    <div class="grid grid-cols-2 gap-2">
                        <div class="h-16 bg-blue-800/60 rounded"></div>
                        <div class="h-16 bg-blue-800/60 rounded"></div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Mockup flotante izquierdo -->
        <div class="hidden lg:block absolute left-0 top-2/3 w-1/4 opacity-15 transform -translate-x-5 -rotate-3">
            <div class="bg-gradient-to-br from-green-600/30 to-blue-600/30 rounded-3xl p-3 backdrop-blur-xl border border-green-500/20">
                <div class="bg-blue-900/50 rounded-2xl p-3 space-y-2">
                    <div class="h-6 bg-gradient-to-r from-green-400/40 to-yellow-400/40 rounded"></div>
                    <div class="h-14 bg-blue-800/60 rounded"></div>
                    <div class="grid grid-cols-3 gap-1">
                        <div class="h-10 bg-blue-800/60 rounded"></div>
                        <div class="h-10 bg-blue-800/60 rounded"></div>
                        <div class="h-10 bg-blue-800/60 rounded"></div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="max-w-5xl mx-auto text-center relative z-10">
            <!-- Titular Principal -->
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
                Gestiona tus propiedades con la <span class="text-neon-green">inteligencia</span> del futuro
            </h1>
            
            <!-- Subtítulo -->
            <p class="text-lg md:text-xl lg:text-2xl text-gray-300 max-w-4xl mx-auto mb-12 leading-relaxed">
                Optimiza tus rentas, automatiza el cumplimiento legal y predice el valor de tus activos con nuestra plataforma impulsada por IA.
            </p>
            
            <!-- Video Demo Predicción -->
            <div class="max-w-4xl mx-auto mb-12">
                <div class="relative bg-gradient-to-br from-blue-800/30 to-blue-900/40 rounded-3xl p-4 border border-blue-700/30">
                    <div class="aspect-video bg-blue-900/50 rounded-2xl flex items-center justify-center relative overflow-hidden">
                        <!-- Próximamente: Video demo de predicción de alquiler -->
                        <div class="text-center">
                            <i class="bi bi-play-circle-fill text-7xl text-yellow-400 mb-4"></i>
                            <p class="text-xl font-semibold text-gray-300">Demo de Predicción de Alquiler</p>
                            <p class="text-sm text-gray-400 mt-2">Próximamente</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Botones CTA -->
            <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
                <a href="/auth/register" class="bg-yellow-400 hover:bg-yellow-500 text-black font-bold px-10 py-4 rounded-full transition text-lg">
                    <i class="bi bi-rocket-takeoff me-2"></i>Registrarme gratis
                </a>
                <a href="#video" class="border-2 border-white hover:bg-white/10 text-white font-bold px-10 py-4 rounded-full transition text-lg">
                    <i class="bi bi-play-circle me-2"></i>Ver demo
                </a>
            </div>
        </div>
    </section>

    <!-- Sección de Funciones (Bento Grid Dashboard Preview) -->
    <section class="py-20 px-6 lg:px-12 bg-gradient-to-b from-blue-950/40 to-blue-950/20" id="funciones">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12">
                <h2 class="text-4xl lg:text-5xl font-extrabold mb-4">Tu <span class="text-yellow-400">centro de control</span> financiero</h2>
                <p class="text-xl text-gray-300">Todo lo que necesitas en un solo dashboard</p>
            </div>
            
            <!-- Bento Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                
                <!-- Widget 1: Gráfico de Ingresos -->
                <div class="lg:col-span-2 bg-gradient-to-br from-blue-800/30 to-blue-900/40 rounded-3xl p-8 border border-blue-700/30 relative overflow-hidden">
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-2xl font-bold">Ingresos Mensuales</h3>
                        <i class="bi bi-bar-chart-fill text-3xl text-yellow-400"></i>
                    </div>
                    <!-- Placeholder para captura real de gráfico - Descomenta cuando tengas la imagen:
                    <img src="/images/dashboard/chart-ingresos.png" alt="Gráfico de ingresos" class="w-full h-48 object-contain rounded-xl">
                    -->
                    <div class="h-48 flex items-end gap-2">
                        <div class="flex-1 bg-yellow-400/30 rounded-t-xl" style="height: 60%"></div>
                        <div class="flex-1 bg-yellow-400/40 rounded-t-xl" style="height: 45%"></div>
                        <div class="flex-1 bg-yellow-400/50 rounded-t-xl" style="height: 75%"></div>
                        <div class="flex-1 bg-yellow-400/60 rounded-t-xl" style="height: 55%"></div>
                        <div class="flex-1 bg-yellow-400 rounded-t-xl" style="height: 90%"></div>
                        <div class="flex-1 bg-yellow-400/70 rounded-t-xl" style="height: 65%"></div>
                    </div>
                    <p class="text-gray-400 text-sm mt-4">Análisis de ingresos mensuales</p>
                </div>
                
                <!-- Widget 2: Tasa de Ocupación -->
                <div class="bg-gradient-to-br from-blue-800/30 to-blue-900/40 rounded-3xl p-8 border border-blue-700/30 flex flex-col justify-center items-center">
                    <i class="bi bi-graph-up-arrow text-5xl text-neon-green mb-4"></i>
                    <h3 class="text-xl font-bold mb-2">Tasa de Ocupación</h3>
                    <p class="text-6xl font-extrabold text-neon-green mb-2">87%</p>
                    <p class="text-gray-400 text-sm">Ocupación en tiempo real</p>
                </div>
                
                <!-- Widget 3: Beneficio Neto -->
                <div class="bg-gradient-to-br from-blue-800/30 to-blue-900/40 rounded-3xl p-8 border border-blue-700/30 flex flex-col justify-center items-center">
                    <i class="bi bi-currency-euro text-5xl text-yellow-400 mb-4"></i>
                    <h3 class="text-xl font-bold mb-2">Beneficio Neto</h3>
                    <p class="text-6xl font-extrabold text-yellow-400 mb-2">3.2K€</p>
                    <p class="text-gray-400 text-sm">Beneficio mensual actual</p>
                </div>
                
                <!-- Widget 4: IA Predictiva -->
                <div class="lg:col-span-2 bg-gradient-to-br from-blue-800/30 to-blue-900/40 rounded-3xl p-8 border border-blue-700/30 relative overflow-hidden">
                    <!-- Placeholder para captura de predicción - Descomenta cuando tengas la imagen:
                    <div class="absolute top-0 right-0 w-1/2 h-full opacity-10">
                        <img src="/images/dashboard/prediction-ai.png" alt="Predicción IA" class="h-full object-cover">
                    </div>
                    -->
                    <div class="flex items-center justify-between mb-6 relative z-10">
                        <h3 class="text-2xl font-bold">IA Predictiva</h3>
                        <i class="bi bi-robot text-3xl text-neon-green"></i>
                    </div>
                    <div class="space-y-4">
                        <div class="flex items-center justify-between">
                            <span class="text-gray-300">Precio recomendado alquiler</span>
                            <span class="text-2xl font-bold text-yellow-400">125€/noche</span>
                        </div>
                        <div class="w-full bg-blue-900/50 rounded-full h-3">
                            <div class="bg-gradient-to-r from-yellow-400 to-neon-green h-3 rounded-full" style="width: 78%"></div>
                        </div>
                        <p class="text-gray-400 text-sm">Basado en 2,450 propiedades similares en tu zona</p>
                    </div>
                </div>
                
            </div>
        </div>
    </section>

    <!-- Sección Cómo Funciona (Video) -->
    <section class="py-20 px-6 lg:px-12 bg-gradient-to-b from-blue-950/20 to-blue-950/50 border-t-2 border-yellow-400/20" id="video">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-12">
                <h2 class="text-4xl lg:text-5xl font-extrabold mb-4">Gestión profesional en <span class="text-yellow-400">3 pasos</span></h2>
                <p class="text-xl text-gray-300">Así de simple. Mira cómo funciona.</p>
            </div>
            
            <!-- Contenedor de Video -->
            <div class="relative mb-16 bg-gradient-to-br from-blue-800/30 to-blue-900/40 rounded-3xl p-4 border border-blue-700/30">
                <div class="aspect-video bg-blue-900/50 rounded-2xl flex items-center justify-center relative overflow-hidden">
                    <!-- Foto de: Captura de pantalla del dashboard principal de la aplicación -->
                    <i class="bi bi-play-circle-fill text-8xl text-yellow-400 cursor-pointer hover:text-yellow-500 transition hover:scale-110"></i>
                </div>
            </div>
            
            <!-- 3 Pasos -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
                <div class="text-center">
                    <div class="w-20 h-20 mx-auto mb-4 bg-yellow-400 rounded-full flex items-center justify-center">
                        <span class="text-3xl font-extrabold text-black">1</span>
                    </div>
                    <h3 class="text-2xl font-bold mb-3">Sincroniza</h3>
                    <p class="text-gray-300 text-base">Conecta tus calendarios de Airbnb, Booking y Vrbo en segundos</p>
                </div>
                
                <div class="text-center">
                    <div class="w-20 h-20 mx-auto mb-4 bg-pink-500 rounded-full flex items-center justify-center">
                        <span class="text-3xl font-extrabold text-white">2</span>
                    </div>
                    <h3 class="text-2xl font-bold mb-3">Automatiza</h3>
                    <p class="text-gray-300 text-base">Partes de viajeros, cumplimiento legal y reportes sin tu intervención</p>
                </div>
                
                <div class="text-center">
                    <div class="w-20 h-20 mx-auto mb-4 bg-blue-400 rounded-full flex items-center justify-center">
                        <span class="text-3xl font-extrabold text-black">3</span>
                    </div>
                    <h3 class="text-2xl font-bold mb-3">Cobra</h3>
                    <p class="text-gray-300 text-base">Optimiza precios con IA y maximiza tus ingresos cada mes</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Estadísticas -->
    <section class="py-16 px-6 lg:px-12 bg-blue-950/30 border-t-2 border-blue-700/30">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
                <div>
                    <p class="text-5xl lg:text-6xl font-extrabold text-yellow-400 mb-2">+2,500</p>
                    <p class="text-lg text-gray-300">Huéspedes registrados automáticamente</p>
                </div>
                <div>
                    <p class="text-5xl lg:text-6xl font-extrabold text-neon-green mb-2">0%</p>
                    <p class="text-lg text-gray-300">Errores de sincronización</p>
                </div>
                <div>
                    <p class="text-5xl lg:text-6xl font-extrabold text-blue-400 mb-2">15 min</p>
                    <p class="text-lg text-gray-300">Tiempo de gestión al mes</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Cobertura Nacional (Mapa OpenStreetMap) -->
    <section class="py-20 px-6 lg:px-12 bg-gradient-to-b from-blue-950/50 to-blue-950/20 border-t-2 border-yellow-400/20">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12">
                <h2 class="text-4xl lg:text-5xl font-extrabold mb-4">Cobertura <span class="text-yellow-400">Nacional</span></h2>
                <p class="text-xl text-gray-300">Gestiona propiedades en toda España desde un solo lugar</p>
            </div>
            
            <!-- Mapa OpenStreetMap -->
            <div class="bg-blue-900/30 backdrop-blur-sm border border-blue-700/30 rounded-3xl p-4 lg:p-6">
                <div id="map" class="w-full h-96 lg:h-[500px] rounded-2xl overflow-hidden bg-blue-900/50 relative">
                    <!-- El mapa se cargará aquí con Leaflet.js -->
                </div>
                
                <!-- Grid de ciudades destacadas -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6">
                    <div class="bg-blue-800/40 rounded-xl p-4 text-center border border-blue-700/30">
                        <i class="bi bi-geo-alt-fill text-yellow-400 text-2xl mb-2"></i>
                        <p class="font-bold text-white text-lg">Madrid</p>
                        <p class="text-gray-400 text-sm">+234 propiedades</p>
                    </div>
                    <div class="bg-blue-800/40 rounded-xl p-4 text-center border border-blue-700/30">
                        <i class="bi bi-geo-alt-fill text-yellow-400 text-2xl mb-2"></i>
                        <p class="font-bold text-white text-lg">Barcelona</p>
                        <p class="text-gray-400 text-sm">+189 propiedades</p>
                    </div>
                    <div class="bg-blue-800/40 rounded-xl p-4 text-center border border-blue-700/30">
                        <i class="bi bi-geo-alt-fill text-yellow-400 text-2xl mb-2"></i>
                        <p class="font-bold text-white text-lg">Valencia</p>
                        <p class="text-gray-400 text-sm">+156 propiedades</p>
                    </div>
                    <div class="bg-blue-800/40 rounded-xl p-4 text-center border border-blue-700/30">
                        <i class="bi bi-geo-alt-fill text-yellow-400 text-2xl mb-2"></i>
                        <p class="font-bold text-white text-lg">Málaga</p>
                        <p class="text-gray-400 text-sm">+142 propiedades</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Propiedades Destacadas -->
    <section class="py-20 px-6 lg:px-12 border-t-2 border-blue-700/30 bg-gradient-to-b from-blue-950/20 to-transparent">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12">
                <h2 class="text-4xl lg:text-5xl font-extrabold mb-4">Propiedades <span class="text-neon-green">Destacadas</span></h2>
                <p class="text-xl text-gray-300">Ejemplos reales de gestión exitosa</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                
                <!-- Propiedad 1 -->
                <div class="bg-gradient-to-br from-blue-800/30 to-blue-900/40 rounded-3xl overflow-hidden border border-blue-700/30 hover:border-yellow-400/50 transition group">
                    <!-- Placeholder para imagen de propiedad -->
                    <div class="h-56 bg-gradient-to-br from-blue-700/50 to-blue-800/50 relative overflow-hidden">
                        <!-- Descomenta y reemplaza con imagen real:
                        <img src="/images/properties/property-1.jpg" alt="Apartamento Madrid" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                        -->
                        <div class="absolute inset-0 flex items-center justify-center">
                            <i class="bi bi-house-door-fill text-6xl text-blue-600/40"></i>
                        </div>
                        <div class="absolute top-4 right-4 bg-neon-green text-black font-bold px-3 py-1 rounded-full text-sm">
                            87% ocupación
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-xl font-bold text-white">Apartamento Centro</h3>
                            <span class="text-yellow-400 font-bold text-lg">1.850€/mes</span>
                        </div>
                        <p class="text-gray-400 text-sm mb-4 flex items-center gap-2">
                            <i class="bi bi-geo-alt-fill text-yellow-400"></i>
                            Madrid, Sol
                        </p>
                        <div class="flex items-center gap-4 text-sm text-gray-400">
                            <span><i class="bi bi-door-closed me-1"></i>2 hab</span>
                            <span><i class="bi bi-droplet me-1"></i>1 baño</span>
                            <span><i class="bi bi-arrows-fullscreen me-1"></i>65m²</span>
                        </div>
                    </div>
                </div>

                <!-- Propiedad 2 -->
                <div class="bg-gradient-to-br from-blue-800/30 to-blue-900/40 rounded-3xl overflow-hidden border border-blue-700/30 hover:border-yellow-400/50 transition group">
                    <div class="h-56 bg-gradient-to-br from-purple-700/50 to-purple-800/50 relative overflow-hidden">
                        <!-- Placeholder -->
                        <div class="absolute inset-0 flex items-center justify-center">
                            <i class="bi bi-building text-6xl text-purple-600/40"></i>
                        </div>
                        <div class="absolute top-4 right-4 bg-yellow-400 text-black font-bold px-3 py-1 rounded-full text-sm">
                            92% ocupación
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-xl font-bold text-white">Loft Moderno</h3>
                            <span class="text-yellow-400 font-bold text-lg">2.100€/mes</span>
                        </div>
                        <p class="text-gray-400 text-sm mb-4 flex items-center gap-2">
                            <i class="bi bi-geo-alt-fill text-yellow-400"></i>
                            Barcelona, Eixample
                        </p>
                        <div class="flex items-center gap-4 text-sm text-gray-400">
                            <span><i class="bi bi-door-closed me-1"></i>3 hab</span>
                            <span><i class="bi bi-droplet me-1"></i>2 baños</span>
                            <span><i class="bi bi-arrows-fullscreen me-1"></i>85m²</span>
                        </div>
                    </div>
                </div>

                <!-- Propiedad 3 -->
                <div class="bg-gradient-to-br from-blue-800/30 to-blue-900/40 rounded-3xl overflow-hidden border border-blue-700/30 hover:border-yellow-400/50 transition group">
                    <div class="h-56 bg-gradient-to-br from-green-700/50 to-green-800/50 relative overflow-hidden">
                        <!-- Placeholder -->
                        <div class="absolute inset-0 flex items-center justify-center">
                            <i class="bi bi-house-heart-fill text-6xl text-green-600/40"></i>
                        </div>
                        <div class="absolute top-4 right-4 bg-neon-green text-black font-bold px-3 py-1 rounded-full text-sm">
                            95% ocupación
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-xl font-bold text-white">Villa Playa</h3>
                            <span class="text-yellow-400 font-bold text-lg">3.200€/mes</span>
                        </div>
                        <p class="text-gray-400 text-sm mb-4 flex items-center gap-2">
                            <i class="bi bi-geo-alt-fill text-yellow-400"></i>
                            Málaga, Marbella
                        </p>
                        <div class="flex items-center gap-4 text-sm text-gray-400">
                            <span><i class="bi bi-door-closed me-1"></i>4 hab</span>
                            <span><i class="bi bi-droplet me-1"></i>3 baños</span>
                            <span><i class="bi bi-arrows-fullscreen me-1"></i>120m²</span>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </section>

    <!-- Testimonios (Social Proof) -->
    <section class="py-20 px-6 lg:px-12 bg-gradient-to-b from-transparent to-blue-950/40 border-t-2 border-yellow-400/20" id="reseñas">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12">
                <h2 class="text-4xl lg:text-5xl font-extrabold mb-4">Lo que dicen nuestros <span class="text-yellow-400">usuarios</span></h2>
                <p class="text-xl text-gray-300">Propietarios reales, resultados reales</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                
                <!-- Testimonio 1 -->
                <div class="bg-white rounded-3xl p-8">
                    <div class="flex items-center gap-4 mb-6">
                        <!-- Placeholder para foto real - Descomenta cuando tengas la imagen:
                        <img src="/images/testimonials/ana-martinez.jpg" alt="Ana Martínez" class="w-16 h-16 rounded-full object-cover border-4 border-yellow-400">
                        -->
                        <div class="w-16 h-16 bg-gradient-to-br from-yellow-400 to-yellow-500 rounded-full flex items-center justify-center text-2xl font-bold text-black">
                            AM
                        </div>
                        <div>
                            <p class="font-bold text-gray-900 text-lg">Ana Martínez</p>
                            <p class="text-gray-600 text-sm">Propietaria en Madrid</p>
                        </div>
                    </div>
                    <div class="flex gap-1 mb-4">
                        <i class="bi bi-star-fill text-yellow-400 text-xl"></i>
                        <i class="bi bi-star-fill text-yellow-400 text-xl"></i>
                        <i class="bi bi-star-fill text-yellow-400 text-xl"></i>
                        <i class="bi bi-star-fill text-yellow-400 text-xl"></i>
                        <i class="bi bi-star-fill text-yellow-400 text-xl"></i>
