    <!-- Leaflet.js para OpenStreetMap -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <!-- Scripts -->
    <script>
        // Inicializar mapa de OpenStreetMap
        document.addEventListener('DOMContentLoaded', function() {
            // Crear mapa centrado en España
            const map = L.map('map', {
                center: [40.4168, -3.7038], // Madrid
                zoom: 6,
                scrollWheelZoom: false,
                zoomControl: true
            });
            
            // Añadir capa de OpenStreetMap con estilo claro
            L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
                maxZoom: 19
            }).addTo(map);
            
            // Icono personalizado (amarillo)
            const customIcon = L.divIcon({
                className: 'custom-marker',
                html: '<div style="background-color: #FFD700; width: 24px; height: 24px; border-radius: 50%; border: 3px solid #1a2332; display: flex; align-items: center; justify-content: center;"><i class="bi bi-house-fill" style="color: #1a2332; font-size: 12px;"></i></div>',
                iconSize: [24, 24],
                iconAnchor: [12, 12]
            });
            
            // Añadir marcadores de ciudades principales
            const ciudades = [
                { nombre: 'Madrid', coords: [40.4168, -3.7038], propiedades: 234 },
                { nombre: 'Barcelona', coords: [41.3851, 2.1734], propiedades: 189 },
                { nombre: 'Valencia', coords: [39.4699, -0.3763], propiedades: 156 },
                { nombre: 'Málaga', coords: [36.7213, -4.4214], propiedades: 142 },
                { nombre: 'Sevilla', coords: [37.3891, -5.9845], propiedades: 98 },
                { nombre: 'Bilbao', coords: [43.2630, -2.9350], propiedades: 76 },
                { nombre: 'Alicante', coords: [38.3452, -0.4810], propiedades: 112 },
                { nombre: 'Granada', coords: [37.1773, -3.5986], propiedades: 64 }
            ];
            
            ciudades.forEach(ciudad => {
                L.marker(ciudad.coords, { icon: customIcon })
                    .addTo(map)
                    .bindPopup(`
                        <div style="color: #1a2332; font-weight: bold; text-align: center;">
                            <p style="margin: 0; font-size: 16px;">${ciudad.nombre}</p>
                            <p style="margin: 4px 0 0 0; font-size: 14px; color: #666;">+${ciudad.propiedades} propiedades</p>
                        </div>
                    `);
            });
        });
        
        // Smooth scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
        
        // Acordeón FAQ
        document.querySelectorAll('.accordion-trigger').forEach(button => {
            button.addEventListener('click', function() {
                const content = this.nextElementSibling;
                const icon = this.querySelector('.accordion-icon');
                
                // Cerrar todos los demás acordeones
                document.querySelectorAll('.accordion-content').forEach(item => {
                    if (item !== content) {
                        item.classList.remove('active');
                        item.previousElementSibling.querySelector('.accordion-icon').style.transform = 'rotate(0deg)';
                    }
                });
                
                // Toggle del acordeón actual
                content.classList.toggle('active');
                if (content.classList.contains('active')) {
                    icon.style.transform = 'rotate(180deg)';
                } else {
                    icon.style.transform = 'rotate(0deg)';
                }
            });
        });
    </script>
