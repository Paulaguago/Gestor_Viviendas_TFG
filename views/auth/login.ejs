<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <!-- Landing CSS para consistencia -->
    <link rel="stylesheet" href="/css/landing.css">
    <style>
        body {
            background: linear-gradient(135deg, #1a2332 0%, #0f1419 100%);
            position: relative;
            overflow-x: hidden;
        }
        
        /* Contenedor de partículas */
        #particles-js {
            position: fixed;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            z-index: 0;
        }
        
        /* Skyline de ciudad */
        .cityscape {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 120px;
            z-index: 1;
            display: flex;
            align-items: flex-end;
            gap: 2px;
            padding: 0 5%;
            opacity: 0.15;
        }
        
        .building {
            background: linear-gradient(to top, #1e3a5f, #2a4a70);
            border-radius: 4px 4px 0 0;
            position: relative;
            animation: pulse 4s ease-in-out infinite;
        }
        
        .building:nth-child(1) { height: 70px; width: 60px; animation-delay: 0s; }
        .building:nth-child(2) { height: 95px; width: 80px; animation-delay: 0.5s; }
        .building:nth-child(3) { height: 60px; width: 50px; animation-delay: 1s; }
        .building:nth-child(4) { height: 110px; width: 70px; animation-delay: 1.5s; }
        .building:nth-child(5) { height: 85px; width: 65px; animation-delay: 2s; }
        .building:nth-child(6) { height: 65px; width: 55px; animation-delay: 2.5s; }
        .building:nth-child(7) { height: 100px; width: 75px; animation-delay: 3s; }
        .building:nth-child(8) { height: 80px; width: 60px; animation-delay: 3.5s; }
        
        .building::before {
            content: '';
            position: absolute;
            top: 10px;
            left: 10px;
            right: 10px;
            height: 80%;
            background: linear-gradient(to bottom, 
                transparent 0%, 
                rgba(255, 215, 0, 0.1) 20%, 
                transparent 40%,
                rgba(255, 215, 0, 0.1) 60%,
                transparent 80%
            );
            background-size: 100% 20px;
            animation: windows 3s linear infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 0.15; transform: scaleY(1); }
            50% { opacity: 0.25; transform: scaleY(1.02); }
        }
        
        @keyframes windows {
            0% { background-position: 0 0; }
            100% { background-position: 0 100px; }
        }
        
        /* Asegurar que el contenido esté sobre el fondo */
        nav, .min-h-screen > div {
            position: relative;
            z-index: 10;
        }
    </style>
    <!-- Particles.js -->
    <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
</head>
<body class="min-h-screen text-white">
    
    <%- include('../partials/spinner') %>
    
    <!-- Fondo de partículas -->
    <div id="particles-js"></div>
    
    <!-- Skyline de ciudad -->
    <div class="cityscape">
        <div class="building"></div>
        <div class="building"></div>
        <div class="building"></div>
        <div class="building"></div>
        <div class="building"></div>
        <div class="building"></div>
        <div class="building"></div>
        <div class="building"></div>
    </div>
    
    <!-- Navbar -->
    <nav class="w-full py-4 px-6 lg:px-12 absolute top-0 z-50">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <a href="/" class="flex items-center gap-3">
                <img src="/images/logo.png" alt="Gestor Viviendas Logo" class="h-12 lg:h-14">
                <span class="text-xl lg:text-2xl font-bold text-white">Gestor Viviendas</span>
            </a>
            <a href="/" class="text-gray-300 hover:text-white transition">
                <i class="bi bi-arrow-left me-2"></i>Volver al inicio
            </a>
        </div>
    </nav>

    <!-- Contenedor principal -->
    <div class="min-h-screen flex items-start justify-center px-6 pt-0 pb-12">
        <div class="max-w-md w-full mx-auto">
            <div class="bg-gradient-to-br from-blue-900/40 to-blue-950/60 backdrop-blur-lg rounded-3xl border border-blue-700/30 p-8 lg:p-10">
                <!-- Header -->
                <div class="text-center mb-8">
                    <div class="w-16 h-16 bg-yellow-400 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <i class="bi bi-box-arrow-in-right text-3xl text-black"></i>
                    </div>
                    <h1 class="text-3xl font-bold mb-2">Iniciar Sesión</h1>
                            <p class="text-gray-400">Accede a tu cuenta para continuar</p>
                        </div>

                        <!-- Mensajes de error/éxito -->
                        <% if (error && error.length > 0) { %>
                            <div class="mb-6 bg-red-500/10 border border-red-500/30 rounded-xl p-4">
                                <div class="flex items-start gap-3">
                                    <i class="bi bi-exclamation-triangle-fill text-red-400 text-xl"></i>
                                    <p class="text-red-300 text-sm"><%= error %></p>
                                </div>
                            </div>
                        <% } %>
                        
                        <% if (success && success.length > 0) { %>
                            <div class="mb-6 bg-green-500/10 border border-green-500/30 rounded-xl p-4">
                                <div class="flex items-start gap-3">
                                    <i class="bi bi-check-circle-fill text-green-400 text-xl"></i>
                                    <p class="text-green-300 text-sm"><%= success %></p>
                                </div>
                            </div>
                        <% } %>

                        <!-- Formulario -->
                        <form action="/auth/login" method="POST" class="space-y-5" onsubmit="showSpinner('Iniciando sesión...', 'Validando tus credenciales', 'fa-right-to-bracket')">
                            <!-- Email -->
                            <div>
                                <label for="email" class="block text-sm font-semibold text-gray-200 mb-2">
                                    <i class="bi bi-envelope me-2"></i>Email
                                </label>
                                <input 
                                    type="email" 
                                    id="email" 
                                    name="email" 
                                    placeholder="tu@email.com"
                                    required
                                    class="w-full px-4 py-3 bg-blue-950/50 border border-blue-700/30 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent transition"
                                >
                            </div>

                            <!-- Contraseña -->
                            <div>
                                <label for="password" class="block text-sm font-semibold text-gray-200 mb-2">
                                    <i class="bi bi-lock me-2"></i>Contraseña
                                </label>
                                <input 
                                    type="password" 
                                    id="password" 
                                    name="password" 
                                    placeholder="••••••••"
                                    required
                                    class="w-full px-4 py-3 bg-blue-950/50 border border-blue-700/30 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent transition"
                                >
                            </div>

                            <!-- Botón de envío -->
                            <button 
                                type="submit" 
                                class="w-full bg-yellow-400 hover:bg-yellow-500 text-black font-bold py-3.5 rounded-xl transition transform hover:scale-[1.02] active:scale-[0.98]"
                            >
                                <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión
                            </button>
    <!-- Inicializar Particles.js -->
    <script>
        particlesJS('particles-js', {
            particles: {
                number: {
                    value: 40,
                    density: {
                        enable: true,
                        value_area: 800
                    }
                },
                color: {
                    value: ['#FFD700', '#4A90E2', '#00ff88']
                },
                shape: {
                    type: ['circle', 'edge'],
                    stroke: {
                        width: 0,
                        color: '#000000'
                    }
                },
                opacity: {
                    value: 0.15,
                    random: true,
                    anim: {
                        enable: true,
                        speed: 0.5,
                        opacity_min: 0.05,
                        sync: false
                    }
                },
                size: {
                    value: 4,
                    random: true,
                    anim: {
                        enable: true,
                        speed: 2,
                        size_min: 1,
                        sync: false
                    }
                },
                line_linked: {
                    enable: true,
                    distance: 150,
                    color: '#4A90E2',
                    opacity: 0.1,
                    width: 1
                },
                move: {
                    enable: true,
                    speed: 1,
                    direction: 'top',
                    random: true,
                    straight: false,
                    out_mode: 'out',
                    bounce: false,
                    attract: {
                        enable: true,
                        rotateX: 600,
                        rotateY: 1200
                    }
                }
            },
            interactivity: {
                detect_on: 'canvas',
                events: {
                    onhover: {
                        enable: true,
                        mode: 'grab'
                    },
                    onclick: {
                        enable: true,
                        mode: 'push'
                    },
                    resize: true
                },
                modes: {
                    grab: {
                        distance: 140,
                        line_linked: {
                            opacity: 0.3
                        }
                    },
                    push: {
                        particles_nb: 2
                    }
                }
            },
            retina_detect: true
        });
    </script>

                        </form>

                        <!-- Enlace a registro -->
                        <div class="mt-6 text-center">
                            <p class="text-gray-400">
                                ¿No tienes cuenta? 
                                <a href="/auth/register" class="text-yellow-400 hover:text-yellow-300 font-semibold transition">
                                    Regístrate aquí
                                </a>
                            </p>
                        </div>
                    </div>
        </div>
    </div>

</body>
</html>
