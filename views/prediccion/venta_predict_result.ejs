<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Resultado Predicción de Venta</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/prediccion/alquiler_predict_result_rf.css">
  <link rel="stylesheet" href="/css/navbar.css">
  <style>
    /* ── Venta overrides (dark) ─────────────────────── */
    .detail-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 12px;
      margin-top: 16px;
    }
    .detail-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      background: #161822;
      border-radius: 10px;
      border: 1px solid #2E3248;
      font-size: 14px;
      color: #c5c8d6;
    }
    .detail-item i { color: #6C63FF; font-size: 16px; min-width: 18px; }
    .detail-item .lbl { color: #8B8FA8; margin-right: 4px; }
    .amenity-pills { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
    .amenity-pill {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 5px 12px; border-radius: 20px; font-size: 13px; font-weight: 600;
      background: rgba(0,212,170,.1); color: #00D4AA; border: 1px solid rgba(0,212,170,.3);
    }
    .section-divider {
      margin: 24px 0 16px; padding-bottom: 8px;
      border-bottom: 2px solid #353950;
      font-size: .75rem; font-weight: 700; color: #8B8FA8;
      display: flex; align-items: center; gap: 8px;
      text-transform: uppercase; letter-spacing: .08em;
    }
    .actions-bar {
      display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap;
    }
    .actions-bar a {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 10px 20px; border-radius: 10px; font-weight: 600; font-size: 14px;
      text-decoration: none; transition: all .15s;
    }
    .btn-primary-g { background: linear-gradient(135deg,#6C63FF,#00D4AA); color:#fff; }
    .btn-primary-g:hover { filter: brightness(1.1); }
    .btn-outline-g { background: transparent; color: #A99FF5; border: 2px solid rgba(108,99,255,.4); }
    .btn-outline-g:hover { background: rgba(108,99,255,.1); }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>
  <% if (sample) { %>
  <div class="grid" style="max-width: 860px; margin: 40px auto; padding: 0 16px;">
    <div class="card">
      <!-- Precio principal -->
      <div class="title"><i class="bi bi-house-door"></i> Precio estimado de venta</div>
      <div class="price" style="font-size: 2.8rem; margin: 12px 0;">
        <%= typeof sample.price === 'number' ? sample.price.toLocaleString('es-ES', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) : sample.price %> <%= sample.currency %>
      </div>
      <div class="pill"><%= sample.modelo %></div>

      <!-- Chips resumen -->
      <div style="margin-top: 14px; display: flex; flex-wrap: wrap; gap: 8px;">
        <% if (sample.input) { %>
          <span class="chip"><i class="bi bi-building"></i> <%= sample.input.loc_city || 'N/A' %></span>
          <span class="chip"><i class="bi bi-house"></i> <%= sample.input.house_type %></span>
          <span class="chip"><i class="bi bi-arrows-fullscreen"></i> <%= sample.input.m2_useful %> m²</span>
          <span class="chip"><i class="bi bi-door-closed"></i> <%= sample.input.room_num %> hab.</span>
          <span class="chip"><i class="bi bi-droplet"></i> <%= sample.input.bath_num %> baños</span>
        <% } %>
      </div>

      <!-- Detalles de la vivienda -->
      <div class="section-divider"><i class="bi bi-list-check"></i> Datos introducidos</div>

      <div class="detail-grid">
        <div class="detail-item"><i class="bi bi-geo-alt"></i> <span class="lbl">Ciudad:</span> <%= sample.input.loc_city || '—' %></div>
        <% if (sample.input.loc_zone) { %><div class="detail-item"><i class="bi bi-pin-map"></i> <span class="lbl">Zona:</span> <%= sample.input.loc_zone %></div><% } %>
        <% if (sample.input.loc_district) { %><div class="detail-item"><i class="bi bi-signpost-2"></i> <span class="lbl">Distrito:</span> <%= sample.input.loc_district %></div><% } %>
        <% if (sample.input.loc_neigh) { %><div class="detail-item"><i class="bi bi-houses"></i> <span class="lbl">Barrio:</span> <%= sample.input.loc_neigh %></div><% } %>
        <div class="detail-item"><i class="bi bi-house"></i> <span class="lbl">Tipo:</span> <%= sample.input.house_type %></div>
        <div class="detail-item"><i class="bi bi-arrows-fullscreen"></i> <span class="lbl">m² útiles:</span> <%= sample.input.m2_useful %></div>
        <div class="detail-item"><i class="bi bi-bounding-box"></i> <span class="lbl">m² construidos:</span> <%= sample.input.m2_real %></div>
        <div class="detail-item"><i class="bi bi-door-closed"></i> <span class="lbl">Habitaciones:</span> <%= sample.input.room_num %></div>
        <div class="detail-item"><i class="bi bi-droplet"></i> <span class="lbl">Baños:</span> <%= sample.input.bath_num %></div>
        <div class="detail-item"><i class="bi bi-layers"></i> <span class="lbl">Planta:</span> <%= sample.input.floor %></div>
        <div class="detail-item"><i class="bi bi-calendar3"></i> <span class="lbl">Año:</span> <%= sample.input.construct_date %></div>
        <div class="detail-item"><i class="bi bi-tools"></i> <span class="lbl">Estado:</span> <%= sample.input.condition %></div>
        <div class="detail-item"><i class="bi bi-lightning-charge"></i> <span class="lbl">Energía:</span> <%= sample.input.energetic_certif %></div>
        <div class="detail-item"><i class="bi bi-thermometer-half"></i> <span class="lbl">Calefacción:</span> <%= sample.input.heating %></div>
        <div class="detail-item"><i class="bi bi-compass"></i> <span class="lbl">Orientación:</span> <%= sample.input.orientation %></div>
      </div>

      <!-- Amenities -->
      <%
        const amenityLabels = {
          garage: { icon: 'bi-car-front', text: 'Garaje' },
          terrace: { icon: 'bi-brightness-high', text: 'Terraza' },
          garden: { icon: 'bi-tree', text: 'Jardín' },
          swimming_pool: { icon: 'bi-water', text: 'Piscina' },
          lift: { icon: 'bi-arrow-up-square', text: 'Ascensor' },
          balcony: { icon: 'bi-columns-gap', text: 'Balcón' },
          air_conditioner: { icon: 'bi-snow', text: 'Aire acondicionado' },
          built_in_wardrobe: { icon: 'bi-box-seam', text: 'Armarios empotrados' },
          chimney: { icon: 'bi-fire', text: 'Chimenea' },
          storage_room: { icon: 'bi-archive', text: 'Trastero' },
          reduced_mobility: { icon: 'bi-person-wheelchair', text: 'Accesible' }
        };
        const activeAmenities = Object.entries(amenityLabels).filter(([k]) => sample.input[k] == 1);
      %>
      <% if (activeAmenities.length) { %>
        <div class="section-divider"><i class="bi bi-stars"></i> Servicios incluidos</div>
        <div class="amenity-pills">
          <% activeAmenities.forEach(([k, v]) => { %>
            <span class="amenity-pill"><i class="bi <%= v.icon %>"></i> <%= v.text %></span>
          <% }); %>
        </div>
      <% } %>

      <!-- Acciones -->
      <div class="actions-bar">
        <a href="/venta" class="btn-primary-g"><i class="bi bi-arrow-repeat"></i> Nueva predicción</a>
        <a href="/opciones-prediccion" class="btn-outline-g"><i class="bi bi-arrow-left"></i> Volver a opciones</a>
        <a href="/dashboard" class="btn-outline-g"><i class="bi bi-speedometer2"></i> Dashboard</a>
      </div>
    </div>
  </div>

  <% } else { %>
  <!-- Error -->
  <div class="card" style="max-width:720px; margin: 40px auto;">
    <h3><i class="bi bi-exclamation-triangle" style="color:#ef4444;"></i> Error en la predicción</h3>
    <p class="muted"><%= error || 'No se pudo calcular el precio de venta.' %></p>
    <div class="actions-bar">
      <a href="/venta" class="btn-primary-g"><i class="bi bi-arrow-repeat"></i> Reintentar</a>
      <a href="/opciones-prediccion" class="btn-outline-g"><i class="bi bi-arrow-left"></i> Volver</a>
    </div>
  </div>
  <% } %>
</body>
</html>
