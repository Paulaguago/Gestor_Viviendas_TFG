<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Resultado Predicción de Venta</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <link rel="stylesheet" href="/css/navbar.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root {
      --green-dark: #1a7a3c;
      --green-mid:  #2d6a4f;
      --green-light: #ecf7ef;
      --green-border: #a8d5b5;
      --red-deep: #c0392b;
    }
    body { font-family: 'Inter', system-ui, sans-serif; background: #F4F6F9; color: #0F172A; margin: 0; }

    /* ── Page wrapper ──────────────────────────────── */
    .vr-page { max-width: 1340px; margin: 0 auto; padding: 2rem 1.75rem 3rem; }

    /* ── Hero card ─────────────────────────────────── */
    .vr-hero-card {
      background: #fff; border-radius: 16px;
      box-shadow: 0 1px 3px rgba(0,0,0,.08);
      padding: 2rem 2rem 1.75rem;
      display: flex; align-items: flex-start;
      justify-content: space-between; flex-wrap: wrap;
      gap: 1.5rem; margin-bottom: 1.5rem;
    }
    .vr-hero-label {
      font-size: .68rem; font-weight: 700; letter-spacing: .12em;
      text-transform: uppercase; color: #64748b;
      display: flex; align-items: center; gap: .4rem;
    }
    .vr-hero-label i { color: var(--green-dark); }
    .vr-price {
      font-size: 3rem; font-weight: 900;
      color: var(--green-dark);
      line-height: 1; margin: .4rem 0;
    }
    .vr-price-sub { font-size: .85rem; color: #64748b; }
    .vr-model-pill {
      display: inline-block; padding: 4px 14px; border-radius: 20px;
      font-size: .75rem; font-weight: 700;
      background: #EFF6FF; color: #3B82F6; border: 1px solid #BFDBFE; margin-top: .5rem;
    }
    .vr-chips { display: flex; flex-wrap: wrap; gap: 7px; align-items: center; }
    .vr-chip {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 6px 13px; border-radius: 20px; font-size: .78rem; font-weight: 600;
      background: #F1F5F9; color: #334155; border: 1px solid #E2E8F0;
    }
    .vr-chip i { color: var(--green-dark); font-size: .8rem; }

    /* ── Main two-column grid ─────────────────────── */
    .vr-main-grid {
      display: grid;
      grid-template-columns: 60% 40%;
      gap: 1.5rem;
      align-items: start;
    }
    @media (max-width: 768px) { .vr-main-grid { grid-template-columns: 1fr; } }

    /* Left column flows naturally */
    .vr-left-col { display: flex; flex-direction: column; gap: 16px; }

    /* Right column is sticky */
    .vr-right-col {
      display: flex; flex-direction: column; gap: 16px;
      position: sticky; top: 20px;
    }
    @media (max-width: 768px) { .vr-right-col { position: static; } }

    .vr-card {
      background: #fff; border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,.10); padding: 1.25rem 1.375rem;
      border-left: 3px solid var(--green-dark);
    }

    /* Section titles */
    .vr-section {
      font-size: .75rem; font-weight: 800; text-transform: uppercase;
      letter-spacing: .09em; color: #3a4a3e;
      display: flex; align-items: center; gap: 8px;
      border-bottom: 2px solid #e4ede7; padding-bottom: 11px; margin-bottom: 14px;
    }
    .vr-section i { color: var(--green-dark); font-size: .9rem; }

    /* Detail grid */
    .vr-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .vr-detail-item {
      display: flex; align-items: center; gap: 8px;
      padding: 9px 12px; background: #f8faf9;
      border-radius: 8px; border: 1px solid #ddeee4;
      font-size: .82rem; color: #1e2e24;
    }
    .vr-detail-item i {
      color: #fff; font-size: .78rem;
      min-width: 24px; height: 24px; flex-shrink: 0;
      background: var(--green-dark); border-radius: 50%;
      display: inline-flex; align-items: center; justify-content: center;
    }
    .vr-detail-item .lbl { color: #64748b; margin-right: 3px; }

    /* Amenity pills */
    .vr-amenities { display: flex; flex-wrap: wrap; gap: 7px; }
    .vr-amenity {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 6px 13px; border-radius: 20px; font-size: .78rem; font-weight: 700;
      background: var(--green-dark); color: #fff; border: 1px solid var(--green-dark);
    }
    .vr-amenity i { color: #fff; opacity: .9; }

    /* Actions */
    .vr-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: .75rem; }
    .vr-btn {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 10px 18px; border-radius: 10px; font-weight: 700; font-size: .85rem;
      text-decoration: none; transition: all .15s; cursor: pointer; border: none;
    }
    .vr-btn-primary { background: var(--green-dark); color: #fff; box-shadow: 0 4px 14px rgba(26,122,60,.3); }
    .vr-btn-primary:hover { background: var(--green-mid); color: #fff; }
    .vr-btn-outline { background: #fff; color: #334155; border: 1.5px solid #E2E8F0; }
    .vr-btn-outline:hover { background: #F1F5F9; }

    /* ── Map inside card ──────────────────────────── */
    .vr-map-wrap { position: relative; border-radius: 8px; overflow: hidden; margin-top: 4px; }
    #vr-map { width: 100%; height: 280px; }
    .vr-map-overlay {
      position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
      background: rgba(255,255,255,.95); backdrop-filter: blur(8px);
      border: 1px solid #E2E8F0; border-radius: 12px;
      padding: 9px 16px; font-size: .82rem; font-weight: 600; color: #334155;
      display: flex; align-items: center; gap: 7px; z-index: 999;
      white-space: nowrap; max-width: calc(100% - 28px);
      overflow: hidden; text-overflow: ellipsis;
      box-shadow: 0 2px 8px rgba(0,0,0,.1);
    }
    .vr-map-overlay i { color: var(--green-dark); }

    /* Error page */
    .vr-error {
      max-width: 560px; margin: 80px auto; padding: 40px 32px;
      background: #fff; border: 1px solid #E2E8F0; border-radius: 16px;
      text-align: center; box-shadow: 0 1px 3px rgba(0,0,0,.08);
    }
    .vr-error i { font-size: 2.5rem; color: #EF4444; }
    .vr-error h3 { margin: 12px 0 8px; font-size: 1.3rem; color: #0F172A; }
    .vr-error p { color: #64748b; font-size: .9rem; }

    /* ── SHAP section (lives in left col) ────────── */

    .vr-shap-title {
      font-size: .75rem; font-weight: 800; text-transform: uppercase;
      letter-spacing: .09em; color: #3a4a3e;
      display: flex; align-items: center; gap: 8px;
      border-bottom: 2px solid #e4ede7; padding-bottom: 11px; margin-bottom: 16px;
    }
    .vr-shap-title i { color: var(--green-dark); font-size: .9rem; }

    #vr-shap-factors { display: flex; flex-direction: column; gap: 10px; }

    .vr-shap-row { display: grid; grid-template-columns: 170px minmax(0,1fr) 110px; gap: 10px; align-items: center; }
    @media (max-width: 680px) { .vr-shap-row { grid-template-columns: 1fr; gap: 4px; } }

    .vr-shap-label-wrap { display: flex; align-items: center; gap: 6px; }
    .vr-shap-label { font-size: .82rem; font-weight: 600; color: #334155; }
    .vr-shap-info-btn {
      width: 18px; height: 18px; border-radius: 50%; border: 1.5px solid #CBD5E1;
      background: #F8FAFC; color: #64748b; font-size: .65rem; font-weight: 700;
      cursor: pointer; flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center;
      transition: all .15s;
    }
    .vr-shap-info-btn:hover { background: var(--green-dark); color: #fff; border-color: var(--green-dark); }

    .vr-shap-bar-wrap { display: flex; align-items: center; }
    .vr-shap-bar-outer {
      width: 100%; height: 10px; background: #F1F5F9;
      border-radius: 99px; overflow: hidden;
    }
    .vr-shap-bar-inner { height: 100%; border-radius: 99px; transition: width .5s ease; }

    .vr-shap-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; }
    .vr-shap-meta strong { font-size: .82rem; color: #0F172A; }
    .vr-shap-direction { font-size: .72rem; font-weight: 700; }
    .vr-shap-direction.up   { color: var(--green-dark); font-weight: 800; }
    .vr-shap-direction.down { color: var(--red-deep);   font-weight: 800; }
    .vr-shap-eur { font-size: .7rem; color: #64748b; }

    .vr-shap-error { color: #EF4444; font-size: .85rem; }
    #vr-shap-base-note {
      font-size: .78rem; color: #64748b; margin-top: 14px;
      padding: 10px 14px; background: #f8faf9;
      border-left: 3px solid var(--green-dark); border-radius: 0 8px 8px 0;
      display: none;
    }

    /* Spinner while loading */
    .vr-shap-spinner {
      display: flex; flex-direction: column; align-items: center; gap: 10px;
      padding: 24px 0;
    }
    .vr-shap-spinner .spin {
      width: 32px; height: 32px; border: 3px solid #E2E8F0;
      border-top-color: var(--green-dark); border-radius: 50%;
      animation: vr-spin .8s linear infinite;
    }
    @keyframes vr-spin { to { transform: rotate(360deg); } }

    /* ── Model metrics card ───────────────────────────────────── */
    .vr-metric-progress {
      height: 8px; background: #F1F5F9; border-radius: 99px;
      overflow: hidden; margin: 8px 0 4px;
    }
    .vr-metric-progress span {
      display: block; height: 100%;
      background: linear-gradient(90deg, var(--green-dark), var(--green-mid));
      border-radius: 99px; transition: width .6s ease;
    }
    .vr-metric-boxes {
      display: flex; flex-direction: column;
      gap: 10px; margin-top: 14px;
    }
    .vr-metric-box {
      border-radius: 10px; padding: 13px 16px;
      border: 1px solid transparent;
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
    }
    .vr-metric-box.blue   { background: #EFF6FF; border-color: #BFDBFE; }
    .vr-metric-box.purple { background: #F5F3FF; border-color: #DDD6FE; }
    .vr-metric-box.green  { background: var(--green-light); border-color: var(--green-border); }
    .vr-metric-box-label { font-size: .78rem; font-weight: 600; color: #64748b; }
    .vr-metric-box-label i { margin-right: 5px; }
    .vr-metric-box-value { font-size: 1.25rem; font-weight: 800; color: var(--green-dark); white-space: nowrap; }
    .badge-soft {
      display: inline-block; padding: 2px 10px; border-radius: 12px;
      font-size: .7rem; font-weight: 700;
      background: var(--green-light); color: var(--green-dark); border: 1px solid var(--green-border);
      margin-left: 6px;
    }
    #vr-metric-desc { font-size: .78rem; color: #64748b; margin-top: 10px; line-height: 1.6; }

    /* ── Info Modal ──────────────────────────────────────────── */
    .vr-shap-modal-backdrop {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.45); z-index: 9999;
      align-items: center; justify-content: center;
    }
    .vr-shap-modal-backdrop.active { display: flex; }
    .vr-shap-modal-box {
      background: #fff; border-radius: 16px; padding: 28px 28px 24px;
      max-width: 440px; width: 90%; position: relative;
      box-shadow: 0 20px 60px rgba(0,0,0,.18);
    }
    .vr-shap-modal-close {
      position: absolute; top: 14px; right: 14px;
      background: none; border: none; font-size: 1.4rem;
      cursor: pointer; color: #94A3B8; line-height: 1;
    }
    .vr-shap-modal-close:hover { color: #0F172A; }
    .vr-shap-modal-title { font-size: 1rem; font-weight: 700; color: #0F172A; margin-bottom: 10px; }
    .vr-shap-modal-desc  { font-size: .88rem; color: #475569; line-height: 1.6; }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>

  <% if (sample) { %>
  <%
    const amenityMeta = {
      garage:           { icon: 'bi-car-front',        text: 'Garaje' },
      terrace:          { icon: 'bi-brightness-high',  text: 'Terraza' },
      garden:           { icon: 'bi-tree',             text: 'Jardín' },
      swimming_pool:    { icon: 'bi-water',            text: 'Piscina' },
      lift:             { icon: 'bi-arrow-up-square',  text: 'Ascensor' },
      balcony:          { icon: 'bi-columns-gap',      text: 'Balcón' },
      air_conditioner:  { icon: 'bi-snow',             text: 'Aire acondicionado' },
      built_in_wardrobe:{ icon: 'bi-box-seam',         text: 'Armarios empotrados' },
      chimney:          { icon: 'bi-fire',             text: 'Chimenea' },
      storage_room:     { icon: 'bi-archive',          text: 'Trastero' },
      reduced_mobility: { icon: 'bi-person-wheelchair',text: 'Accesible' },
      unfurnished:      { icon: 'bi-dash-circle',      text: 'Sin amueblar' }
    };
    const activeAmenities = Object.entries(amenityMeta).filter(([k]) => sample.input[k] == 1);
  %>

  <div class="vr-page">

    <!-- ── Hero price card ── -->
    <div class="vr-hero-card">
      <div>
        <div class="vr-hero-label"><i class="bi bi-house-door"></i> Precio estimado de venta</div>
        <div class="vr-price">
          <%= typeof sample.price === 'number'
            ? sample.price.toLocaleString('es-ES', { minimumFractionDigits: 0, maximumFractionDigits: 0 })
            : sample.price %> <%= sample.currency %>
        </div>
        <div class="vr-price-sub">Estimación basada en modelo predictivo</div>
        <span class="vr-model-pill"><%= sample.modelo %></span>
        <div class="vr-actions">
          <a href="/venta" class="vr-btn vr-btn-primary"><i class="bi bi-arrow-repeat"></i> Nueva predicción</a>
          <a href="/dashboard" class="vr-btn vr-btn-outline"><i class="bi bi-arrow-left"></i> Volver</a>
        </div>
      </div>
      <div class="vr-chips">
        <span class="vr-chip"><i class="bi bi-building"></i> <%= sample.input.loc_city || 'N/A' %></span>
        <span class="vr-chip"><i class="bi bi-house"></i> <%= sample.input.house_type %></span>
        <span class="vr-chip"><i class="bi bi-arrows-fullscreen"></i> <%= sample.input.m2_useful %> m²</span>
        <span class="vr-chip"><i class="bi bi-door-closed"></i> <%= sample.input.room_num %> hab.</span>
        <span class="vr-chip"><i class="bi bi-droplet"></i> <%= sample.input.bath_num %> baños</span>
      </div>
    </div>

    <!-- ── Main 2-column grid ── -->
    <div class="vr-main-grid">

      <!-- ════ LEFT COLUMN (60%) ════ -->
      <div class="vr-left-col">

        <!-- Location -->
        <div class="vr-card">
          <div class="vr-section"><i class="bi bi-geo-alt"></i> Ubicación</div>
          <div class="vr-detail-grid">
            <div class="vr-detail-item"><i class="bi bi-building"></i><span class="lbl">Ciudad:</span><%= sample.input.loc_city || '—' %></div>
            <% if (sample.input.loc_zone) { %><div class="vr-detail-item"><i class="bi bi-pin-map"></i><span class="lbl">Zona:</span><%= sample.input.loc_zone %></div><% } %>
            <% if (sample.input.loc_district) { %><div class="vr-detail-item"><i class="bi bi-signpost-2"></i><span class="lbl">Distrito:</span><%= sample.input.loc_district %></div><% } %>
            <% if (sample.input.loc_neigh) { %><div class="vr-detail-item"><i class="bi bi-houses"></i><span class="lbl">Barrio:</span><%= sample.input.loc_neigh %></div><% } %>
          </div>
        </div>

        <!-- Characteristics -->
        <div class="vr-card">
          <div class="vr-section"><i class="bi bi-list-check"></i> Características</div>
          <div class="vr-detail-grid">
            <div class="vr-detail-item"><i class="bi bi-house"></i><span class="lbl">Tipo:</span><%= sample.input.house_type %></div>
            <div class="vr-detail-item"><i class="bi bi-arrows-fullscreen"></i><span class="lbl">m² útiles:</span><%= sample.input.m2_useful %></div>
            <div class="vr-detail-item"><i class="bi bi-bounding-box"></i><span class="lbl">m² constr.:</span><%= sample.input.m2_real %></div>
            <div class="vr-detail-item"><i class="bi bi-door-closed"></i><span class="lbl">Habitaciones:</span><%= sample.input.room_num %></div>
            <div class="vr-detail-item"><i class="bi bi-droplet"></i><span class="lbl">Baños:</span><%= sample.input.bath_num %></div>
            <div class="vr-detail-item"><i class="bi bi-layers"></i><span class="lbl">Planta:</span><%= sample.input.floor %></div>
            <% if (sample.input.ground_size > 0) { %><div class="vr-detail-item"><i class="bi bi-textarea-resize"></i><span class="lbl">Parcela:</span><%= sample.input.ground_size %> m²</div><% } %>
            <div class="vr-detail-item"><i class="bi bi-calendar3"></i><span class="lbl">Año:</span><%= sample.input.construct_date %></div>
            <div class="vr-detail-item"><i class="bi bi-tools"></i><span class="lbl">Estado:</span><%= sample.input.condition %></div>
            <div class="vr-detail-item"><i class="bi bi-lightning-charge"></i><span class="lbl">Energía:</span><%= sample.input.energetic_certif %></div>
            <div class="vr-detail-item"><i class="bi bi-thermometer-half"></i><span class="lbl">Calefacción:</span><%= sample.input.heating %></div>
            <div class="vr-detail-item"><i class="bi bi-compass"></i><span class="lbl">Orientación:</span><%= sample.input.orientation %></div>
          </div>
        </div>

        <!-- Amenities -->
        <% if (activeAmenities.length) { %>
        <div class="vr-card">
          <div class="vr-section"><i class="bi bi-stars"></i> Servicios incluidos</div>
          <div class="vr-amenities">
            <% activeAmenities.forEach(([k, v]) => { %>
              <span class="vr-amenity"><i class="bi <%= v.icon %>"></i> <%= v.text %></span>
            <% }); %>
          </div>
        </div>
        <% } %>

        <!-- SHAP factors -->
        <div class="vr-card">
          <div class="vr-shap-title"><i class="bi bi-bar-chart-steps"></i> Factores que determinan el precio</div>
          <p style="font-size:.82rem; color:#64748b; margin: 0 0 14px;">
            El modelo analiza <strong>todas las características del inmueble</strong> y calcula cuánto
            sube o baja el precio estimado respecto a la media del mercado. Las barras muestran
            la importancia relativa de cada factor y su dirección (▲ sube, ▼ baja).
          </p>
          <div id="vr-shap-factors">
            <div class="vr-shap-spinner"><div class="spin"></div><span style="font-size:.8rem;color:#64748b;">Calculando importancia de variables...</span></div>
          </div>
          <div id="vr-shap-base-note"></div>
        </div>

      </div><!-- /vr-left-col -->

      <!-- ════ RIGHT COLUMN (40%, sticky) ════ -->
      <div class="vr-right-col">

        <!-- Map card -->
        <div class="vr-card">
          <div class="vr-section"><i class="bi bi-map"></i> Ubicación en el mapa</div>
          <div class="vr-map-wrap">
            <div id="vr-map"></div>
            <div class="vr-map-overlay" id="mapLabel">
              <i class="bi bi-geo-alt-fill"></i>
              <span><%= locationStr || 'Ubicación no especificada' %></span>
            </div>
          </div>
        </div>

        <!-- Metrics card -->
        <div class="vr-card">
          <div class="vr-shap-title"><i class="bi bi-graph-up"></i> Precisión del modelo <span class="badge-soft" id="vr-metric-name">LightGBM</span></div>
          <p style="font-size:.8rem; color:#64748b; margin:0 0 8px;">Exactitud global estimada: <strong id="vr-metric-acc-text">—</strong></p>
          <div class="vr-metric-progress"><span id="vr-metric-acc-bar" style="width:0%"></span></div>
          <div class="vr-metric-boxes">
            <div class="vr-metric-box blue">
              <div class="vr-metric-box-label"><i class="bi bi-graph-up"></i> Error medio</div>
              <div class="vr-metric-box-value" id="vr-metric-mae">—</div>
            </div>
            <div class="vr-metric-box purple">
              <div class="vr-metric-box-label"><i class="bi bi-bullseye"></i> Confianza (R²)</div>
              <div class="vr-metric-box-value" id="vr-metric-r2">—</div>
            </div>
            <div class="vr-metric-box green">
              <div class="vr-metric-box-label"><i class="bi bi-bar-chart-line"></i> Desviación</div>
              <div class="vr-metric-box-value" id="vr-metric-rmse">—</div>
            </div>
          </div>
          <p id="vr-metric-desc"></p>

          <hr style="margin: 16px 0; border-color: #e4ede7;">

          <div class="vr-shap-title" style="margin-top:4px;"><i class="bi bi-info-circle"></i> ¿Cómo funciona?</div>
          <ul style="font-size:.8rem; color:#475569; line-height:1.9; padding-left:18px; margin:0;">
            <li><strong>Analizamos</strong> todas las características físicas, de ubicación y económicas del inmueble.</li>
            <li><strong>Calculamos</strong> el impacto individual de cada factor usando SHAP (SHapley Additive exPlanations).</li>
            <li><strong>Sumamos</strong> todos los impactos al precio base para obtener el precio final estimado.</li>
          </ul>
        </div>

      </div><!-- /vr-right-col -->

    </div><!-- /vr-main-grid -->

  </div><!-- /vr-page -->

  <% } else { %>
  <!-- Error -->
  <div class="vr-error">
    <i class="bi bi-exclamation-triangle"></i>
    <h3>Error en la predicción</h3>
    <p><%= error || 'No se pudo calcular el precio de venta.' %></p>
    <div class="vr-actions" style="justify-content:center; margin-top:20px;">
      <a href="/venta" class="vr-btn vr-btn-primary"><i class="bi bi-arrow-repeat"></i> Reintentar</a>
      <a href="/dashboard" class="vr-btn vr-btn-outline"><i class="bi bi-arrow-left"></i> Volver</a>
    </div>
  </div>
  <% } %>

  <!-- Info Modal for SHAP variables -->
  <% if (sample) { %>
  <div id="vr-shap-modal" class="vr-shap-modal-backdrop">
    <div class="vr-shap-modal-box">
      <button class="vr-shap-modal-close" id="vr-shap-modal-close">×</button>
      <div class="vr-shap-modal-title" id="vr-shap-modal-title"></div>
      <div class="vr-shap-modal-desc"  id="vr-shap-modal-desc"></div>
    </div>
  </div>
  <% } %>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    <% if (sample) { %>
    const locationQuery = '<%= locationStr.replace(/\'/g, "\\'") %>';
    const cityQuery = '<%= (sample.input.loc_city || '').replace(/\'/g, "\\'") %>';

    const map = L.map('vr-map', { zoomControl: true, attributionControl: true });

    // Light tile layer matching the page theme
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 19
    }).addTo(map);

    // Green marker matching the accent colour
    const markerIcon = L.divIcon({
      html: `<div style="width:32px;height:32px;border-radius:50% 50% 50% 0;background:linear-gradient(135deg,#1a7a3c,#2d6a4f);transform:rotate(-45deg);box-shadow:0 4px 12px rgba(26,122,60,.45);border:3px solid #fff;"></div>`,
      iconSize: [32, 32],
      iconAnchor: [16, 32],
      className: ''
    });

    function showCityMarker(city) {
      fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(city + ', España')}&format=json&limit=1`, {
        headers: { 'Accept-Language': 'es' }
      })
      .then(r => r.json())
      .then(data => {
        if (data && data.length > 0) {
          const lat = parseFloat(data[0].lat);
          const lon = parseFloat(data[0].lon);
          map.setView([lat, lon], 11);
          L.marker([lat, lon], { icon: markerIcon })
            .addTo(map)
            .bindPopup(`<strong>${city}</strong>`)
            .openPopup();
          document.getElementById('mapLabel').innerHTML = `<i class="bi bi-geo-alt"></i><span>Ubicación aproximada: ${city}</span>`;
        } else {
          map.setView([40.416775, -3.703790], 6);
          document.getElementById('mapLabel').innerHTML = '<i class="bi bi-geo-alt"></i><span>Ubicación no encontrada en el mapa</span>';
        }
      })
      .catch(() => {
        map.setView([40.416775, -3.703790], 6);
        document.getElementById('mapLabel').innerHTML = '<i class="bi bi-geo-alt"></i><span>Ubicación no encontrada en el mapa</span>';
      });
    }

    if (locationQuery.trim()) {
      fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(locationQuery + ', España')}&format=json&limit=1`, {
        headers: { 'Accept-Language': 'es' }
      })
      .then(r => r.json())
      .then(data => {
        if (data && data.length > 0) {
          const lat = parseFloat(data[0].lat);
          const lon = parseFloat(data[0].lon);
          map.setView([lat, lon], 14);
          L.marker([lat, lon], { icon: markerIcon })
            .addTo(map)
            .bindPopup(`<strong><%= (sample.input.loc_city || '').replace(/\'/g, "\\'") %></strong><br><%= locationStr.replace(/\'/g, "\\'") %>`)
            .openPopup();
        } else if (cityQuery.trim()) {
          showCityMarker(cityQuery);
        } else {
          map.setView([40.416775, -3.703790], 6);
          document.getElementById('mapLabel').innerHTML = '<i class="bi bi-geo-alt"></i><span>Ubicación no encontrada en el mapa</span>';
        }
      })
      .catch(() => {
        if (cityQuery.trim()) {
          showCityMarker(cityQuery);
        } else {
          map.setView([40.416775, -3.703790], 6);
          document.getElementById('mapLabel').innerHTML = '<i class="bi bi-geo-alt"></i><span>Ubicación no encontrada en el mapa</span>';
        }
      });
    } else if (cityQuery.trim()) {
      showCityMarker(cityQuery);
    } else {
      map.setView([40.416775, -3.703790], 6);
      document.getElementById('mapLabel').innerHTML = '<i class="bi bi-geo-alt"></i><span>Sin ubicación especificada</span>';
    }
    <% } %>
  </script>

  <% if (sample) { %>
  <script>
    // Inject input data for SHAP explainability
    const ventaSample = <%- JSON.stringify({ input: sample.input }) %>;
  </script>
  <script src="/js/prediccion/venta_predict_result.js"></script>
  <% } %>
</body>
</html>
